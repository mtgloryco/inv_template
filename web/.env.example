# ── Database (Neon or Vercel Postgres) — REQUIRED ──
# Neon: https://neon.tech → create project → copy connection string
POSTGRES_URL=
DATABASE_URL=

# ── License signing (pick ONE format) ──
# Legacy license-manager-web PEM (base64) — matches LICENSE_PRIVATE_KEY in old app:
LICENSE_PRIVATE_KEY=
# OR PKCS8 DER base64 (new format):
# LICENSE_RSA_PRIVATE_KEY_B64=

# Admin dashboard login (email + password at /admin)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Optional — API key for scripts (header X-Admin-Key)
ADMIN_API_KEY=

# Customer account JWT (same as old app JWT_SECRET)
JWT_SECRET=change-me-min-32-characters-long-secret

# Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# alias also accepted:
# SMTP_PASSWORD=
SMTP_FROM=noreply@mtglory.com
ADMIN_ALERT_EMAIL=support@mtglory.com

# Downloads (was NEXT_PUBLIC_DOWNLOAD_URL_WINDOWS in old app)
GITHUB_RELEASE_URL=https://github.com/mtgloryco/glorydesk/releases/latest
WINDOWS_INSTALLER_FILE=GloryDesk_Setup_v1.0.1_Windows.exe

# ── NOT used by web/ (MongoDB from old app) ──
# MONGODB_URI=
