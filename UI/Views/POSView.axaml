<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:InventoryManagementSystem.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="InventoryManagementSystem.UI.Views.POSView"
             x:DataType="vm:POSViewModel"
             x:Name="Root">

    <Grid ColumnDefinitions="*, 420" Background="{DynamicResource PageBackgroundColor}">
        
        <!-- LEFT: Product Selection -->
        <Grid Grid.Column="0" RowDefinitions="Auto, *" ColumnDefinitions="*, Auto" Margin="24">
            
            <!-- Header -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,20">
                 <!-- Icon placeholder or logo could go here -->
                 <StackPanel>
                     <TextBlock Text="{Binding Language.Resources[POS_Title]}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextColor}"/>
                     <TextBlock Text="{Binding Language.Resources[POS_Subtitle]}" FontSize="14" Foreground="Gray"/>
                 </StackPanel>
            </StackPanel>
                
                <Border Grid.Column="1" Width="300" Background="{DynamicResource ContentBackgroundColor}" CornerRadius="8" Padding="12,0" 
                        BoxShadow="0 1 2 0 #0F000000" VerticalAlignment="Center">
                    <Grid ColumnDefinitions="Auto, *">
                        <TextBlock Text="🔍" VerticalAlignment="Center" Margin="0,0,8,0" Opacity="0.5"/>
                        <TextBox Grid.Column="1" Text="{Binding SearchText}" Watermark="Search by Name or SKU..." 
                                 FontSize="14" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center"/>
                    </Grid>
                </Border>
            

            <!-- Product Grid -->
            <ScrollViewer Grid.Row="1" Grid.ColumnSpan="2" Padding="0,0,16,0">
                <ItemsControl ItemsSource="{Binding AvailableProducts}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding #Root.((vm:POSViewModel)DataContext).AddToCartCommand}" CommandParameter="{Binding .}"
                                    Width="180" Height="220" Margin="0,0,16,16" 
                                    Background="Transparent" BorderThickness="0" Padding="0"
                                    CornerRadius="12">
                                <Border Background="{DynamicResource ContentBackgroundColor}" CornerRadius="12" BoxShadow="0 4 6 -1 #1A000000" ClipToBounds="True">
                                    <Grid RowDefinitions="*, Auto">
                                        <!-- Placeholder Image Area -->
                                        <Panel Grid.Row="0" Background="#F9FAFB">
                                            <TextBlock Text="{Binding Name, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" 
                                                       FontSize="48" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.1" Foreground="#4B5563"/>
                                            
                                            <!-- Stock Badge -->
                                            <Border Background="{Binding StockQuantity, Converter={x:Static ObjectConverters.IsNull}}" 
                                                    CornerRadius="4" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8" Padding="6,2">
                                                <!-- Simple Stock binding for color logic via classes would be better, but keeping simple -->
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="📦" FontSize="10"/>
                                                    <TextBlock Text="{Binding StockQuantity}" FontSize="12" FontWeight="SemiBold" Foreground="#4B5563"/>
                                                </StackPanel>
                                            </Border>
                                        </Panel>
                                        
                                        <!-- Content -->
                                        <StackPanel Grid.Row="1" Margin="12">
                                            <TextBlock Text="{Binding Category}" FontSize="10" Foreground="{DynamicResource TextSecondaryColor}" LetterSpacing="1"/>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" Margin="0,2,0,4" 
                                                       TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimaryColor}"/>
                                            <TextBlock Text="{Binding SKU}" FontSize="11" Foreground="{DynamicResource TextSecondaryColor}" Margin="0,0,0,8"/>
                                            
                                            <Separator Background="#F3F4F6" Height="1" Margin="0,0,0,8"/>
                                            
                                            <Grid ColumnDefinitions="*, Auto">
                                                <TextBlock FontSize="16" FontWeight="Bold" Foreground="#059669">
                                                    <Run Text="{Binding Price, StringFormat='{}{0:N0}'}"/>
                                                    <Run Text="{Binding #Root.DataContext.CurrencySymbol}" FontSize="12"/>
                                                </TextBlock>
                                                <Border Background="#EEF2FF" CornerRadius="12" Padding="8,2" VerticalAlignment="Center">
                                                    <TextBlock Text="Add" FontSize="11" FontWeight="SemiBold" Foreground="#4F46E5"/>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Cart / Checkout Area (Right) -->
        <Border Grid.Column="1" Background="{DynamicResource ContentBackgroundColor}" CornerRadius="10" Padding="20" BoxShadow="0 4 10 0 #20000000">
            <Grid RowDefinitions="Auto, *, Auto, Auto">
                <TextBlock Grid.Row="0" Text="{Binding Language.Resources[POS_CurrentOrder]}" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                
                <!-- Cart List -->
                <ScrollViewer Grid.Row="1" Margin="0,0,0,15">
                    <ItemsControl ItemsSource="{Binding CartItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*, Auto, Auto, Auto" Margin="0,5">
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Product.Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding UnitPrice, StringFormat='{}{0:N0} RWF'}" FontSize="12" Foreground="Gray"/>
                                    </StackPanel>
                                    
                                    <!-- Qty Controls -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" Margin="10,0">
                                        <Button Content="-" Command="{Binding Decrement}" Padding="5" Width="30"/>
                                        <TextBlock Text="{Binding Quantity}" VerticalAlignment="Center" Width="20" TextAlignment="Center"/>
                                        <Button Content="+" Command="{Binding Increment}" Padding="5" Width="30"/>
                                    </StackPanel>
                                    
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" FontWeight="Bold" Margin="10,0">
                                        <Run Text="{Binding Subtotal, StringFormat='{}{0:N0}'}"/>
                                        <Run Text="{Binding #Root.DataContext.CurrencySymbol}"/>
                                    </TextBlock>
                                    
                                    <Button Grid.Column="3" Content="×" Command="{Binding #Root.DataContext.RemoveFromCartCommand}" 
                                            CommandParameter="{Binding}"
                                            Background="Transparent" Foreground="Red" BorderThickness="0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                
                <!-- Totals and Payment -->
                <StackPanel Grid.Row="2" Spacing="10">
                    <Separator/>
                    <Grid ColumnDefinitions="*, Auto">
                        <TextBlock Text="{Binding Language.Resources[POS_TotalAmount]}" FontSize="16"/>
                        <TextBlock Grid.Column="1" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextColor}">
                            <Run Text="{Binding TotalAmount, StringFormat='{}{0:N0}'}"/>
                            <Run Text="{Binding CurrencySymbol}"/>
                        </TextBlock>
                    </Grid>
                    
                    <Grid ColumnDefinitions="*, Auto">
                        <TextBlock Text="{Binding Language.Resources[POS_AmountPaid]}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding AmountPaid}" Width="120" Watermark="e.g. 5000" HorizontalContentAlignment="Right"/>
                    </Grid>

                    <Grid ColumnDefinitions="*, Auto">
                        <TextBlock Text="{Binding Language.Resources[POS_ChangeDue]}" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AccentColor}">
                            <Run Text="{Binding ChangeDue, StringFormat='{}{0:N0}'}"/>
                            <Run Text="{Binding CurrencySymbol}"/>
                        </TextBlock>
                    </Grid>
                </StackPanel>
                
                <!-- Checkout Button -->
                <Button Grid.Row="3" Margin="0,20,0,0" 
                        Content="{Binding Language.Resources[POS_Checkout]}" 
                        Command="{Binding CheckoutCommand}"
                        Classes="accent" HorizontalAlignment="Stretch" Padding="15" FontSize="16" FontWeight="Bold"/>

            </Grid>
        </Border>

        <!-- RECEIPT MODAL -->
        <Border Grid.ColumnSpan="2" Background="#80000000" IsVisible="{Binding IsReceiptModalOpen}">
            <Border Background="{DynamicResource ContentBackgroundColor}" CornerRadius="16" Width="420" VerticalAlignment="Center" HorizontalAlignment="Center" 
                    Padding="0" BoxShadow="0 20 25 -5 #1A000000" ClipToBounds="True">
                <Grid RowDefinitions="Auto, *, Auto">
                    <!-- Header -->
                    <Border Background="#10B981" Padding="20">
                        <StackPanel Spacing="8">
                            <TextBlock Text="✓" FontSize="32" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Payment Successful!" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Content -->
                    <ScrollViewer Grid.Row="1" MaxHeight="400" Padding="24">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Receipt Details" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryColor}"/>
                            <Border Background="{DynamicResource PageBackgroundColor}" CornerRadius="8" Padding="16" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                                <TextBlock Text="{Binding LastReceiptText}" FontFamily="Monospace" FontSize="12" Foreground="{DynamicResource TextSecondaryColor}" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Actions -->
                    <Grid Grid.Row="2" ColumnDefinitions="*, 16, *" Margin="24" Background="{DynamicResource ContentBackgroundColor}">
                        <Button Grid.Column="0" Content="Close" Command="{Binding CloseReceiptCommand}" 
                                HorizontalAlignment="Stretch" Foreground="{DynamicResource TextSecondaryColor}" Background="{DynamicResource PageBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6"/>
                        <Button Grid.Column="2" Content="Print Receipt" Command="{Binding PrintReceiptCommand}" 
                                HorizontalAlignment="Stretch" Background="#10B981" Foreground="White" CornerRadius="6" FontWeight="SemiBold"/>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
