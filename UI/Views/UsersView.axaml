<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:InventoryManagementSystem.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="InventoryManagementSystem.UI.Views.UsersView"
             x:DataType="vm:UsersViewModel">
    
    <SplitView IsPaneOpen="{Binding IsPaneOpen}"
               DisplayMode="Overlay"
               OpenPaneLength="350"
               PaneBackground="White">
        <SplitView.Pane>
            <Border Padding="20">
                <StackPanel Spacing="15">
                    <TextBlock Text="{Binding PaneTitle}" FontSize="20" FontWeight="Bold" Foreground="#333"/>
                    
                    <TextBox Watermark="Username" Text="{Binding Username}"/>
                    <TextBox Watermark="Password" Text="{Binding Password}" PasswordChar="*"/>
                    
                    <TextBlock Text="Role" Foreground="#666" FontSize="12"/>
                    <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole}" HorizontalAlignment="Stretch"/>
                    
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF5252" TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="Cancel" Command="{Binding CancelPaneCommand}" />
                        <Button Content="Save" Classes="accent" Command="{Binding SaveUserCommand}" Background="#007ACC" Foreground="White" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </SplitView.Pane>
        
        <SplitView.Content>
            <Grid RowDefinitions="Auto, *" Margin="30">
                 <!-- Header -->
                <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,25">
                    <TextBlock Text="User Management" FontSize="28" FontWeight="SemiBold" Foreground="#333" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="+ New User" Command="{Binding OpenAddUserPaneCommand}" Background="#2E7D32" Foreground="White"/>
                </Grid>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Users}" 
                          AutoGenerateColumns="False" 
                          IsReadOnly="True" 
                          GridLinesVisibility="All"
                          BorderThickness="1" BorderBrush="#EEE" Background="White">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*"/>
                        <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="150"/>
                        
                        <DataGridTemplateColumn Header="Actions" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Delete" Command="{Binding $parent[UserControl].((vm:UsersViewModel)DataContext).DeleteUserCommand}" CommandParameter="{Binding .}" Background="#D32F2F" Foreground="White" FontSize="10" Padding="5,2"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </SplitView.Content>
    </SplitView>
</UserControl>
