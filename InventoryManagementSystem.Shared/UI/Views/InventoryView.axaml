<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:InventoryManagementSystem.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="InventoryManagementSystem.UI.Views.InventoryView"
             x:DataType="vm:InventoryViewModel"
             x:Name="Root">
    
    <SplitView IsPaneOpen="{Binding IsPaneOpen}"
               DisplayMode="Overlay"
               OpenPaneLength="400"
               PaneBackground="{DynamicResource ContentBackgroundColor}">
        
        <SplitView.Pane>
            <Border Padding="20">
                <StackPanel Spacing="15">
                    <TextBlock Text="{Binding PaneTitle}" FontSize="20" FontWeight="Bold"/>
                    
                    <!-- Product Form -->
                    <StackPanel Spacing="15" IsVisible="{Binding !IsStockMode}">
                        <TextBox Watermark="{Binding Language.Resources[Inv_ProductName]}" Text="{Binding CurrentProduct.Name}" />
                        <TextBox Watermark="{Binding Language.Resources[Inv_SKU]}" Text="{Binding CurrentProduct.SKU}" />
                        <TextBox Watermark="{Binding Language.Resources[Inv_Category]}" Text="{Binding CurrentProduct.Category}" />
                        <TextBox Watermark="{Binding Language.Resources[Inv_Unit]}" Text="{Binding CurrentProduct.Unit}" />
                        
                        <!-- Price and Cost are now set only during Stock Actions -->
                        
                        <TextBox Watermark="{Binding Language.Resources[Inv_InitialStock]}" Text="{Binding CurrentProduct.StockQuantity}" IsEnabled="{Binding CurrentProduct.Id, Converter={x:Static ObjectConverters.IsNull}}"/>
                    </StackPanel>

                    <!-- Stock Adjustment Form -->
                    <StackPanel Spacing="15" IsVisible="{Binding IsStockMode}">
                        <TextBlock Text="{Binding Language.Resources[Inv_MovementType]}" FontSize="12"/>
                        <ComboBox ItemsSource="{Binding MovementTypes}" SelectedItem="{Binding SelectedMovementType}" HorizontalAlignment="Stretch"/>
                        
                        <TextBlock Text="{Binding Language.Resources[Inv_Quantity]}" FontSize="12"/>
                        <TextBox Watermark="{Binding Language.Resources[Inv_Quantity]}" Text="{Binding AdjustmentQuantity}" />

                        <!-- Batch Financials -->
                        <StackPanel IsVisible="{Binding IsMovementIn}" Spacing="5">
                            <TextBlock Text="{Binding Language.Resources[Inv_CostPerUnit]}" FontSize="12"/>
                            <TextBox Watermark="{Binding Language.Resources[Inv_CostPerUnit]}" Text="{Binding AdjustmentCostPerUnit}" />
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsMovementOut}" Spacing="5">
                            <TextBlock Text="{Binding Language.Resources[Inv_SellingPrice]}" FontSize="12"/>
                            <TextBox Watermark="{Binding Language.Resources[Inv_SellingPrice]}" Text="{Binding AdjustmentUnitPrice}" />
                        </StackPanel>
                        
                        <TextBlock Text="{Binding Language.Resources[Inv_Reason]}" FontSize="12"/>
                        <TextBox Watermark="{Binding Language.Resources[Inv_Reason]}" Text="{Binding AdjustmentReason}" />
                    </StackPanel>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF5252" TextWrapping="Wrap" IsVisible="{Binding HasError}"/>
                    
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="{Binding Language.Resources[Inv_Cancel]}" Command="{Binding CancelPaneCommand}" />
                        <Button Content="{Binding Language.Resources[Inv_Save]}" Classes="accent" Command="{Binding SaveProductCommand}" Background="#007ACC" Foreground="White" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </SplitView.Pane>

        <SplitView.Content>
            <Grid RowDefinitions="Auto, Auto, *">
                <!-- Quick Actions Toolbar -->
                <Border Grid.Row="0" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,10,12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Quick Actions:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <Button Content="Purchase Orders" Command="{Binding GoToPurchaseOrdersCommand}" Background="#007ACC" Foreground="White" Padding="12,6" FontWeight="SemiBold" CornerRadius="4" />
                    </StackPanel>
                </Border>

                <!-- Header / Toolbar -->
                <Grid Grid.Row="1" ColumnDefinitions="*, Auto, Auto" Margin="0,0,10,10">
                    <TextBox Text="{Binding SearchText}" Watermark="{Binding Language.Resources[Inv_SearchPlaceholder]}" Width="300" HorizontalAlignment="Left"/>
                    
                    <Button Grid.Column="1" Margin="0,0,10,0" 
                            Content="{Binding Language.Resources[Inv_Import]}" 
                            Command="{Binding ImportProductsCommand}" 
                            IsEnabled="{Binding CanBulkImport}"
                            ToolTip.Tip="{Binding BulkImportTooltip}"
                            Background="{DynamicResource PageBackgroundColor}" />
                            
                    <Button Grid.Column="2" Content="{Binding Language.Resources[Inv_NewProduct]}" Command="{Binding OpenAddProductPaneCommand}" Background="#2E7D32" Foreground="White"/>
                </Grid>

                <!-- Product List -->
                <DataGrid Grid.Row="2" ItemsSource="{Binding Products}" 
                          SelectedItem="{Binding SelectedProduct}"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True" 
                          CanUserSortColumns="True"
                          GridLinesVisibility="All"
                          BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" Background="{DynamicResource ContentBackgroundColor}">
                    <DataGrid.Columns>
                        <!-- Removed ID Column -->
                        <DataGridTextColumn Header="{Binding Language.Resources[Inv_SKU]}" Binding="{Binding SKU}" Width="100"/>
                        <DataGridTextColumn Header="{Binding Language.Resources[Inv_ProductName]}" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="{Binding Language.Resources[Inv_Category]}" Binding="{Binding Category}" Width="100"/>
                        <DataGridTextColumn Header="{Binding Language.Resources[Inv_Stock]}" Binding="{Binding StockQuantity}" Width="80"/>
                        <DataGridTextColumn Header="{Binding Language.Resources[Inv_Unit]}" Binding="{Binding Unit}" Width="60"/>
                        <!-- Price is roughly displayed here, but actual sale price is set per transaction -->
                        <DataGridTemplateColumn Header="{Binding Language.Resources[Inv_SellingPrice]}" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center" Margin="5,0,0,0">
                                        <Run Text="{Binding Price, StringFormat='{}{0:N0}'}"/>
                                        <Run Text="{Binding #Root.DataContext.CurrencySymbol}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <DataGridTemplateColumn Header="{Binding Language.Resources[Inv_Actions]}" Width="190">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <Button Content="Stock" Command="{Binding $parent[UserControl].((vm:InventoryViewModel)DataContext).OpenStockPaneCommand}" CommandParameter="{Binding .}" Background="#F57C00" Foreground="White" FontSize="10" Padding="5,2"/>
                                        <Button Content="Edit" Command="{Binding $parent[UserControl].((vm:InventoryViewModel)DataContext).OpenEditProductPaneCommand}" CommandParameter="{Binding .}" FontSize="10" Padding="5,2"/>
                                        <Button Content="Delete" Command="{Binding $parent[UserControl].((vm:InventoryViewModel)DataContext).DeleteProductCommand}" CommandParameter="{Binding .}" Background="#D32F2F" Foreground="White" FontSize="10" Padding="5,2"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </SplitView.Content>
    </SplitView>
</UserControl>
