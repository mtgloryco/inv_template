<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:InventoryManagementSystem.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="InventoryManagementSystem.UI.Views.MainView"
             x:DataType="vm:MainViewModel">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding SidebarGridLength}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource PageBackgroundColor}" Padding="20" IsVisible="{Binding IsLoggedIn}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="15">
                    <TextBlock Text="IMS" FontWeight="Bold" FontSize="24" Margin="0,30,0,20"/>
                    <TextBlock Text="{Binding CurrentUserName}" FontWeight="SemiBold" Margin="0,0,0,20"/>
                    
                    <Button Content="{Binding Language.Resources[Dashboard]}" Command="{Binding GoToDashboardCommand}" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Left" Padding="10"/>
                    <Button Content="{Binding Language.Resources[POS]}" Command="{Binding GoToPOSCommand}" IsVisible="{Binding CanAccessPOS}" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Left" Padding="10"/>
                    <Button Content="{Binding Language.Resources[Inventory]}" Command="{Binding GoToInventoryCommand}" IsVisible="{Binding CanAccessInventory}" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Left" Padding="10"/>
                    <Button Content="{Binding Language.Resources[Manufacturing]}" Command="{Binding GoToManufacturingCommand}" IsVisible="{Binding CanAccessManufacturing}" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Left" Padding="10"/>
                    <Button Content="{Binding Language.Resources[Suppliers]}" Command="{Binding GoToSuppliersCommand}" IsVisible="{Binding CanAccessSuppliers}" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Left" Padding="10"/>
                    <Button Content="{Binding Language.Resources[Reports]}" Command="{Binding GoToReportsCommand}" IsVisible="{Binding CanAccessReports}" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Left" Padding="10"/>
                    <Button Content="{Binding Language.Resources[Returns]}" Command="{Binding GoToReturnsCommand}" IsVisible="{Binding CanAccessReturns}" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Left" Padding="10"/>
                    <Button Content="{Binding Language.Resources[Users]}" Command="{Binding GoToUsersCommand}" IsVisible="{Binding IsAdmin}" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Left" Padding="10"/>
                    <Button Content="{Binding Language.Resources[License]}" Command="{Binding GoToLicenseCommand}" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Left" Padding="10"/>
                    <Button Content="{Binding Language.Resources[Settings]}" Command="{Binding GoToSettingsCommand}" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Left" Padding="10"/>
                    <Button Content="{Binding UpdateStatusText}" Command="{Binding CheckForUpdatesCommand}" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Left" Padding="10"/>

                    <Border Background="{DynamicResource ThemeControlLowBrush}" CornerRadius="6" Padding="10" IsVisible="{Binding CanAccessCloudSync}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Cloud Sync" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SyncStatusText}" FontSize="11" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding LastSyncDisplay, StringFormat='Last sync: {0}'}" FontSize="10" Foreground="Gray"/>
                            <TextBox Watermark="Cloud email" Text="{Binding CloudEmail}" IsEnabled="{Binding !IsSyncing}"/>
                            <TextBox Watermark="Password" Text="{Binding CloudPassword}" PasswordChar="*" IsEnabled="{Binding !IsSyncing}"/>
                            <TextBox Watermark="Organization" Text="{Binding CloudOrganizationName}" IsEnabled="{Binding !IsSyncing}"/>
                            <Button Content="Connect / Register" Command="{Binding ConnectCloudCommand}" IsEnabled="{Binding !IsSyncing}" HorizontalAlignment="Stretch"/>
                            <Button Content="Sync Now" Command="{Binding SyncNowCommand}" IsEnabled="{Binding !IsSyncing}" HorizontalAlignment="Stretch"/>
                            <Grid ColumnDefinitions="*,*">
                                <Button Content="Backup" Command="{Binding BackupToCloudCommand}" IsEnabled="{Binding !IsSyncing}" Margin="0,0,4,0"/>
                                <Button Grid.Column="1" Content="Restore" Command="{Binding RestoreFromCloudCommand}" IsEnabled="{Binding !IsSyncing}" Margin="4,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <StackPanel VerticalAlignment="Bottom" Margin="0,40,0,0" Spacing="10">
                        <Button Content="Toggle Theme" Command="{Binding ToggleThemeCommand}" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Left" Padding="10"/>
                        
                        <TextBlock Text="Language / Ururimi" FontSize="10" Foreground="Gray"/>
                        <Grid ColumnDefinitions="*,*,*">
                           <Button Content="EN" Command="{Binding ChangeLanguageCommand}" CommandParameter="en" Background="Transparent" BorderThickness="0" FontSize="10"/>
                           <Button Grid.Column="1" Content="FR" Command="{Binding ChangeLanguageCommand}" CommandParameter="fr" Background="Transparent" BorderThickness="0" FontSize="10"/>
                           <Button Grid.Column="2" Content="RW" Command="{Binding ChangeLanguageCommand}" CommandParameter="rw" Background="Transparent" BorderThickness="0" FontSize="10"/>
                        </Grid>
                    
                         <Button Content="{Binding Language.Resources[Exit]}" Command="{Binding LogoutCommand}" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Left" Padding="10" Foreground="#FF5252"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Main Content (Spans entire window if not logged in) -->
        <Border Grid.Column="1">
            <Grid RowDefinitions="Auto,*">
                 <Button Grid.Row="0" Content="← Go Back" Command="{Binding GoBackCommand}" IsVisible="{Binding CanGoBack}" 
                         Margin="20,10,0,0" Background="Transparent" Foreground="Gray" HorizontalAlignment="Left" Cursor="Hand"/>

                 <!-- Update Notification Banner -->
                 <Border Grid.Row="0" Background="#E3F2FD" BorderBrush="#2196F3" BorderThickness="1" CornerRadius="4" Padding="10" Margin="20,5,20,5" IsVisible="{Binding IsUpdateAvailable}" HorizontalAlignment="Center" VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal" Spacing="15">
                        <TextBlock Text="{Binding UpdateVersion, StringFormat='New Version Available: {0}'}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#0D47A1"/>
                        <Button Content="View Changes" Command="{Binding OpenReleaseNotesCommand}" Background="Transparent" Foreground="#1976D2" BorderThickness="0" Cursor="Hand"/>
                        <Button Content="Install &amp; Restart" Command="{Binding InstallUpdateCommand}" Background="#1976D2" Foreground="White" CornerRadius="4"/>
                    </StackPanel>
                 </Border>

                <ContentControl Grid.Row="1" Content="{Binding CurrentPage}" Margin="20"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
