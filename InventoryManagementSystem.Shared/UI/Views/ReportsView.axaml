<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:InventoryManagementSystem.UI.ViewModels"
             xmlns:helpers="using:InventoryManagementSystem.UI.Helpers"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="InventoryManagementSystem.UI.Views.ReportsView"
             x:DataType="vm:ReportsViewModel"
             x:Name="Root">
    
    <UserControl.Styles>
        <Style Selector="TextBlock.header">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#007ACC"/>
        </Style>
        <Style Selector="TextBlock.subHeader">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryColor}"/>
        </Style>
    </UserControl.Styles>
    
    <Grid ColumnDefinitions="260, *" RowDefinitions="Auto, *" Margin="30">
        <!-- Header -->
        <Grid Grid.ColumnSpan="2" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
            <StackPanel Spacing="6">
                <TextBlock Text="Reports &amp; Analytics" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryColor}" />
                <TextBlock Text="Choose a category and report from the sidebar. Each report opens in its own view." FontSize="13" Foreground="{DynamicResource TextSecondaryColor}"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" Spacing="10" Grid.Column="1" VerticalAlignment="Center">
                 <Button Content="Refresh" Command="{Binding LoadSelectedReportAsync}" 
                         Background="{DynamicResource ContentBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="15,8" CornerRadius="6"
                         IsVisible="{Binding !IsStockStatusSelected}"/>
                         
                 <Button Content="View Details" Command="{Binding OpenDetailsCommand}" 
                         IsEnabled="{Binding SelectedStockMovement, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" 
                         Background="{DynamicResource ContentBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="15,8" CornerRadius="6"
                         IsVisible="{Binding IsStockHistorySelected}"/>
                 
                 <Button Content="Export to CSV" Command="{Binding ExportToCsvCommand}" Background="#007ACC" Foreground="White" Padding="15,8" CornerRadius="6"
                         IsVisible="{Binding IsStockStatusSelected}"/>
                 <Button Content="Export VAT CSV" Command="{Binding ExportVatToCsvCommand}" Background="#007ACC" Foreground="White" Padding="15,8" CornerRadius="6"
                         IsVisible="{Binding IsVatReturnSelected}"/>
            </StackPanel>
        </Grid>

        <!-- Sidebar: category dropdown + report list -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{DynamicResource ContentBackgroundColor}"
                CornerRadius="8"
                BoxShadow="0 4 15 0 #10000000"
                Padding="16"
                Margin="0,0,16,0">
            <StackPanel Spacing="14">
                <StackPanel Spacing="6">
                    <TextBlock Text="Report Category" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryColor}"/>
                    <ComboBox ItemsSource="{Binding ReportCategories}"
                              SelectedItem="{Binding SelectedCategory}"
                              HorizontalAlignment="Stretch"/>
                </StackPanel>

                <Separator Height="1" Background="{DynamicResource BorderColor}"/>

                <StackPanel Spacing="6">
                    <TextBlock Text="Reports in Category" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryColor}"/>
                    <ListBox ItemsSource="{Binding ReportsInCategory}"
                             SelectedItem="{Binding SelectedReportNavItem}"
                             Background="Transparent"
                             BorderThickness="0"
                             MinHeight="420">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:ReportNavItem">
                                <Border Padding="10,8" CornerRadius="6" Margin="0,2">
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"/>
                                        <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource TextSecondaryColor}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Report content screen -->
        <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource ContentBackgroundColor}" CornerRadius="8" BoxShadow="0 4 15 0 #10000000" BorderThickness="0" ClipToBounds="True">
             <Grid RowDefinitions="Auto, *">
                  <Border Background="{DynamicResource PageBackgroundColor}" Padding="15" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1">
                      <TextBlock Text="{Binding ReportTitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryColor}" FontSize="16"/>
                  </Border>
                  
                  <Panel Grid.Row="1">
                      <!-- Balance Sheet Report -->
                      <ScrollViewer IsVisible="{Binding IsBalanceSheetSelected}" Margin="20">
                          <StackPanel Spacing="15">
                              <Grid ColumnDefinitions="*, Auto" Margin="5,0,15,5">
                                  <TextBlock Text="REPORT LINE" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryColor}" FontSize="12"/>
                                  <TextBlock Grid.Column="1" Text="BALANCE" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryColor}" FontSize="12" Margin="0,0,10,0"/>
                              </Grid>
                              <Separator Height="1" Background="{DynamicResource BorderColor}" Margin="0,0,0,5"/>
                              <ItemsControl ItemsSource="{Binding BalanceSheetLines}">
                                  <ItemsControl.ItemTemplate>
                                      <DataTemplate DataType="vm:ReportLineWrapper">
                                          <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" Padding="0,8">
                                              <Panel>
                                                  <!-- Non-clickable header/structural lines -->
                                                  <Grid ColumnDefinitions="*, Auto" Margin="{Binding Margin}" IsVisible="{Binding !Result.HasComputations}">
                                                      <TextBlock Text="{Binding Name}" 
                                                                 Classes.header="{Binding IsHeader}"
                                                                 Classes.subHeader="{Binding IsSubHeader}"
                                                                 VerticalAlignment="Center"/>
                                                      
                                                      <TextBlock Grid.Column="1" 
                                                                 Text="{Binding FormattedBalance}" 
                                                                 Classes.header="{Binding IsHeader}"
                                                                 Classes.subHeader="{Binding IsSubHeader}"
                                                                 TextAlignment="Right" 
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,10,0"/>
                                                  </Grid>
                                                  
                                                  <!-- Clickable computed balance lines -->
                                                  <Button Command="{Binding #Root.DataContext.OpenJournalEntriesCommand}"
                                                          CommandParameter="{Binding .}"
                                                          Background="#00000000"
                                                          BorderThickness="0"
                                                          Padding="0"
                                                          HorizontalAlignment="Stretch"
                                                          HorizontalContentAlignment="Stretch"
                                                          Cursor="Hand"
                                                          IsVisible="{Binding Result.HasComputations}">
                                                      <Grid ColumnDefinitions="*, Auto" Margin="{Binding Margin}" Background="#00000000" Cursor="Hand">
                                                          <TextBlock Text="{Binding Name}" 
                                                                     Classes.header="{Binding IsHeader}"
                                                                     Classes.subHeader="{Binding IsSubHeader}"
                                                                     Foreground="#007ACC"
                                                                     TextDecorations="Underline"
                                                                     Cursor="Hand"
                                                                     VerticalAlignment="Center"/>
                                                          
                                                          <TextBlock Grid.Column="1" 
                                                                     Text="{Binding FormattedBalance}" 
                                                                     Classes.header="{Binding IsHeader}"
                                                                     Classes.subHeader="{Binding IsSubHeader}"
                                                                     Foreground="#007ACC"
                                                                     TextDecorations="Underline"
                                                                     TextAlignment="Right" 
                                                                     Cursor="Hand"
                                                                     VerticalAlignment="Center"
                                                                     Margin="0,0,10,0"/>
                                                      </Grid>
                                                  </Button>
                                              </Panel>
                                          </Border>
                                      </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                              </ItemsControl>
                          </StackPanel>
                      </ScrollViewer>

                      <!-- Profit and Loss Report -->
                      <ScrollViewer IsVisible="{Binding IsProfitAndLossSelected}" Margin="20">
                          <StackPanel Spacing="15">
                              <Grid ColumnDefinitions="*, Auto" Margin="5,0,15,5">
                                  <TextBlock Text="REPORT LINE" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryColor}" FontSize="12"/>
                                  <TextBlock Grid.Column="1" Text="BALANCE" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryColor}" FontSize="12" Margin="0,0,10,0"/>
                              </Grid>
                              <Separator Height="1" Background="{DynamicResource BorderColor}" Margin="0,0,0,5"/>
                              <ItemsControl ItemsSource="{Binding ProfitAndLossLines}">
                                  <ItemsControl.ItemTemplate>
                                      <DataTemplate DataType="vm:ReportLineWrapper">
                                          <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" Padding="0,8">
                                              <Panel>
                                                  <!-- Non-clickable header/structural lines -->
                                                  <Grid ColumnDefinitions="*, Auto" Margin="{Binding Margin}" IsVisible="{Binding !Result.HasComputations}">
                                                      <TextBlock Text="{Binding Name}" 
                                                                 Classes.header="{Binding IsHeader}"
                                                                 Classes.subHeader="{Binding IsSubHeader}"
                                                                 VerticalAlignment="Center"/>
                                                      
                                                      <TextBlock Grid.Column="1" 
                                                                 Text="{Binding FormattedBalance}" 
                                                                 Classes.header="{Binding IsHeader}"
                                                                 Classes.subHeader="{Binding IsSubHeader}"
                                                                 TextAlignment="Right" 
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,10,0"/>
                                                  </Grid>
                                                  
                                                  <!-- Clickable computed balance lines -->
                                                  <Button Command="{Binding #Root.DataContext.OpenJournalEntriesCommand}"
                                                          CommandParameter="{Binding .}"
                                                          Background="#00000000"
                                                          BorderThickness="0"
                                                          Padding="0"
                                                          HorizontalAlignment="Stretch"
                                                          HorizontalContentAlignment="Stretch"
                                                          Cursor="Hand"
                                                          IsVisible="{Binding Result.HasComputations}">
                                                      <Grid ColumnDefinitions="*, Auto" Margin="{Binding Margin}" Background="#00000000" Cursor="Hand">
                                                          <TextBlock Text="{Binding Name}" 
                                                                     Classes.header="{Binding IsHeader}"
                                                                     Classes.subHeader="{Binding IsSubHeader}"
                                                                     Foreground="#007ACC"
                                                                     TextDecorations="Underline"
                                                                     Cursor="Hand"
                                                                     VerticalAlignment="Center"/>
                                                          
                                                          <TextBlock Grid.Column="1" 
                                                                     Text="{Binding FormattedBalance}" 
                                                                     Classes.header="{Binding IsHeader}"
                                                                     Classes.subHeader="{Binding IsSubHeader}"
                                                                     Foreground="#007ACC"
                                                                     TextDecorations="Underline"
                                                                     TextAlignment="Right" 
                                                                     Cursor="Hand"
                                                                     VerticalAlignment="Center"
                                                                     Margin="0,0,10,0"/>
                                                      </Grid>
                                                  </Button>
                                              </Panel>
                                          </Border>
                                      </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                              </ItemsControl>
                          </StackPanel>
                      </ScrollViewer>

                      <!-- Stock Status View -->
                      <Grid RowDefinitions="Auto, *" IsVisible="{Binding IsStockStatusSelected}">
                          <!-- Sub-toggle for Stock Status -->
                          <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="25" Margin="20,15">
                              <RadioButton Content="All Products" IsChecked="{Binding !IsLowStockReport}" Command="{Binding LoadStockReportCommand}" GroupName="StockFilter"/>
                              <RadioButton Content="Low Stock (&lt; 5 items)" IsChecked="{Binding IsLowStockReport}" Command="{Binding LoadLowStockReportCommand}" GroupName="StockFilter"/>
                          </StackPanel>
                          <DataGrid Grid.Row="1" ItemsSource="{Binding ReportData}" 
                                    AutoGenerateColumns="False" 
                                    IsReadOnly="True" 
                                    GridLinesVisibility="Horizontal"
                                    BorderThickness="0" 
                                    Background="{DynamicResource ContentBackgroundColor}"
                                    RowHeight="45">
                               <DataGrid.Columns>
                                  <DataGridTextColumn Header="SKU" Binding="{Binding SKU}" Width="120"/>
                                  <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                  <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120"/>
                                  <DataGridTextColumn Header="Qty" Binding="{Binding StockQuantity}" Width="80"/>
                                  <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="80"/>
                                  <DataGridTemplateColumn Header="Price" Width="100">
                                      <DataGridTemplateColumn.CellTemplate>
                                          <DataTemplate>
                                              <TextBlock VerticalAlignment="Center" Margin="10,0,0,0">
                                                  <Run Text="{Binding Price, StringFormat='{}{0:N0}'}"/>
                                                  <Run Text="{Binding #Root.DataContext.CurrencySymbol}"/>
                                              </TextBlock>
                                          </DataTemplate>
                                      </DataGridTemplateColumn.CellTemplate>
                                  </DataGridTemplateColumn>
                               </DataGrid.Columns>
                           </DataGrid>
                      </Grid>

                      <!-- Audit Reports -->
                      <DataGrid ItemsSource="{Binding StockHistoryData}" 
                                SelectedItem="{Binding SelectedStockMovement}"
                                IsVisible="{Binding IsStockHistorySelected}"
                                AutoGenerateColumns="False" 
                                IsReadOnly="True" 
                                GridLinesVisibility="Horizontal"
                                BorderThickness="0" 
                                Background="{DynamicResource ContentBackgroundColor}"
                                RowHeight="45">
                           <DataGrid.Columns>
                              <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="160"/>
                              <DataGridTextColumn Header="SKU" Binding="{Binding ProductId}" Width="100"/>
                              <DataGridTextColumn Header="Type" Binding="{Binding MovementType}" Width="80"/>
                              <DataGridTextColumn Header="Qty" Binding="{Binding QuantityChanged}" Width="80"/>
                              <DataGridTextColumn Header="Batch Details" Binding="{Binding BatchTraceInfo}" Width="200"/>
                              <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*"/>
                              <DataGridTextColumn Header="Operator" Binding="{Binding Username}" Width="120"/>
                           </DataGrid.Columns>
                       </DataGrid>

                      <!-- AR Aging -->
                      <ScrollViewer IsVisible="{Binding IsArAgingSelected}" Margin="20">
                          <StackPanel Spacing="16">
                              <Grid ColumnDefinitions="*,*,*,*,*,*">
                                  <Border Background="#E8F5E9" Padding="12" CornerRadius="8" Margin="4"><StackPanel><TextBlock Text="Current" FontSize="11"/><TextBlock Text="{Binding ArAgingSummary.Current, StringFormat='{}{0:N0}'}" FontWeight="Bold"/></StackPanel></Border>
                                  <Border Grid.Column="1" Background="#FFF8E1" Padding="12" CornerRadius="8" Margin="4"><StackPanel><TextBlock Text="1-30 days" FontSize="11"/><TextBlock Text="{Binding ArAgingSummary.Days1To30, StringFormat='{}{0:N0}'}" FontWeight="Bold"/></StackPanel></Border>
                                  <Border Grid.Column="2" Background="#FFE0B2" Padding="12" CornerRadius="8" Margin="4"><StackPanel><TextBlock Text="31-60 days" FontSize="11"/><TextBlock Text="{Binding ArAgingSummary.Days31To60, StringFormat='{}{0:N0}'}" FontWeight="Bold"/></StackPanel></Border>
                                  <Border Grid.Column="3" Background="#FFCDD2" Padding="12" CornerRadius="8" Margin="4"><StackPanel><TextBlock Text="61-90 days" FontSize="11"/><TextBlock Text="{Binding ArAgingSummary.Days61To90, StringFormat='{}{0:N0}'}" FontWeight="Bold"/></StackPanel></Border>
                                  <Border Grid.Column="4" Background="#EF9A9A" Padding="12" CornerRadius="8" Margin="4"><StackPanel><TextBlock Text="90+ days" FontSize="11"/><TextBlock Text="{Binding ArAgingSummary.Over90, StringFormat='{}{0:N0}'}" FontWeight="Bold"/></StackPanel></Border>
                                  <Border Grid.Column="5" Background="#E3F2FD" Padding="12" CornerRadius="8" Margin="4"><StackPanel><TextBlock Text="Total Open" FontSize="11"/><TextBlock Text="{Binding ArAgingSummary.TotalOpen, StringFormat='{}{0:N0}'}" FontWeight="Bold"/></StackPanel></Border>
                              </Grid>
                              <DataGrid ItemsSource="{Binding ArAgingLines}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal">
                                  <DataGrid.Columns>
                                      <DataGridTextColumn Header="Customer" Binding="{Binding PartnerName}" Width="*"/>
                                      <DataGridTextColumn Header="Invoice" Binding="{Binding DocumentNumber}" Width="140"/>
                                      <DataGridTextColumn Header="Date" Binding="{Binding DocumentDate, StringFormat='{}{0:yyyy-MM-dd}'}" Width="110"/>
                                      <DataGridTextColumn Header="Due" Binding="{Binding DueDate, StringFormat='{}{0:yyyy-MM-dd}'}" Width="110"/>
                                      <DataGridTextColumn Header="Open Balance" Binding="{Binding OpenBalance, StringFormat='{}{0:N0}'}" Width="120"/>
                                      <DataGridTextColumn Header="Days Overdue" Binding="{Binding DaysOverdue}" Width="100"/>
                                      <DataGridTextColumn Header="Bucket" Binding="{Binding AgingBucket}" Width="80"/>
                                  </DataGrid.Columns>
                              </DataGrid>
                          </StackPanel>
                      </ScrollViewer>

                      <!-- AP Aging -->
                      <ScrollViewer IsVisible="{Binding IsApAgingSelected}" Margin="20">
                          <StackPanel Spacing="16">
                              <Grid ColumnDefinitions="*,*,*,*,*,*">
                                  <Border Background="#E8F5E9" Padding="12" CornerRadius="8" Margin="4"><StackPanel><TextBlock Text="Current" FontSize="11"/><TextBlock Text="{Binding ApAgingSummary.Current, StringFormat='{}{0:N0}'}" FontWeight="Bold"/></StackPanel></Border>
                                  <Border Grid.Column="1" Background="#FFF8E1" Padding="12" CornerRadius="8" Margin="4"><StackPanel><TextBlock Text="1-30 days" FontSize="11"/><TextBlock Text="{Binding ApAgingSummary.Days1To30, StringFormat='{}{0:N0}'}" FontWeight="Bold"/></StackPanel></Border>
                                  <Border Grid.Column="2" Background="#FFE0B2" Padding="12" CornerRadius="8" Margin="4"><StackPanel><TextBlock Text="31-60 days" FontSize="11"/><TextBlock Text="{Binding ApAgingSummary.Days31To60, StringFormat='{}{0:N0}'}" FontWeight="Bold"/></StackPanel></Border>
                                  <Border Grid.Column="3" Background="#FFCDD2" Padding="12" CornerRadius="8" Margin="4"><StackPanel><TextBlock Text="61-90 days" FontSize="11"/><TextBlock Text="{Binding ApAgingSummary.Days61To90, StringFormat='{}{0:N0}'}" FontWeight="Bold"/></StackPanel></Border>
                                  <Border Grid.Column="4" Background="#EF9A9A" Padding="12" CornerRadius="8" Margin="4"><StackPanel><TextBlock Text="90+ days" FontSize="11"/><TextBlock Text="{Binding ApAgingSummary.Over90, StringFormat='{}{0:N0}'}" FontWeight="Bold"/></StackPanel></Border>
                                  <Border Grid.Column="5" Background="#E3F2FD" Padding="12" CornerRadius="8" Margin="4"><StackPanel><TextBlock Text="Total Open" FontSize="11"/><TextBlock Text="{Binding ApAgingSummary.TotalOpen, StringFormat='{}{0:N0}'}" FontWeight="Bold"/></StackPanel></Border>
                              </Grid>
                              <DataGrid ItemsSource="{Binding ApAgingLines}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal">
                                  <DataGrid.Columns>
                                      <DataGridTextColumn Header="Supplier" Binding="{Binding PartnerName}" Width="*"/>
                                      <DataGridTextColumn Header="Bill" Binding="{Binding DocumentNumber}" Width="140"/>
                                      <DataGridTextColumn Header="Date" Binding="{Binding DocumentDate, StringFormat='{}{0:yyyy-MM-dd}'}" Width="110"/>
                                      <DataGridTextColumn Header="Due" Binding="{Binding DueDate, StringFormat='{}{0:yyyy-MM-dd}'}" Width="110"/>
                                      <DataGridTextColumn Header="Open Balance" Binding="{Binding OpenBalance, StringFormat='{}{0:N0}'}" Width="120"/>
                                      <DataGridTextColumn Header="Days Overdue" Binding="{Binding DaysOverdue}" Width="100"/>
                                      <DataGridTextColumn Header="Bucket" Binding="{Binding AgingBucket}" Width="80"/>
                                  </DataGrid.Columns>
                              </DataGrid>
                          </StackPanel>
                      </ScrollViewer>

                      <!-- VAT Return -->
                      <ScrollViewer IsVisible="{Binding IsVatReturnSelected}" Margin="20">
                          <StackPanel Spacing="16">
                              <Grid ColumnDefinitions="Auto, Auto, Auto, *">
                                  <StackPanel Spacing="5" Margin="0,0,15,0">
                                      <TextBlock Text="Period Start" FontSize="12" FontWeight="SemiBold"/>
                                      <DatePicker SelectedDate="{Binding VatPeriodStart}"/>
                                  </StackPanel>
                                  <StackPanel Spacing="5" Margin="0,0,15,0">
                                      <TextBlock Text="Period End" FontSize="12" FontWeight="SemiBold"/>
                                      <DatePicker SelectedDate="{Binding VatPeriodEnd}"/>
                                  </StackPanel>
                                  <Button Content="Compute VAT Return" Command="{Binding LoadVatReturnCommand}" Background="#007ACC" Foreground="White" Padding="12,8" VerticalAlignment="Bottom"/>
                              </Grid>
                              <Grid ColumnDefinitions="*,*,*,*,*" IsVisible="{Binding VatSummary, Converter={x:Static ObjectConverters.IsNotNull}}">
                                  <Border Background="#E3F2FD" Padding="12" CornerRadius="8" Margin="4"><StackPanel><TextBlock Text="Taxable Sales" FontSize="11"/><TextBlock Text="{Binding VatSummary.TaxableSales, StringFormat='{}{0:N2}'}" FontWeight="Bold"/></StackPanel></Border>
                                  <Border Grid.Column="1" Background="#E8F5E9" Padding="12" CornerRadius="8" Margin="4"><StackPanel><TextBlock Text="Output VAT" FontSize="11"/><TextBlock Text="{Binding VatSummary.OutputVat, StringFormat='{}{0:N2}'}" FontWeight="Bold"/></StackPanel></Border>
                                  <Border Grid.Column="2" Background="#FFF8E1" Padding="12" CornerRadius="8" Margin="4"><StackPanel><TextBlock Text="Taxable Purchases" FontSize="11"/><TextBlock Text="{Binding VatSummary.TaxablePurchases, StringFormat='{}{0:N2}'}" FontWeight="Bold"/></StackPanel></Border>
                                  <Border Grid.Column="3" Background="#FFE0B2" Padding="12" CornerRadius="8" Margin="4"><StackPanel><TextBlock Text="Input VAT" FontSize="11"/><TextBlock Text="{Binding VatSummary.InputVat, StringFormat='{}{0:N2}'}" FontWeight="Bold"/></StackPanel></Border>
                                  <Border Grid.Column="4" Background="#FFCDD2" Padding="12" CornerRadius="8" Margin="4"><StackPanel><TextBlock Text="Net VAT Payable" FontSize="11"/><TextBlock Text="{Binding VatSummary.NetVatPayable, StringFormat='{}{0:N2}'}" FontWeight="Bold"/></StackPanel></Border>
                              </Grid>
                          </StackPanel>
                      </ScrollViewer>

                      <!-- Budget vs Actual -->
                      <ScrollViewer IsVisible="{Binding IsBudgetVsActualSelected}" Margin="20">
                          <StackPanel Spacing="16">
                              <Grid ColumnDefinitions="Auto, Auto, Auto, *">
                                  <StackPanel Spacing="5" Margin="0,0,15,0">
                                      <TextBlock Text="Fiscal Year" FontSize="12" FontWeight="SemiBold"/>
                                      <NumericUpDown Value="{Binding BudgetFiscalYear}" Minimum="2000" Maximum="2100" Width="120"/>
                                  </StackPanel>
                                  <StackPanel Spacing="5" Margin="0,0,15,0">
                                      <TextBlock Text="Month (0 = annual)" FontSize="12" FontWeight="SemiBold"/>
                                      <NumericUpDown Value="{Binding BudgetPeriodMonth}" Minimum="0" Maximum="12" Width="120"/>
                                  </StackPanel>
                                  <Button Content="Load Report" Command="{Binding LoadBudgetVsActualCommand}" Background="#007ACC" Foreground="White" Padding="12,8" VerticalAlignment="Bottom"/>
                              </Grid>
                              <Grid ColumnDefinitions="*,*,*">
                                  <Border Background="#E3F2FD" Padding="12" CornerRadius="8" Margin="4"><StackPanel><TextBlock Text="Total Budget" FontSize="11"/><TextBlock Text="{Binding BudgetTotalBudget, StringFormat='{}{0:N2}'}" FontWeight="Bold"/></StackPanel></Border>
                                  <Border Grid.Column="1" Background="#E8F5E9" Padding="12" CornerRadius="8" Margin="4"><StackPanel><TextBlock Text="Total Actual" FontSize="11"/><TextBlock Text="{Binding BudgetTotalActual, StringFormat='{}{0:N2}'}" FontWeight="Bold"/></StackPanel></Border>
                                  <Border Grid.Column="2" Background="#FFF8E1" Padding="12" CornerRadius="8" Margin="4"><StackPanel><TextBlock Text="Total Variance" FontSize="11"/><TextBlock Text="{Binding BudgetTotalVariance, StringFormat='{}{0:N2}'}" FontWeight="Bold"/></StackPanel></Border>
                              </Grid>
                              <DataGrid ItemsSource="{Binding BudgetVsActualLines}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal">
                                  <DataGrid.Columns>
                                      <DataGridTextColumn Header="Code" Binding="{Binding AccountCode}" Width="100"/>
                                      <DataGridTextColumn Header="Account" Binding="{Binding AccountName}" Width="*"/>
                                      <DataGridTextColumn Header="Type" Binding="{Binding AccountType}" Width="160"/>
                                      <DataGridTextColumn Header="Budget" Binding="{Binding BudgetAmount, StringFormat='{}{0:N2}'}" Width="120"/>
                                      <DataGridTextColumn Header="Actual" Binding="{Binding ActualAmount, StringFormat='{}{0:N2}'}" Width="120"/>
                                      <DataGridTextColumn Header="Variance" Binding="{Binding Variance, StringFormat='{}{0:N2}'}" Width="120"/>
                                      <DataGridTextColumn Header="Var %" Binding="{Binding VariancePercent, StringFormat='{}{0:N1}%'}" Width="80"/>
                                  </DataGrid.Columns>
                              </DataGrid>
                          </StackPanel>
                      </ScrollViewer>

                      <!-- Bank Reconciliation -->
                      <ScrollViewer IsVisible="{Binding IsBankReconciliationSelected}" Margin="20">
                          <StackPanel Spacing="16">
                              <Grid ColumnDefinitions="Auto, Auto, *">
                                  <StackPanel Spacing="5" Margin="0,0,15,0">
                                      <TextBlock Text="Bank Account" FontSize="12" FontWeight="SemiBold"/>
                                      <ComboBox ItemsSource="{Binding ReconBankAccounts}" SelectedItem="{Binding SelectedReconBankAccount}" Width="280">
                                          <ComboBox.ItemTemplate>
                                              <DataTemplate x:DataType="vm:BankAccountDisplayRow">
                                                  <TextBlock Text="{Binding AccountNumber}"/>
                                              </DataTemplate>
                                          </ComboBox.ItemTemplate>
                                      </ComboBox>
                                  </StackPanel>
                                  <Button Content="Refresh" Command="{Binding LoadBankReconciliationCommand}" Background="#007ACC" Foreground="White" Padding="12,8" VerticalAlignment="Bottom"/>
                                  <Button Grid.Column="2" Content="Import Statement" Command="{Binding OpenImportStatementCommand}" Background="#5C6BC0" Foreground="White" Padding="12,8" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="0,0,10,0"/>
                                  <Button Grid.Column="2" Content="Match Selected" Command="{Binding MatchReconciliationCommand}" Background="#2E7D32" Foreground="White" Padding="12,8" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="140,0,0,0"/>
                              </Grid>
                              <TextBlock Text="{Binding ReconStatusMessage}" Foreground="Gray"/>
                              <Grid ColumnDefinitions="*, 20, *">
                                  <StackPanel Grid.Column="0" Spacing="8">
                                      <TextBlock Text="Unreconciled Payments" FontWeight="Bold"/>
                                      <DataGrid ItemsSource="{Binding UnreconciledPayments}" SelectedItem="{Binding SelectedReconPayment}" AutoGenerateColumns="False" IsReadOnly="True" Height="280">
                                          <DataGrid.Columns>
                                              <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="*"/>
                                              <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat='{}{0:yyyy-MM-dd}'}" Width="110"/>
                                              <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat='{}{0:N2}'}" Width="100"/>
                                          </DataGrid.Columns>
                                      </DataGrid>
                                  </StackPanel>
                                  <StackPanel Grid.Column="2" Spacing="8">
                                      <TextBlock Text="Unreconciled Statement Lines" FontWeight="Bold"/>
                                      <DataGrid ItemsSource="{Binding UnreconciledStatementLines}" SelectedItem="{Binding SelectedReconLine}" AutoGenerateColumns="False" IsReadOnly="True" Height="280">
                                          <DataGrid.Columns>
                                              <DataGridTextColumn Header="Description" Binding="{Binding Label}" Width="*"/>
                                              <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat='{}{0:yyyy-MM-dd}'}" Width="110"/>
                                              <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat='{}{0:N2}'}" Width="100"/>
                                          </DataGrid.Columns>
                                      </DataGrid>
                                  </StackPanel>
                              </Grid>
                          </StackPanel>
                      </ScrollViewer>
                  </Panel>
             </Grid>
        </Border>

        <!-- DETAILS MODAL -->
        <Border Background="#44000000" Grid.RowSpan="2" Grid.ColumnSpan="2" IsVisible="{Binding IsDetailsModalOpen}">
             <Border Background="{DynamicResource ContentBackgroundColor}" CornerRadius="12" MinWidth="400" MinHeight="300" Width="600" Height="480" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30" BoxShadow="0 10 40 0 #44000000" helpers:ResizableHelper.CanResize="True">
                  <Grid RowDefinitions="Auto, *, Auto">
                      <StackPanel Spacing="10">
                          <TextBlock Text="Transaction Details" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryColor}"/>
                          <StackPanel Orientation="Horizontal" Spacing="20">
                               <TextBlock Text="{Binding SelectedStockMovement.Date, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Foreground="{DynamicResource TextSecondaryColor}"/>
                               <TextBlock Text="{Binding SelectedStockMovement.MovementType}" FontWeight="Bold" Foreground="#007ACC"/>
                          </StackPanel>
                          <Separator Height="1" Background="{DynamicResource BorderColor}" Margin="0,10"/>
                      </StackPanel>

                      <ScrollViewer Grid.Row="1" Margin="0,15">
                          <StackPanel Spacing="15">
                              <StackPanel>
                                  <TextBlock Text="Performed By" FontSize="12" Foreground="#888"/>
                                  <TextBlock Text="{Binding SelectedStockMovement.Username}" FontSize="16"/>
                              </StackPanel>
                              <StackPanel>
                                  <TextBlock Text="Product ID (SKU)" FontSize="12" Foreground="#888"/>
                                  <TextBlock Text="{Binding SelectedStockMovement.ProductId}" FontSize="16"/>
                              </StackPanel>
                              <StackPanel>
                                  <TextBlock Text="Reason" FontSize="12" Foreground="{DynamicResource TextSecondaryColor}"/>
                                  <TextBlock Text="{Binding SelectedStockMovement.Reason}" FontSize="16" TextWrapping="Wrap"/>
                              </StackPanel>
                              <Border Background="{DynamicResource PageBackgroundColor}" Padding="15" CornerRadius="6">
                                  <Grid ColumnDefinitions="*, Auto">
                                      <StackPanel Spacing="5">
                                         <TextBlock Text="Batch Trace / Cost Details" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryColor}"/>
                                         <TextBlock Text="{Binding SelectedStockMovement.BatchTraceInfo}" TextWrapping="Wrap" LineHeight="22"/>
                                      </StackPanel>
                                      <Button Grid.Column="1" Command="{Binding CopyToClipboardCommand}" CommandParameter="{Binding SelectedStockMovement.BatchTraceInfo}" 
                                              Content="Copy" Background="{DynamicResource ContentBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" VerticalAlignment="Top"/>
                                  </Grid>
                              </Border>
                          </StackPanel>
                      </ScrollViewer>

                      <Button Grid.Row="2" Content="Close" Command="{Binding CloseDetailsCommand}" HorizontalAlignment="Right" Width="100" Background="#EEE"/>
                  </Grid>
             </Border>
        </Border>

        <!-- JOURNAL ENTRIES MODAL -->
        <Border Background="#44000000" Grid.RowSpan="2" Grid.ColumnSpan="2" IsVisible="{Binding IsJournalModalOpen}">
             <Border Background="{DynamicResource ContentBackgroundColor}" CornerRadius="12" MinWidth="750" MinHeight="450" Margin="40" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Padding="25" BoxShadow="0 10 40 0 #44000000" helpers:ResizableHelper.CanResize="True">
                  <Grid RowDefinitions="Auto, *, Auto">
                      <StackPanel Spacing="10">
                          <Grid ColumnDefinitions="*, Auto">
                              <TextBlock Text="{Binding DetailedJournalTitle}" FontSize="22" FontWeight="Bold" Foreground="#007ACC"/>
                              <Button Grid.Column="1" Content="X" Command="{Binding CloseJournalModalCommand}" Background="Transparent" BorderThickness="0" FontSize="16" FontWeight="Bold"/>
                          </Grid>
                          <Separator Height="1" Background="{DynamicResource BorderColor}" Margin="0,10"/>
                      </StackPanel>

                      <Border Grid.Row="1" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="4">
                          <DataGrid ItemsSource="{Binding DetailedJournalLines}" AutoGenerateColumns="False" GridLinesVisibility="Horizontal" CanUserResizeColumns="True" Background="{DynamicResource ContentBackgroundColor}">
                              <DataGrid.Columns>
                                  <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="Auto"/>
                                  <DataGridTextColumn Header="Journal Entry" Binding="{Binding EntryNumber}" Width="Auto"/>
                                  <DataGridTextColumn Header="Account (COA)" Binding="{Binding AccountDisplay}" Width="Auto"/>
                                  <DataGridTextColumn Header="Partner" Binding="{Binding PartnerName}" Width="Auto"/>
                                  <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="*"/>
                                  <DataGridTextColumn Header="Debit" Binding="{Binding Debit, StringFormat='{}{0:N2}'}" Width="Auto"/>
                                  <DataGridTextColumn Header="Credit" Binding="{Binding Credit, StringFormat='{}{0:N2}'}" Width="Auto"/>
                                  <DataGridTextColumn Header="Matching" Binding="{Binding Matching}" Width="Auto"/>
                              </DataGrid.Columns>
                          </DataGrid>
                      </Border>

                      <Grid Grid.Row="2" ColumnDefinitions="*, Auto" Margin="0,15,0,0">
                          <!-- Totals and Integrity Info -->
                          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="25" VerticalAlignment="Center">
                              <StackPanel Orientation="Horizontal" Spacing="8">
                                  <TextBlock Text="Total Debit:" FontSize="14" Foreground="Gray" FontWeight="SemiBold"/>
                                  <TextBlock Text="{Binding TotalDebit, StringFormat='{}{0:N2}'}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryColor}"/>
                              </StackPanel>
                              <StackPanel Orientation="Horizontal" Spacing="8">
                                  <TextBlock Text="Total Credit:" FontSize="14" Foreground="Gray" FontWeight="SemiBold"/>
                                  <TextBlock Text="{Binding TotalCredit, StringFormat='{}{0:N2}'}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryColor}"/>
                              </StackPanel>
                              
                              <!-- Balanced Badge -->
                              <Border CornerRadius="4" Padding="8,4" VerticalAlignment="Center" IsVisible="{Binding IsBalanced}" Background="#2E7D32">
                                  <TextBlock Text="Balanced" Foreground="White" FontSize="11" FontWeight="Bold"/>
                              </Border>
                              <Border CornerRadius="4" Padding="8,4" VerticalAlignment="Center" IsVisible="{Binding !IsBalanced}" Background="#D32F2F">
                                  <StackPanel Orientation="Horizontal" Spacing="4">
                                      <TextBlock Text="Unbalanced (Diff:" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                      <TextBlock Text="{Binding BalanceDifference, StringFormat='{}{0:N2}'}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                      <TextBlock Text=" " Foreground="White" FontSize="11" FontWeight="Bold"/>
                                      <TextBlock Text="{Binding CurrencySymbol}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                      <TextBlock Text=")" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                  </StackPanel>
                              </Border>
                          </StackPanel>

                          <!-- Close Button -->
                          <Button Grid.Column="1" Content="Close" Command="{Binding CloseJournalModalCommand}" Width="100" HorizontalContentAlignment="Center"/>
                      </Grid>
                  </Grid>
             </Border>
        </Border>

        <!-- Import Bank Statement Modal -->
        <Border Background="#44000000" Grid.RowSpan="2" Grid.ColumnSpan="2" IsVisible="{Binding IsImportStatementModalOpen}">
            <Border Background="{DynamicResource ContentBackgroundColor}" CornerRadius="12" Width="480" Padding="25" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Spacing="12">
                    <TextBlock Text="Import Bank Statement" FontSize="18" FontWeight="Bold"/>
                    <Grid ColumnDefinitions="*, *">
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                            <TextBlock Text="Statement Date" FontSize="11"/>
                            <DatePicker SelectedDate="{Binding ImportStatementDate}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Line Date" FontSize="11"/>
                            <DatePicker SelectedDate="{Binding ImportLineDate}"/>
                        </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="*, *">
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                            <TextBlock Text="Opening Balance" FontSize="11"/>
                            <TextBox Text="{Binding ImportOpeningBalance}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Closing Balance" FontSize="11"/>
                            <TextBox Text="{Binding ImportClosingBalance}"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Line Description" FontSize="11"/>
                        <TextBox Text="{Binding ImportLineDescription}"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="*, *">
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                            <TextBlock Text="Line Amount" FontSize="11"/>
                            <TextBox Text="{Binding ImportLineAmount}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Reference" FontSize="11"/>
                            <TextBox Text="{Binding ImportLineReference}"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="{Binding ImportErrorMessage}" Foreground="#D32F2F"/>
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                        <Button Content="Cancel" Command="{Binding CloseImportStatementCommand}"/>
                        <Button Content="Import" Command="{Binding SubmitImportStatementCommand}" Background="#2E7D32" Foreground="White"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
