<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:InventoryManagementSystem.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="600"
             x:Class="InventoryManagementSystem.UI.Views.StockTransferView"
             x:DataType="vm:StockTransferViewModel">

    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" Background="{DynamicResource SystemAccentColor}" Padding="20">
            <TextBlock Text="Inventory Stock Transfer" FontSize="24" FontWeight="Bold" Foreground="White"/>
        </Border>

        <Border Grid.Row="1" Margin="30" Padding="30" Background="{DynamicResource ContentBackgroundColor}" CornerRadius="12" BoxShadow="0 10 30 0 #10000000" VerticalAlignment="Top" MaxWidth="500">
            <StackPanel Spacing="20">
                <TextBlock Text="Transfer Internal Items" FontSize="18" FontWeight="SemiBold"/>
                
                <StackPanel Spacing="5">
                    <TextBlock Text="From Location" FontSize="12" Foreground="Gray"/>
                    <ComboBox ItemsSource="{Binding Locations}" SelectedItem="{Binding SourceLocation}" HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="To Location" FontSize="12" Foreground="Gray"/>
                    <ComboBox ItemsSource="{Binding Locations}" SelectedItem="{Binding DestLocation}" HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="Product" FontSize="12" Foreground="Gray"/>
                    <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" HorizontalAlignment="Stretch">
                         <ComboBox.ItemTemplate>
                            <DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="Quantity" FontSize="12" Foreground="Gray"/>
                    <NumericUpDown Value="{Binding Quantity}" Minimum="1" HorizontalAlignment="Stretch"/>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="Notes" FontSize="12" Foreground="Gray"/>
                    <TextBox Text="{Binding Notes}" Watermark="Reason for transfer..." Height="80" AcceptsReturn="True"/>
                </StackPanel>

                <Button Content="Execute Transfer" Command="{Binding PerformTransferCommand}" HorizontalAlignment="Stretch" Padding="15" Classes="accent"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
