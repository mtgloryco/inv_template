<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:InventoryManagementSystem.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
             x:Class="InventoryManagementSystem.UI.Views.ReorderDashboardView"
             x:DataType="vm:ReorderDashboardViewModel">
    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        <Grid RowDefinitions="Auto" ColumnDefinitions="*,Auto" Grid.Row="0">
            <StackPanel Grid.Column="0">
                <TextBlock Text="Reorder Dashboard" FontSize="26" FontWeight="SemiBold" />
                <TextBlock Text="Actionable items based on forecasting rules." FontSize="13" Foreground="#6B7280" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Refresh" Command="{Binding LoadRecommendationsCommand}" IsEnabled="{Binding !IsLoading}" VerticalAlignment="Bottom" Background="#007ACC" Foreground="White" BorderThickness="0" Padding="12,6" />
        </Grid>

        <Border Grid.Row="1" Margin="0,16,0,0" CornerRadius="10" Background="{DynamicResource ContentBackgroundColor}" Padding="10" BorderBrush="#E5E7EB" BorderThickness="1">
            <Grid>
                <TextBlock Text="Analyzing..." IsVisible="{Binding IsLoading}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#6B7280"/>

                <ScrollViewer IsVisible="{Binding !IsLoading}">
                    <StackPanel Spacing="10">
                        <ItemsControl ItemsSource="{Binding Recommendations}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="10">
                                        <StackPanel Spacing="6">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Ellipse Width="10" Height="10" Fill="#F59E0B" VerticalAlignment="Center"/>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Product.Name}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding SupplierName}" FontSize="12" Foreground="#6B7280"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock Text="{Binding DaysUntilStockout, StringFormat='Days until stockout: {0}'}" FontSize="12" Foreground="#111827"/>
                                                <TextBlock Text="{Binding ThresholdDays, StringFormat='Threshold: {0}'}" FontSize="12" Foreground="#6B7280"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding RecommendedOrderQuantity, StringFormat='Recommended Qty: {0}'}" FontSize="13" FontWeight="Bold" Foreground="#111827"/>
                                                <Button Content="Create PO" Command="{Binding DataContext.CreatePurchaseOrderForRecommendationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                        CommandParameter="{Binding}" 
                                                        Background="#10B981" Foreground="White" BorderThickness="0" Padding="10,6"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{Binding StatusMessage}" IsVisible="{Binding IsRecommendationsEmpty}" 
                                   Foreground="#6B7280" FontSize="13" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" IsVisible="{Binding !IsLoading}" Foreground="#6B7280" FontSize="12" Margin="0,12,0,0" TextWrapping="Wrap" HorizontalAlignment="Center"/>
    </Grid>
</UserControl>

