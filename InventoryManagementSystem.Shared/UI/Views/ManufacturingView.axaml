<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:InventoryManagementSystem.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
             x:Class="InventoryManagementSystem.UI.Views.ManufacturingView"
             x:DataType="vm:ManufacturingViewModel">
    <TabControl SelectedIndex="{Binding SelectedTabIndex}" Margin="10">
        <!-- ==================== TAB 1: BILLS OF MATERIALS ==================== -->
        <TabItem Header="Bill of Materials (BoM)">
            <Grid Margin="10">
                <!-- STATE 1: BOM LIST VIEW -->
                <Grid RowDefinitions="Auto,Auto,*" IsVisible="{Binding !IsFormVisible}">
                    <!-- Header Panel -->
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,16">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Bills of Materials" FontSize="20" FontWeight="Bold" />
                            <TextBlock Text="Define and configure production recipes and ingredient list for goods." FontSize="11" Foreground="Gray" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="+ New BoM" Command="{Binding ShowCreateBomFormCommand}" Background="#007ACC" Foreground="White" Padding="12,6" FontWeight="SemiBold" CornerRadius="4" />
                    </Grid>

                    <!-- Search Bar -->
                    <Border Grid.Row="1" Background="{DynamicResource CardBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,12">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBox Grid.Column="0" Text="{Binding SearchText}" Watermark="Search recipes by name, reference, type or company..." VerticalContentAlignment="Center" Background="Transparent" BorderThickness="0" Padding="5,0"/>
                            <TextBlock Grid.Column="1" Text="🔍" VerticalAlignment="Center" Margin="5,0" Foreground="Gray"/>
                        </Grid>
                    </Border>

                    <!-- DataGrid list -->
                    <Border Grid.Row="2" Background="{DynamicResource CardBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="12">
                        <DataGrid ItemsSource="{Binding Boms}" SelectedItem="{Binding SelectedBom}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Final Product" Binding="{Binding ProductName}" Width="2*" />
                                <DataGridTextColumn Header="Reference" Binding="{Binding Reference}" Width="*" />
                                <DataGridTextColumn Header="BoM Type" Binding="{Binding BomType}" Width="*" />
                                <DataGridTextColumn Header="Company" Binding="{Binding Company}" Width="*" />
                                <DataGridTemplateColumn Header="Actions" Width="180">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                                <Button Content="Open / Edit" Command="{Binding $parent[UserControl].((vm:ManufacturingViewModel)DataContext).OpenBomDetailCommand}" CommandParameter="{Binding}" Background="#007ACC" Foreground="White" FontSize="10" Padding="8,4" CornerRadius="4"/>
                                                <Button Content="Delete" Command="{Binding $parent[UserControl].((vm:ManufacturingViewModel)DataContext).DeleteBomCommand}" CommandParameter="{Binding}" Background="#D32F2F" Foreground="White" FontSize="10" Padding="8,4" CornerRadius="4"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>

                <!-- STATE 2: FULL-SCREEN BoM DETAIL FORM VIEW -->
                <Grid RowDefinitions="Auto,*" IsVisible="{Binding IsFormVisible}">
                    <!-- Form Header & Actions -->
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,16">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                            <Button Content="← Back to Recipes" Command="{Binding CloseFormCommand}" Background="Transparent" Foreground="#007ACC" Padding="0" VerticalAlignment="Center" FontSize="13"/>
                            <TextBlock Text="/" Foreground="Gray" VerticalAlignment="Center" FontSize="13"/>
                            <TextBlock Text="{Binding Reference, FallbackValue='New Recipe'}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                            <Button Content="Discard" Command="{Binding CloseFormCommand}" Padding="12,6" FontSize="13" CornerRadius="4"/>
                            <Button Content="Save Recipe" Command="{Binding SaveBomCommand}" Background="#2E7D32" Foreground="White" Padding="14,6" FontSize="13" FontWeight="SemiBold" CornerRadius="4"/>
                        </StackPanel>
                    </Grid>

                    <!-- Card Editor Sheet -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Border Background="{DynamicResource CardBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel Spacing="16">
                                <!-- Alert Banner -->
                                <Border Background="#FFEBEE" BorderBrush="#FFCDD2" BorderThickness="1" CornerRadius="4" Padding="10" IsVisible="{Binding HasError}">
                                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#B71C1C" FontSize="12" TextWrapping="Wrap"/>
                                </Border>

                                <!-- Header Grid -->
                                <Grid ColumnDefinitions="*, *" RowDefinitions="Auto,Auto,Auto">
                                    <!-- Product -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="5" Margin="0,0,16,12">
                                        <TextBlock Text="Product to Manufacture" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>
                                        <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedFinalProduct}" HorizontalAlignment="Stretch" PlaceholderText="Select product...">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Product Variant -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="5" Margin="0,0,16,12">
                                        <TextBlock Text="Product Variant" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>
                                        <TextBox Text="No variants configured" IsEnabled="False" Foreground="Gray"/>
                                    </StackPanel>

                                    <!-- Quantity -->
                                    <StackPanel Grid.Row="2" Grid.Column="0" Spacing="5" Margin="0,0,16,12">
                                        <TextBlock Text="Quantity to Produce" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>
                                        <Grid ColumnDefinitions="*, Auto">
                                            <TextBox Grid.Column="0" Text="{Binding Quantity}" Watermark="1.0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SelectedFinalProduct.Unit, FallbackValue='Units'}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="Gray" FontWeight="SemiBold"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Reference -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="5" Margin="16,0,0,12">
                                        <TextBlock Text="Reference" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>
                                        <TextBox Text="{Binding Reference}" Watermark="BOM-001"/>
                                    </StackPanel>

                                    <!-- BoM Type -->
                                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="5" Margin="16,0,0,12">
                                        <TextBlock Text="BoM Type" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>
                                        <StackPanel Orientation="Horizontal" Spacing="24" Margin="0,8,0,0">
                                            <RadioButton Content="Manufacture this product" IsChecked="{Binding IsManufactureType}" GroupName="BomTypeGroup"/>
                                            <RadioButton Content="Kit" IsChecked="{Binding IsKitType}" GroupName="BomTypeGroup"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Company -->
                                    <StackPanel Grid.Row="2" Grid.Column="1" Spacing="5" Margin="16,0,0,12">
                                        <TextBlock Text="Company" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>
                                        <TextBox Text="{Binding Company}" Watermark="Company name"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Spacing="5" Margin="0,0,0,12">
                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                                            <StackPanel Spacing="5">
                                                <TextBlock Text="Yield %" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>
                                                <TextBox Text="{Binding YieldPercent}" Watermark="100"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Spacing="5">
                                                <TextBlock Text="Scrap %" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>
                                                <TextBox Text="{Binding ScrapPercent}" Watermark="0"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <TabControl Margin="0,10,0,0">
                                    <TabItem Header="Components">
                                        <Border BorderThickness="0" Padding="0,12,0,0">
                                            <DockPanel>
                                                <!-- Bottom Add Row Button -->
                                                <Button DockPanel.Dock="Bottom" Content="+ Add a line" Command="{Binding AddComponentLineCommand}" Background="Transparent" Foreground="#007ACC" FontWeight="SemiBold" FontSize="12" Margin="0,6,0,0"/>

                                                <StackPanel Spacing="6">
                                                    <!-- Table Header -->
                                                    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" Padding="0,4,0,8">
                                                        <Grid ColumnDefinitions="3*, 1*, 1*, 1*, Auto">
                                                            <TextBlock Grid.Column="0" Text="Component" FontWeight="SemiBold" FontSize="12" Foreground="Gray"/>
                                                            <TextBlock Grid.Column="1" Text="Quantity" FontWeight="SemiBold" FontSize="12" Foreground="Gray" Margin="10,0"/>
                                                            <TextBlock Grid.Column="2" Text="Scrap %" FontWeight="SemiBold" FontSize="12" Foreground="Gray" Margin="10,0"/>
                                                            <TextBlock Grid.Column="3" Text="Unit" FontWeight="SemiBold" FontSize="12" Foreground="Gray" Margin="10,0"/>
                                                            <TextBlock Grid.Column="4" Width="30"/>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Rows -->
                                                    <ItemsControl ItemsSource="{Binding ComponentLines}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" Padding="0,6">
                                                                    <Grid ColumnDefinitions="3*, 1*, 1*, 1*, Auto">
                                                                        <!-- Component Picker -->
                                                                        <ComboBox Grid.Column="0" ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" HorizontalAlignment="Stretch" PlaceholderText="Select component...">
                                                                            <ComboBox.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <TextBlock Text="{Binding Name}" />
                                                                                </DataTemplate>
                                                                            </ComboBox.ItemTemplate>
                                                                        </ComboBox>

                                                                        <!-- Quantity -->
                                                                        <TextBox Grid.Column="1" Text="{Binding Quantity}" Margin="10,0" VerticalAlignment="Center"/>

                                                                        <!-- Scrap -->
                                                                        <TextBox Grid.Column="2" Text="{Binding ScrapPercent}" Margin="10,0" VerticalAlignment="Center"/>

                                                                        <!-- Unit -->
                                                                        <ComboBox Grid.Column="3" ItemsSource="{Binding Units}" SelectedItem="{Binding Unit}" HorizontalAlignment="Stretch" Margin="10,0" VerticalAlignment="Center"/>

                                                                        <!-- Delete -->
                                                                        <Button Grid.Column="4" Content="✕" Command="{Binding $parent[UserControl].((vm:ManufacturingViewModel)DataContext).RemoveComponentLineCommand}" CommandParameter="{Binding .}" Foreground="Red" Background="Transparent" FontSize="12" Padding="6,2" VerticalAlignment="Center"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </TabItem>
                                    <TabItem Header="Operations">
                                        <Border Padding="0,20">
                                            <TextBlock Text="No operations configured for this Bill of Materials." Foreground="Gray" HorizontalAlignment="Center"/>
                                        </Border>
                                    </TabItem>
                                    <TabItem Header="Miscellaneous">
                                        <Border Padding="0,20">
                                            <TextBlock Text="Recipe settings and default ledger configurations." Foreground="Gray" HorizontalAlignment="Center"/>
                                        </Border>
                                    </TabItem>
                                </TabControl>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </TabItem>

        <!-- ==================== TAB 2: MANUFACTURING ORDERS ==================== -->
        <TabItem Header="Manufacturing Orders (MO)">
            <Grid Margin="10">
                <!-- STATE 1: MO LIST VIEW -->
                <Grid RowDefinitions="Auto,Auto,*" IsVisible="{Binding !IsMOFormVisible}">
                    <!-- Header -->
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,16">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Manufacturing Orders" FontSize="20" FontWeight="Bold" />
                            <TextBlock Text="Create production jobs and track expected vs. actual yield." FontSize="11" Foreground="Gray" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="+ New MO" Command="{Binding ShowCreateMOFormCommand}" Background="#007ACC" Foreground="White" Padding="12,6" FontWeight="SemiBold" CornerRadius="4" />
                    </Grid>

                    <!-- Search Bar -->
                    <Border Grid.Row="1" Background="{DynamicResource CardBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,12">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBox Grid.Column="0" Text="{Binding SearchMOText}" Watermark="Search MOs by number, product, status or company..." VerticalContentAlignment="Center" Background="Transparent" BorderThickness="0" Padding="5,0"/>
                            <TextBlock Grid.Column="1" Text="🔍" VerticalAlignment="Center" Margin="5,0" Foreground="Gray"/>
                        </Grid>
                    </Border>

                    <!-- MO Grid List -->
                    <Border Grid.Row="2" Background="{DynamicResource CardBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="12">
                        <DataGrid ItemsSource="{Binding ManufacturingOrders}" SelectedItem="{Binding SelectedMO}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="MO Number" Binding="{Binding MONumber}" Width="*" />
                                <DataGridTextColumn Header="Final Product" Binding="{Binding ProductName}" Width="2*" />
                                <DataGridTextColumn Header="Planned Qty" Binding="{Binding TargetQuantityDisplay}" Width="*" />
                                <DataGridTextColumn Header="Produced Qty" Binding="{Binding ActualQuantityDisplay}" Width="*" />
                                <DataGridTextColumn Header="Date" Binding="{Binding OrderDateDisplay}" Width="*" />
                                <DataGridTextColumn Header="Cost (RWF)" Binding="{Binding TotalCostDisplay}" Width="*" />
                                
                                 <!-- Status Column with Badges -->
                                <DataGridTemplateColumn Header="Status" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="6,3" HorizontalAlignment="Center" Tag="{Binding Status}">
                                                <Border.Styles>
                                                    <Style Selector="Border[Tag=Draft]">
                                                        <Setter Property="Background" Value="#9E9E9E"/>
                                                    </Style>
                                                    <Style Selector="Border[Tag=Confirmed]">
                                                        <Setter Property="Background" Value="#F57C00"/>
                                                    </Style>
                                                    <Style Selector="Border[Tag=Done]">
                                                        <Setter Property="Background" Value="#2E7D32"/>
                                                    </Style>
                                                </Border.Styles>
                                                <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Actions" Width="160">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                                <Button Content="Open" Command="{Binding $parent[UserControl].((vm:ManufacturingViewModel)DataContext).OpenMODetailCommand}" CommandParameter="{Binding}" Background="#007ACC" Foreground="White" FontSize="10" Padding="8,4" CornerRadius="4"/>
                                                <Button Content="Delete" Command="{Binding $parent[UserControl].((vm:ManufacturingViewModel)DataContext).DeleteMOCommand}" CommandParameter="{Binding}" Background="#D32F2F" Foreground="White" FontSize="10" Padding="8,4" CornerRadius="4"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>

                <!-- STATE 2: FULL-SCREEN MO SHEET EDITOR VIEW -->
                <Grid RowDefinitions="Auto,*" IsVisible="{Binding IsMOFormVisible}">
                    <!-- Form Header -->
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,16">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                            <Button Content="← Back to Orders" Command="{Binding CloseMOFormCommand}" Background="Transparent" Foreground="#007ACC" Padding="0" VerticalAlignment="Center" FontSize="13"/>
                            <TextBlock Text="/" Foreground="Gray" VerticalAlignment="Center" FontSize="13"/>
                            <TextBlock Text="{Binding MONumber, FallbackValue='New MO'}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Actions based on state -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                            <!-- Draft mode actions -->
                            <Button Content="Save Draft" Command="{Binding SaveMODraftCommand}" IsVisible="{Binding IsDraftState}" Padding="12,6" FontSize="13" CornerRadius="4"/>
                            <Button Content="Confirm" Command="{Binding ConfirmMOCommand}" IsVisible="{Binding IsDraftState}" Background="#007ACC" Foreground="White" Padding="14,6" FontSize="13" FontWeight="SemiBold" CornerRadius="4"/>

                            <!-- Confirmed mode actions -->
                            <Button Content="Produce All" Command="{Binding StartProductionInputCommand}" IsVisible="{Binding IsConfirmedState}" Background="#007ACC" Foreground="White" Padding="16,6" FontSize="13" FontWeight="SemiBold" CornerRadius="4"/>

                            <!-- Produce input active actions -->
                            <Button Content="Cancel Produce" Command="{Binding CloseMOFormCommand}" IsVisible="{Binding IsProduceStateActive}" Padding="12,6" FontSize="13" CornerRadius="4"/>
                            <Button Content="Mark as Done" Command="{Binding RecordProductionCommand}" IsVisible="{Binding IsProduceStateActive}" Background="#2E7D32" Foreground="White" Padding="16,6" FontSize="13" FontWeight="SemiBold" CornerRadius="4"/>

                            <!-- Closed/Done mode actions -->
                            <Button Content="Close Details" Command="{Binding CloseMOFormCommand}" IsVisible="{Binding IsDoneState}" Padding="12,6" FontSize="13" CornerRadius="4"/>
                        </StackPanel>
                    </Grid>

                    <!-- Sheet Details Card -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Border Background="{DynamicResource CardBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel Spacing="16">
                                <!-- Error Alerts -->
                                <Border Background="#FFEBEE" BorderBrush="#FFCDD2" BorderThickness="1" CornerRadius="4" Padding="10" IsVisible="{Binding HasError}">
                                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#B71C1C" FontSize="12" TextWrapping="Wrap"/>
                                </Border>

                                <!-- Header Fields -->
                                <Grid ColumnDefinitions="*, *" RowDefinitions="Auto,Auto,Auto" Margin="0,0,0,10">
                                    <!-- Left side fields -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="5" Margin="0,0,16,12">
                                        <TextBlock Text="Bill of Materials Recipe" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>
                                        <!-- Editable only in Draft -->
                                        <ComboBox ItemsSource="{Binding ActiveBoms}" SelectedItem="{Binding SelectedBoMForMO}" 
                                                  IsEnabled="{Binding IsDraftState}"
                                                  HorizontalAlignment="Stretch" PlaceholderText="Select recipe (BoM)...">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding ProductName, StringFormat='{}{0}'}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="5" Margin="0,0,16,12">
                                        <TextBlock Text="Finished Product" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>
                                        <TextBox Text="{Binding MOProduct.Name, FallbackValue='No Product Selected'}" IsEnabled="False" Foreground="Gray"/>
                                    </StackPanel>

                                    <!-- Target Qty / Produce Qty -->
                                    <StackPanel Grid.Row="2" Grid.Column="0" Spacing="5" Margin="0,0,16,12">
                                        <!-- Draft/Confirmed target qty edit -->
                                        <TextBlock Text="Target Quantity to Produce" FontSize="11" FontWeight="SemiBold" Foreground="Gray" 
                                                   IsVisible="{Binding !IsProduceStateActive}"/>
                                        <TextBox Text="{Binding MOTargetQuantity}" Watermark="1.0" 
                                                 IsEnabled="{Binding IsDraftState}"
                                                 IsVisible="{Binding !IsProduceStateActive}"/>
                                        
                                        <!-- Yield Actual edit visible only during Produce -->
                                        <TextBlock Text="ACTUAL PRODUCED QUANTITY (YIELD)" FontSize="11" FontWeight="Bold" Foreground="#2E7D32" 
                                                   IsVisible="{Binding IsProduceStateActive}"/>
                                        <TextBox Text="{Binding MOActualQuantity}" Watermark="Enter yield..." Background="#E8F5E9"
                                                 IsVisible="{Binding IsProduceStateActive}"/>

                                        <!-- Done state actual qty display -->
                                        <TextBlock Text="Actual Produced Quantity (Done)" FontSize="11" FontWeight="SemiBold" Foreground="Gray" 
                                                   IsVisible="{Binding IsDoneState}"/>
                                        <TextBox Text="{Binding MOActualQuantity}" IsEnabled="False" 
                                                 IsVisible="{Binding IsDoneState}"/>
                                    </StackPanel>

                                    <!-- Right side fields -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="5" Margin="16,0,0,12">
                                        <TextBlock Text="MO Number" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>
                                        <TextBox Text="{Binding MONumber}" IsEnabled="False" Foreground="Gray"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="5" Margin="16,0,0,12">
                                        <TextBlock Text="Status" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>
                                        <Border CornerRadius="4" Padding="8,4" Tag="{Binding MOStatus}" HorizontalAlignment="Left">
                                            <Border.Styles>
                                                <Style Selector="Border[Tag=Draft]">
                                                    <Setter Property="Background" Value="#9E9E9E"/>
                                                </Style>
                                                <Style Selector="Border[Tag=Confirmed]">
                                                    <Setter Property="Background" Value="#F57C00"/>
                                                </Style>
                                                <Style Selector="Border[Tag=Done]">
                                                    <Setter Property="Background" Value="#2E7D32"/>
                                                </Style>
                                            </Border.Styles>
                                            <TextBlock Text="{Binding MOStatus}" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="1" Spacing="5" Margin="16,0,0,12">
                                        <TextBlock Text="Company" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>
                                        <TextBox Text="{Binding MOCompany}" Watermark="Company settings"
                                                 IsEnabled="{Binding IsDraftState}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- TabControl Ingredients -->
                                <TabControl Margin="0,10,0,0">
                                    <TabItem Header="Components">
                                        <Border BorderThickness="0" Padding="0,12,0,0">
                                            <StackPanel Spacing="6">
                                                <!-- Headers -->
                                                <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" Padding="0,4,0,8">
                                                    <Grid ColumnDefinitions="3*, 1*, 1*, 1*, Auto">
                                                        <TextBlock Grid.Column="0" Text="Component" FontWeight="SemiBold" FontSize="12" Foreground="Gray"/>
                                                        <TextBlock Grid.Column="1" Text="To Consume (Planned)" FontWeight="SemiBold" FontSize="12" Foreground="Gray" Margin="6,0"/>
                                                        <TextBlock Grid.Column="2" Text="Consumed (Actual)" FontWeight="SemiBold" FontSize="12" Foreground="Gray" Margin="6,0"/>
                                                        <TextBlock Grid.Column="3" Text="Unit" FontWeight="SemiBold" FontSize="12" Foreground="Gray" Margin="6,0"/>
                                                        <TextBlock Grid.Column="4" Text="Unit Cost" FontWeight="SemiBold" FontSize="12" Foreground="Gray" Width="60" TextAlignment="Right"/>
                                                    </Grid>
                                                </Border>

                                                <!-- Component Rows -->
                                                <ItemsControl ItemsSource="{Binding MOComponentLines}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" Padding="0,8">
                                                                <Grid ColumnDefinitions="3*, 1*, 1*, 1*, Auto" VerticalAlignment="Center">
                                                                    <TextBlock Grid.Column="0" Text="{Binding ProductName}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                                    <TextBlock Grid.Column="1" Text="{Binding ExpectedQuantity, StringFormat='{}{0:F2}'}" Margin="6,0" VerticalAlignment="Center"/>
                                                                    
                                                                    <!-- Actual Consumed: editable only during ProduceStateActive -->
                                                                    <TextBox Grid.Column="2" Text="{Binding ActualQuantity}" Margin="6,0" VerticalAlignment="Center"
                                                                             IsEnabled="{Binding $parent[UserControl].((vm:ManufacturingViewModel)DataContext).IsProduceStateActive}"/>
                                                                    
                                                                    <TextBlock Grid.Column="3" Text="{Binding Unit}" Margin="6,0" VerticalAlignment="Center" Foreground="Gray"/>
                                                                    <TextBlock Grid.Column="4" Text="{Binding UnitCost, StringFormat='{}{0:N2}'}" VerticalAlignment="Center" TextAlignment="Right" Width="60" Foreground="Gray"/>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </TabItem>
                                    <TabItem Header="Miscellaneous">
                                        <Border Padding="0,20">
                                            <TextBlock Text="Manufacturing Order logs, audit fields and system users." Foreground="Gray" HorizontalAlignment="Center"/>
                                        </Border>
                                    </TabItem>
                                </TabControl>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </TabItem>

        <!-- ==================== TAB 3: PRODUCTION REPORTING ==================== -->
        <TabItem Header="Reporting">
            <Grid RowDefinitions="Auto, *" Margin="10">
                <!-- Summary Widgets Card Grid -->
                <Grid Grid.Row="0" ColumnDefinitions="*, *, *" Margin="0,0,0,20">
                    <!-- Widget 1: Total Manufacturing Orders -->
                    <Border Grid.Column="0" Background="{DynamicResource CardBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,10,0">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Total Runs Started" FontSize="11" Foreground="Gray" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding TotalMOsCount}" FontSize="24" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- Widget 2: Completed Orders -->
                    <Border Grid.Column="1" Background="{DynamicResource CardBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="16" Margin="10,0,10,0">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Completed Production Runs" FontSize="11" Foreground="Gray" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding CompletedMOsCount}" FontSize="24" FontWeight="Bold" Foreground="#2E7D32"/>
                        </StackPanel>
                    </Border>

                    <!-- Widget 3: Cumulative Cost of Materials -->
                    <Border Grid.Column="2" Background="{DynamicResource CardBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="16" Margin="10,0,0,0">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Cumulative Materials Cost" FontSize="11" Foreground="Gray" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding TotalProductionCost, StringFormat='{}{0:N2} RWF'}" FontSize="22" FontWeight="Bold" Foreground="#007ACC"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- DataGrid logs list -->
                <Border Grid.Row="1" Background="{DynamicResource CardBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="12">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Finished Goods Yields &amp; Cost Summaries" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <DataGrid ItemsSource="{Binding ReportOrders}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Production Code (MO)" Binding="{Binding MONumber}" Width="*" />
                                <DataGridTextColumn Header="Final Manufactured Good" Binding="{Binding ProductName}" Width="2*" />
                                <DataGridTextColumn Header="Planned Qty" Binding="{Binding ManufacturingOrder.TargetQuantity}" Width="*" />
                                <DataGridTextColumn Header="Actual Qty Produced" Binding="{Binding ManufacturingOrder.ActualQuantity}" Width="*" />
                                <DataGridTextColumn Header="Yield Cost (RWF)" Binding="{Binding TotalCostDisplay}" Width="*" />
                                <DataGridTextColumn Header="Date Completed" Binding="{Binding ManufacturingOrder.ProduceDate, StringFormat='{}{0:yyyy-MM-dd}'}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
