<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:InventoryManagementSystem.UI.ViewModels"
             xmlns:domain="clr-namespace:InventoryManagementSystem.Domain"
             xmlns:svc="clr-namespace:InventoryManagementSystem.Services"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="800"
             x:Class="InventoryManagementSystem.UI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             Background="{DynamicResource PageBackgroundColor}">

    <UserControl.Styles>
        <!-- Premium Tab Navigation Button Styling -->
        <Style Selector="Button.tab-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="BorderThickness" Value="0,0,0,3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.tab-btn:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryColor}"/>
            <Setter Property="Background" Value="#10000000"/>
        </Style>
        <Style Selector="Button.active-tab">
            <Setter Property="Foreground" Value="#007ACC"/>
            <Setter Property="BorderBrush" Value="#007ACC"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, Auto, *" Margin="30">
        <!-- Header -->
        <TextBlock Text="{Binding Language.Resources[Settings_Title]}" FontSize="28" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryColor}" Margin="0,0,0,20" />

        <!-- Inline Tab Bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="5" Margin="0,0,0,20">
            <Button Content="General Settings" Command="{Binding SelectTabCommand}" CommandParameter="General"
                    Classes="tab-btn" Classes.active-tab="{Binding IsGeneralTabActive}" />
            <Button Content="Taxes Setup" Command="{Binding SelectTabCommand}" CommandParameter="Taxes"
                    Classes="tab-btn" Classes.active-tab="{Binding IsTaxesTabActive}" />
            <Button Content="Accounting" Command="{Binding SelectTabCommand}" CommandParameter="Accounting"
                    Classes="tab-btn" Classes.active-tab="{Binding IsAccountingTabActive}" />
            <Button Content="Payments Setup" Command="{Binding SelectTabCommand}" CommandParameter="Payments"
                    Classes="tab-btn" Classes.active-tab="{Binding IsPaymentsTabActive}" />
            <Button Content="Financial" Command="{Binding SelectTabCommand}" CommandParameter="Financial"
                    Classes="tab-btn" Classes.active-tab="{Binding IsFinancialTabActive}" />
            <Button Content="Business Setup" Command="{Binding SelectTabCommand}" CommandParameter="BusinessSetup"
                    Classes="tab-btn" Classes.active-tab="{Binding IsBusinessSetupTabActive}" />
            <Button Content="Custom Fields" Command="{Binding SelectTabCommand}" CommandParameter="CustomFields"
                    Classes="tab-btn" Classes.active-tab="{Binding IsCustomFieldsTabActive}" />
            <Button Content="Terminology" Command="{Binding SelectTabCommand}" CommandParameter="Terminology"
                    Classes="tab-btn" Classes.active-tab="{Binding IsTerminologyTabActive}" />
            <Button Content="Modules" Command="{Binding SelectTabCommand}" CommandParameter="Modules"
                    Classes="tab-btn" Classes.active-tab="{Binding IsModulesTabActive}" />
        </StackPanel>

        <!-- Content Area -->
        <Border Grid.Row="2" Background="{DynamicResource ContentBackgroundColor}" CornerRadius="12" Padding="30" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Panel>
                    <!-- TAB 1: GENERAL SETTINGS -->
                    <StackPanel Spacing="20" MaxWidth="600" HorizontalAlignment="Left" IsVisible="{Binding IsGeneralTabActive}">
                        <StackPanel Spacing="5">
                             <TextBlock Text="{Binding Language.Resources[Settings_StoreInfo]}" FontSize="20" FontWeight="Bold"/>
                             <TextBlock Text="{Binding Language.Resources[Settings_StoreInfoDesc]}" Foreground="Gray" Margin="0,0,0,10"/>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="{Binding Language.Resources[Settings_StoreName]}" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding StoreName}" Watermark="{Binding Language.Resources[Settings_StoreName]}"/>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="{Binding Language.Resources[Settings_Address]}" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding StoreAddress}" Watermark="{Binding Language.Resources[Settings_Address]}" Height="80" AcceptsReturn="True"/>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="{Binding Language.Resources[Settings_Currency]}" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding CurrencySymbol}" Watermark="e.g. RWF, $, €" Width="150" HorizontalAlignment="Left"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="5">
                            <TextBlock Text="{Binding Language.Resources[Settings_Printer]}" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding PrinterName}" Watermark="{Binding Language.Resources[Settings_Printer]}"/>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Enable Sudo Mode (Super User Functions)" FontWeight="SemiBold"/>
                            <ToggleSwitch IsChecked="{Binding IsSudoModeEnabled}" OnContent="Enabled" OffContent="Disabled" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Spacing="15" Margin="0,20,0,0">
                            <Button Content="{Binding Language.Resources[Settings_Save]}" Command="{Binding SaveSettingsCommand}"
                                    Classes="accent" Background="#2E7D32" Foreground="White" Padding="20,10" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Foreground="#4CAF50" FontWeight="Medium"/>
                        </StackPanel>

                        <Separator Height="1" Background="{DynamicResource BorderColor}" Margin="0,25,0,15" IsVisible="{Binding IsSudoModeEnabled}"/>

                        <StackPanel Spacing="10" IsVisible="{Binding IsSudoModeEnabled}">
                            <TextBlock Text="Database Maintenance" FontSize="18" FontWeight="Bold" Foreground="#D32F2F"/>
                            <TextBlock Text="Warning: Clearing transaction data will permanently delete all sales orders, purchase orders, stock movements, and journal entries. Your product list and configurations will remain, but all stock levels and account balances will be reset to 0." 
                                       Foreground="Gray" TextWrapping="Wrap"/>
                            <Button Content="Clear Transaction Data (Reset Stock &amp; Balances)" 
                                    Command="{Binding ClearTransactionDataCommand}"
                                    Classes="accent" Background="#D32F2F" Foreground="White" Padding="20,10" FontWeight="SemiBold"
                                    HorizontalAlignment="Left" Margin="0,10,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- TAB 2: TAXES SETUP -->
                    <Grid RowDefinitions="Auto, Auto, *" IsVisible="{Binding IsTaxesTabActive}">
                        <!-- Top actions -->
                        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,15">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Manage Taxes" FontSize="20" FontWeight="Bold"/>
                                <TextBlock Text="Set up product tax rules for purchases and sales." Foreground="Gray"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="+ Create Tax" Command="{Binding OpenAddTaxFormCommand}" Background="#007ACC" Foreground="White" Padding="15,8" FontWeight="SemiBold" CornerRadius="6" IsVisible="{Binding !IsTaxFormVisible}" />
                        </Grid>

                        <!-- Add/Edit Tax Form (2-column layout) -->
                        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="20" CornerRadius="8" Margin="0,0,0,25" IsVisible="{Binding IsTaxFormVisible}">
                            <StackPanel Spacing="15">
                                <TextBlock Text="Add / Edit Tax Rule" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />

                                <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto, Auto, Auto" Margin="0" HorizontalAlignment="Stretch">
                                    <!-- Column 1 -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,15,12" Spacing="5">
                                        <TextBlock Text="Tax Name *" FontWeight="Medium" FontSize="12" />
                                        <TextBox Text="{Binding TaxName}" Watermark="e.g. VAT 18%" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,15,12" Spacing="5">
                                        <TextBlock Text="Tax Computation" FontWeight="Medium" FontSize="12" />
                                        <ComboBox ItemsSource="{Binding ComputationOptions}" SelectedItem="{Binding TaxComputation}" HorizontalAlignment="Stretch" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,15,12" Spacing="5">
                                        <TextBlock Text="Amount" FontWeight="Medium" FontSize="12" />
                                        <TextBox Text="{Binding TaxAmount}" Watermark="e.g. 18 for percentage, 500 for fixed" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,15,0" Spacing="5">
                                        <TextBlock Text="Tax Type" FontWeight="Medium" FontSize="12" />
                                        <ComboBox ItemsSource="{Binding TaxTypeOptions}" SelectedItem="{Binding TaxType}" HorizontalAlignment="Stretch" />
                                    </StackPanel>

                                    <!-- Column 2 -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="15,0,0,12" Spacing="5">
                                        <TextBlock Text="Label on Invoices" FontWeight="Medium" FontSize="12" />
                                        <TextBox Text="{Binding TaxLabelOnInvoice}" Watermark="e.g. VAT (defaults to Name)" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="15,0,0,12" Spacing="5">
                                        <TextBlock Text="Tax Scope" FontWeight="Medium" FontSize="12" />
                                        <ComboBox ItemsSource="{Binding ScopeOptions}" SelectedItem="{Binding TaxScope}" HorizontalAlignment="Stretch" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="15,0,0,12" Spacing="5">
                                        <TextBlock Text="Included in Price" FontWeight="Medium" FontSize="12" />
                                        <ComboBox ItemsSource="{Binding IncludedInPriceOptions}" SelectedItem="{Binding IncludedInPrice}" HorizontalAlignment="Stretch" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="15,0,0,0" Spacing="5">
                                        <TextBlock Text="Description" FontWeight="Medium" FontSize="12" />
                                        <TextBox Text="{Binding TaxDescription}" Watermark="Optional description..." />
                                    </StackPanel>

                                    <!-- Status Toggle Row -->
                                    <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,12,15,0" Spacing="10" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Status" FontWeight="Medium" FontSize="12" VerticalAlignment="Center" />
                                        <ToggleSwitch IsChecked="{Binding TaxIsActive}" OnContent="Active" OffContent="Inactive" VerticalAlignment="Center" Margin="10,0,0,0" />
                                    </StackPanel>

                                    <!-- Tax Account Selector -->
                                    <StackPanel Grid.Row="4" Grid.Column="1" Margin="15,12,0,0" Spacing="5">
                                        <TextBlock Text="Tax Account (COA)" FontWeight="Medium" FontSize="12" />
                                        <ComboBox ItemsSource="{Binding TaxAccounts}" SelectedItem="{Binding TaxSelectedAccount}" HorizontalAlignment="Stretch">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                                        <TextBlock Text="{Binding Code}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="-"/>
                                                        <TextBlock Text="{Binding Name}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="{Binding TaxErrorMessage}" Foreground="#D32F2F" FontSize="12" Margin="0,5,0,0" IsVisible="{Binding TaxErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,15,0,0">
                                    <Button Content="Cancel" Command="{Binding CloseTaxFormCommand}" Padding="15,8" />
                                    <Button Content="Save Tax Rule" Command="{Binding SaveTaxCommand}" Background="#2E7D32" Foreground="White" Padding="15,8" FontWeight="SemiBold" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Taxes Table -->
                        <DataGrid Grid.Row="2" ItemsSource="{Binding Taxes}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="All" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" MinHeight="250">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="Label on Invoice" Binding="{Binding LabelOnInvoice}" Width="*" />
                                <DataGridTextColumn Header="Computation" Binding="{Binding Computation}" Width="110" />
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="100" />
                                <DataGridTextColumn Header="Type" Binding="{Binding TaxType}" Width="100" />
                                <DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="100" />
                                <DataGridTextColumn Header="Included in Price" Binding="{Binding IncludedInPrice}" Width="130" />
                                <DataGridTemplateColumn Header="Status" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Panel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).ToggleTaxStatusCommand}" CommandParameter="{Binding .}" IsVisible="{Binding IsActive}" Background="#2E7D32" Foreground="White" Content="Active" FontSize="11" Padding="10,4" CornerRadius="4" Cursor="Hand" />
                                                <Button Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).ToggleTaxStatusCommand}" CommandParameter="{Binding .}" IsVisible="{Binding !IsActive}" Background="#D32F2F" Foreground="White" Content="Inactive" FontSize="11" Padding="10,4" CornerRadius="4" Cursor="Hand" />
                                            </Panel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Actions" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="5" Margin="5,0">
                                                <Button Content="Edit" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).OpenEditTaxFormCommand}" CommandParameter="{Binding .}" FontSize="11" Padding="6,3" />
                                                <Button Content="Delete" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).DeleteTaxCommand}" CommandParameter="{Binding .}" Background="#D32F2F" Foreground="White" FontSize="11" Padding="6,3" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- TAB 3: ACCOUNTING SETUP -->
                    <Grid RowDefinitions="Auto, *" IsVisible="{Binding IsAccountingTabActive}" Margin="0,10,0,0">
                        <!-- Top header row: sub-tab selector + context-sensitive create button -->
                        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,15">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
                                <TextBlock Text="Accounting Setting:" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryColor}"/>
                                <ComboBox ItemsSource="{Binding AccountingSubTabs}" SelectedItem="{Binding SelectedAccountingSubTab}" Width="220" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Panel Grid.Column="2">
                                <Button Content="+ Create Account" Command="{Binding OpenAddAccountFormCommand}" Background="#007ACC" Foreground="White" Padding="15,8" FontWeight="SemiBold" CornerRadius="6" IsVisible="{Binding IsCreateAccountButtonVisible}" />
                                <Button Content="+ Create Journal" Command="{Binding OpenAddJournalFormCommand}" Background="#007ACC" Foreground="White" Padding="15,8" FontWeight="SemiBold" CornerRadius="6" IsVisible="{Binding IsCreateJournalButtonVisible}" />
                            </Panel>
                        </Grid>

                        <!-- Content area — all sub-tab panels share Grid Row 1 -->
                        <Panel Grid.Row="1">

                            <!-- ══ CHART OF ACCOUNTS ══ -->
                            <Grid ColumnDefinitions="240, *" IsVisible="{Binding IsChartOfAccountsVisible}">
                                <!-- Sidebar Groups -->
                                <Border Grid.Column="0" Background="{DynamicResource PageBackgroundColor}" CornerRadius="12" Padding="10" Margin="0,0,15,0" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" VerticalAlignment="Top">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Account Groups" FontSize="14" FontWeight="SemiBold" Margin="5,0,0,5" Foreground="Gray"/>
                                        <ListBox ItemsSource="{Binding Groups}" SelectedItem="{Binding SelectedGroupText}" Background="Transparent" BorderThickness="0">
                                            <ListBox.Styles>
                                                <Style Selector="ListBoxItem">
                                                    <Setter Property="Padding" Value="12,10"/>
                                                    <Setter Property="CornerRadius" Value="8"/>
                                                    <Setter Property="Margin" Value="0,2"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                            </ListBox.Styles>
                                        </ListBox>
                                    </StackPanel>
                                </Border>

                                <!-- Table & Search -->
                                <Grid Grid.Column="1" RowDefinitions="Auto, *">
                                    <TextBox Grid.Row="0" Text="{Binding AccountSearchQuery}" Watermark="Search by account code, name or type..." Margin="0,0,0,15" UseFloatingWatermark="False"/>
                                    <DataGrid Grid.Row="1" ItemsSource="{Binding FilteredAccounts}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="All" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" MinHeight="350">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="100" />
                                            <DataGridTextColumn Header="Account Name" Binding="{Binding Name}" Width="2*" />
                                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="2*" />
                                            <DataGridTemplateColumn Header="Payment Reconciliation" Width="180">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Panel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <TextBlock Text="Yes" IsVisible="{Binding PaymentReconciliation}" Foreground="#2E7D32" FontWeight="SemiBold"/>
                                                            <TextBlock Text="No" IsVisible="{Binding !PaymentReconciliation}" Foreground="Gray"/>
                                                        </Panel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Currency" Binding="{Binding Currency}" Width="100" />
                                            <DataGridTemplateColumn Header="Status" Width="100">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Panel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Button Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).ToggleAccountStatusCommand}" CommandParameter="{Binding .}" IsVisible="{Binding IsActive}" Background="#2E7D32" Foreground="White" Content="Active" FontSize="11" Padding="10,4" CornerRadius="4" Cursor="Hand" />
                                                            <Button Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).ToggleAccountStatusCommand}" CommandParameter="{Binding .}" IsVisible="{Binding !IsActive}" Background="#D32F2F" Foreground="White" Content="Inactive" FontSize="11" Padding="10,4" CornerRadius="4" Cursor="Hand" />
                                                        </Panel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Actions" Width="140">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="5" Margin="5,0">
                                                            <Button Content="Edit" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).OpenEditAccountFormCommand}" CommandParameter="{Binding .}" FontSize="11" Padding="6,3" />
                                                            <Button Content="Delete" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).DeleteAccountCommand}" CommandParameter="{Binding .}" Background="#D32F2F" Foreground="White" FontSize="11" Padding="6,3" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Grid>

                            <!-- Add/Edit Account Form -->
                            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="20" CornerRadius="8" IsVisible="{Binding IsAccountFormVisible}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Spacing="15">
                                        <TextBlock Text="Add / Edit Chart of Account" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
                                        <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto, Auto, Auto" HorizontalAlignment="Stretch">
                                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,15,12" Spacing="5">
                                                <TextBlock Text="Account Code *" FontWeight="Medium" FontSize="12" />
                                                <TextBox Text="{Binding NewAccountCode}" Watermark="e.g. 101000" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,15,12" Spacing="5">
                                                <TextBlock Text="Account Name *" FontWeight="Medium" FontSize="12" />
                                                <TextBox Text="{Binding NewAccountName}" Watermark="e.g. Cash on Hand" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,15,12" Spacing="5">
                                                <TextBlock Text="Account Type *" FontWeight="Medium" FontSize="12" />
                                                <ComboBox ItemsSource="{Binding AccountTypeOptions}" SelectedItem="{Binding NewAccountType}" HorizontalAlignment="Stretch" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,15,12" Spacing="5">
                                                <TextBlock Text="Default Taxes" FontWeight="Medium" FontSize="12" />
                                                <ComboBox ItemsSource="{Binding AvailableTaxes}" SelectedItem="{Binding NewAccountSelectedTax}" HorizontalAlignment="Stretch">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Name}"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="15,0,0,12" Spacing="5">
                                                <TextBlock Text="Currency" FontWeight="Medium" FontSize="12" />
                                                <ComboBox ItemsSource="{Binding CurrencyOptions}" SelectedItem="{Binding NewAccountCurrency}" HorizontalAlignment="Stretch" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="15,0,0,12" Spacing="5">
                                                <TextBlock Text="Description" FontWeight="Medium" FontSize="12" />
                                                <TextBox Text="{Binding NewAccountDescription}" Watermark="Optional description..." Height="75" AcceptsReturn="True" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="15,0,0,12" Spacing="10" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="Active" FontWeight="Medium" FontSize="12" VerticalAlignment="Center" />
                                                <ToggleSwitch IsChecked="{Binding NewAccountIsActive}" OnContent="Active" OffContent="Inactive" VerticalAlignment="Center" Margin="10,0,0,0" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="3" Grid.Column="1" Margin="15,0,0,12" Spacing="10" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="Payment Reconciliation" FontWeight="Medium" FontSize="12" VerticalAlignment="Center" />
                                                <ToggleSwitch IsChecked="{Binding NewAccountPaymentReconciliation}" OnContent="Enabled" OffContent="Disabled" VerticalAlignment="Center" Margin="10,0,0,0" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="{Binding AccountErrorMessage}" Foreground="#D32F2F" FontSize="12" Margin="0,5,0,0" IsVisible="{Binding AccountErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,15,0,0">
                                            <Button Content="Cancel" Command="{Binding CloseAccountFormCommand}" Padding="15,8" />
                                            <Button Content="Save Account" Command="{Binding SaveAccountCommand}" Background="#2E7D32" Foreground="White" Padding="15,8" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>

                            <!-- ══ JOURNALS ══ -->
                            <DataGrid ItemsSource="{Binding Journals}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="All" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" MinHeight="350" IsVisible="{Binding IsJournalsVisible}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Journal Name" Binding="{Binding Journal.Name}" Width="2*" />
                                    <DataGridTextColumn Header="Type" Binding="{Binding Journal.Type}" Width="*" />
                                    <DataGridTextColumn Header="Sequence Prefix" Binding="{Binding Journal.SequencePrefix}" Width="*" />
                                    <DataGridTextColumn Header="Default Account" Binding="{Binding DefaultAccountDisplay}" Width="2*" />
                                    <DataGridTextColumn Header="Bank Name" Binding="{Binding LinkedBankName}" Width="*" />
                                    <DataGridTextColumn Header="Bank Account" Binding="{Binding LinkedBankAccountNumber}" Width="*" />
                                    <DataGridTemplateColumn Header="Actions" Width="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="5" Margin="5,0">
                                                    <Button Content="Edit" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).OpenEditJournalFormCommand}" CommandParameter="{Binding .}" FontSize="11" Padding="6,3" />
                                                    <Button Content="Delete" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).DeleteJournalCommand}" CommandParameter="{Binding .}" Background="#D32F2F" Foreground="White" FontSize="11" Padding="6,3" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Add/Edit Journal Form -->
                            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="20" CornerRadius="8" IsVisible="{Binding IsJournalFormVisible}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Spacing="15">
                                        <TextBlock Text="Add / Edit Journal" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />

                                        <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto, Auto" HorizontalAlignment="Stretch">
                                            <!-- Left column -->
                                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,15,12" Spacing="5">
                                                <TextBlock Text="Journal Name *" FontWeight="Medium" FontSize="12" />
                                                <TextBox Text="{Binding JournalName}" Watermark="e.g. Sales, Bank" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,15,12" Spacing="5">
                                                <TextBlock Text="Type" FontWeight="Medium" FontSize="12" />
                                                <ComboBox ItemsSource="{Binding JournalTypeOptions}" SelectedItem="{Binding JournalType}" HorizontalAlignment="Stretch" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,15,12" Spacing="5">
                                                <TextBlock Text="Sequence Prefix *" FontWeight="Medium" FontSize="12" />
                                                <TextBox Text="{Binding JournalSequencePrefix}" Watermark="e.g. INV, BILL, BNK1" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,15,12" Spacing="5">
                                                <TextBlock Text="Currency" FontWeight="Medium" FontSize="12" />
                                                <ComboBox ItemsSource="{Binding CurrencyOptions}" SelectedItem="{Binding JournalCurrency}" HorizontalAlignment="Stretch" />
                                            </StackPanel>

                                            <!-- Right column -->
                                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="15,0,0,12" Spacing="5">
                                                <TextBlock Text="Default Account" FontWeight="Medium" FontSize="12" />
                                                <TextBox Text="{Binding JournalAccountSearch}" Watermark="Type account code or name to search..." />
                                                <!-- Search results dropdown -->
                                                <Border IsVisible="{Binding IsJournalAccountResultsVisible}"
                                                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                                        CornerRadius="0,0,6,6" Background="{DynamicResource ContentBackgroundColor}"
                                                        MaxHeight="200">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                        <ItemsControl ItemsSource="{Binding JournalAccountResults}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                                            Background="Transparent" CornerRadius="0" Padding="10,7"
                                                                            Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).SelectJournalAccountCommand}"
                                                                            CommandParameter="{Binding .}"
                                                                            Cursor="Hand">
                                                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                                                            <TextBlock Text="{Binding Code}" FontSize="11" Foreground="Gray" VerticalAlignment="Center" MinWidth="60"/>
                                                                            <TextBlock Text="{Binding Name}" FontWeight="Medium" VerticalAlignment="Center"/>
                                                                        </StackPanel>
                                                                    </Button>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>
                                                </Border>
                                                <!-- Selected account badge -->
                                                <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding JournalDefaultAccount, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                    <Border Background="#10007ACC" CornerRadius="4" Padding="8,4">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Text="{Binding JournalDefaultAccount.Code}" FontSize="11" Foreground="#007ACC" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding JournalDefaultAccount.Name}" FontSize="11" Foreground="{DynamicResource TextPrimaryColor}"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <Button Content="✕" FontSize="10" Padding="4,2" VerticalAlignment="Center"
                                                            Background="Transparent" Foreground="Gray" Cursor="Hand"
                                                            Command="{Binding SelectJournalAccountCommand}" CommandParameter="{x:Null}" />
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Payment Communications card -->
                                            <Border Grid.Row="1" Grid.Column="1" Grid.RowSpan="3" Margin="15,0,0,12"
                                                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="15">
                                                <StackPanel Spacing="12">
                                                    <TextBlock Text="Payment Communications" FontWeight="SemiBold" FontSize="13" />

                                                    <StackPanel Spacing="5">
                                                        <TextBlock Text="Communication Type" FontWeight="Medium" FontSize="12" />
                                                        <ComboBox ItemsSource="{Binding PaymentCommunicationTypeOptions}" SelectedItem="{Binding JournalPaymentCommunicationType}" HorizontalAlignment="Stretch" />
                                                    </StackPanel>

                                                    <StackPanel Spacing="5">
                                                        <TextBlock Text="Communication Standard" FontWeight="Medium" FontSize="12" />
                                                        <TextBox Text="{Binding JournalPaymentCommunicationStandard}" Watermark="e.g. SEPA Credit Transfer" />
                                                    </StackPanel>

                                                    <!-- Contextual hint -->
                                                    <Border Background="#10007ACC" CornerRadius="6" Padding="10">
                                                        <StackPanel Spacing="4">
                                                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#007ACC">
                                                                <TextBlock.Text>
                                                                    <MultiBinding StringFormat="{}Mode: {0}">
                                                                        <Binding Path="JournalPaymentCommunicationType"/>
                                                                    </MultiBinding>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                            <TextBlock Text="Each invoice gets its own unique reference. Enables automatic 1-to-1 bank reconciliation." FontSize="11" Foreground="Gray" TextWrapping="Wrap"
                                                                       IsVisible="{Binding JournalPaymentCommunicationType, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                         <!-- Bank Journal specific configurations -->
                                         <Border IsVisible="{Binding IsJournalTypeBank}" 
                                                 BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" 
                                                 CornerRadius="8" Padding="15" Margin="0,15,0,0">
                                             <StackPanel Spacing="15">
                                                 <TextBlock Text="Bank Account &amp; Clearing Configuration" FontWeight="SemiBold" FontSize="14" Foreground="#007ACC" />
                                                 
                                                 <Border Background="#05007ACC" BorderBrush="#20007ACC" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,5">
                                                     <StackPanel Spacing="6">
                                                         <TextBlock Text="Clearing Zone Operations" FontWeight="Bold" FontSize="11" Foreground="#007ACC"/>
                                                         <TextBlock Text="Bank statements import transactions that aren't matched yet. These intermediate accounts act as temporary holding zones to ensure your balance sheet is accurate in real-time." FontSize="11" Foreground="Gray" TextWrapping="Wrap"/>
                                                     </StackPanel>
                                                 </Border>

                                                 <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto" HorizontalAlignment="Stretch">
                                                     <!-- Bank Account -->
                                                     <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,12" Spacing="5">
                                                         <TextBlock Text="1. Bank Account (CoA Asset)" FontWeight="Medium" FontSize="12" />
                                                         <TextBox Text="{Binding JournalBankAccountSearch}" Watermark="Search bank account in CoA..." />
                                                         <Border IsVisible="{Binding IsJournalBankAccountResultsVisible}"
                                                                 BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                                                 CornerRadius="0,0,6,6" Background="{DynamicResource ContentBackgroundColor}"
                                                                 MaxHeight="150" ZIndex="10">
                                                             <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                                 <ItemsControl ItemsSource="{Binding JournalBankAccountResults}">
                                                                     <ItemsControl.ItemTemplate>
                                                                         <DataTemplate>
                                                                             <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                                                     Background="Transparent" CornerRadius="0" Padding="10,7"
                                                                                     Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).SelectJournalBankAccountCommand}"
                                                                                     CommandParameter="{Binding .}"
                                                                                     Cursor="Hand">
                                                                                 <StackPanel Orientation="Horizontal" Spacing="10">
                                                                                     <TextBlock Text="{Binding Code}" FontSize="11" Foreground="Gray" VerticalAlignment="Center" MinWidth="60"/>
                                                                                     <TextBlock Text="{Binding Name}" FontWeight="Medium" VerticalAlignment="Center"/>
                                                                                 </StackPanel>
                                                                             </Button>
                                                                         </DataTemplate>
                                                                     </ItemsControl.ItemTemplate>
                                                                 </ItemsControl>
                                                             </ScrollViewer>
                                                         </Border>
                                                         <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding JournalBankAccount, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                             <Border Background="#10007ACC" CornerRadius="4" Padding="8,4">
                                                                 <StackPanel Orientation="Horizontal" Spacing="6">
                                                                     <TextBlock Text="{Binding JournalBankAccount.Code}" FontSize="11" Foreground="#007ACC" FontWeight="SemiBold"/>
                                                                     <TextBlock Text="{Binding JournalBankAccount.Name}" FontSize="11" Foreground="{DynamicResource TextPrimaryColor}"/>
                                                                 </StackPanel>
                                                             </Border>
                                                             <Button Content="✕" FontSize="10" Padding="4,2" VerticalAlignment="Center"
                                                                     Background="Transparent" Foreground="Gray" Cursor="Hand"
                                                                     Command="{Binding SelectJournalBankAccountCommand}" CommandParameter="{x:Null}" />
                                                         </StackPanel>
                                                     </StackPanel>

                                                     <!-- Suspense Account -->
                                                     <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,12" Spacing="5">
                                                         <TextBlock Text="2. Suspense Account (Clearing zone)" FontWeight="Medium" FontSize="12" />
                                                         <TextBox Text="{Binding JournalSuspenseAccountSearch}" Watermark="Search suspense account..." />
                                                         <Border IsVisible="{Binding IsJournalSuspenseAccountResultsVisible}"
                                                                 BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                                                 CornerRadius="0,0,6,6" Background="{DynamicResource ContentBackgroundColor}"
                                                                 MaxHeight="150" ZIndex="10">
                                                             <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                                 <ItemsControl ItemsSource="{Binding JournalSuspenseAccountResults}">
                                                                     <ItemsControl.ItemTemplate>
                                                                         <DataTemplate>
                                                                             <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                                                     Background="Transparent" CornerRadius="0" Padding="10,7"
                                                                                     Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).SelectJournalSuspenseAccountCommand}"
                                                                                     CommandParameter="{Binding .}"
                                                                                     Cursor="Hand">
                                                                                 <StackPanel Orientation="Horizontal" Spacing="10">
                                                                                     <TextBlock Text="{Binding Code}" FontSize="11" Foreground="Gray" VerticalAlignment="Center" MinWidth="60"/>
                                                                                     <TextBlock Text="{Binding Name}" FontWeight="Medium" VerticalAlignment="Center"/>
                                                                                 </StackPanel>
                                                                             </Button>
                                                                         </DataTemplate>
                                                                     </ItemsControl.ItemTemplate>
                                                                 </ItemsControl>
                                                             </ScrollViewer>
                                                         </Border>
                                                         <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding JournalSuspenseAccount, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                             <Border Background="#10007ACC" CornerRadius="4" Padding="8,4">
                                                                 <StackPanel Orientation="Horizontal" Spacing="6">
                                                                     <TextBlock Text="{Binding JournalSuspenseAccount.Code}" FontSize="11" Foreground="#007ACC" FontWeight="SemiBold"/>
                                                                     <TextBlock Text="{Binding JournalSuspenseAccount.Name}" FontSize="11" Foreground="{DynamicResource TextPrimaryColor}"/>
                                                                 </StackPanel>
                                                             </Border>
                                                             <Button Content="✕" FontSize="10" Padding="4,2" VerticalAlignment="Center"
                                                                     Background="Transparent" Foreground="Gray" Cursor="Hand"
                                                                     Command="{Binding SelectJournalSuspenseAccountCommand}" CommandParameter="{x:Null}" />
                                                         </StackPanel>
                                                     </StackPanel>

                                                     <!-- Profit Account -->
                                                     <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,12" Spacing="5">
                                                         <TextBlock Text="3. Profit Account (Exchange/Rounding Gain)" FontWeight="Medium" FontSize="12" />
                                                         <TextBox Text="{Binding JournalProfitAccountSearch}" Watermark="Search profit account..." />
                                                         <Border IsVisible="{Binding IsJournalProfitAccountResultsVisible}"
                                                                 BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                                                 CornerRadius="0,0,6,6" Background="{DynamicResource ContentBackgroundColor}"
                                                                 MaxHeight="150" ZIndex="10">
                                                             <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                                 <ItemsControl ItemsSource="{Binding JournalProfitAccountResults}">
                                                                     <ItemsControl.ItemTemplate>
                                                                         <DataTemplate>
                                                                             <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                                                     Background="Transparent" CornerRadius="0" Padding="10,7"
                                                                                     Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).SelectJournalProfitAccountCommand}"
                                                                                     CommandParameter="{Binding .}"
                                                                                     Cursor="Hand">
                                                                                 <StackPanel Orientation="Horizontal" Spacing="10">
                                                                                     <TextBlock Text="{Binding Code}" FontSize="11" Foreground="Gray" VerticalAlignment="Center" MinWidth="60"/>
                                                                                     <TextBlock Text="{Binding Name}" FontWeight="Medium" VerticalAlignment="Center"/>
                                                                                 </StackPanel>
                                                                             </Button>
                                                                         </DataTemplate>
                                                                     </ItemsControl.ItemTemplate>
                                                                 </ItemsControl>
                                                             </ScrollViewer>
                                                         </Border>
                                                         <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding JournalProfitAccount, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                             <Border Background="#10007ACC" CornerRadius="4" Padding="8,4">
                                                                 <StackPanel Orientation="Horizontal" Spacing="6">
                                                                     <TextBlock Text="{Binding JournalProfitAccount.Code}" FontSize="11" Foreground="#007ACC" FontWeight="SemiBold"/>
                                                                     <TextBlock Text="{Binding JournalProfitAccount.Name}" FontSize="11" Foreground="{DynamicResource TextPrimaryColor}"/>
                                                                 </StackPanel>
                                                             </Border>
                                                             <Button Content="✕" FontSize="10" Padding="4,2" VerticalAlignment="Center"
                                                                     Background="Transparent" Foreground="Gray" Cursor="Hand"
                                                                     Command="{Binding SelectJournalProfitAccountCommand}" CommandParameter="{x:Null}" />
                                                         </StackPanel>
                                                     </StackPanel>

                                                     <!-- Loss Account -->
                                                     <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,12" Spacing="5">
                                                         <TextBlock Text="4. Loss Account (Exchange/Rounding Loss)" FontWeight="Medium" FontSize="12" />
                                                         <TextBox Text="{Binding JournalLossAccountSearch}" Watermark="Search loss account..." />
                                                         <Border IsVisible="{Binding IsJournalLossAccountResultsVisible}"
                                                                 BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                                                 CornerRadius="0,0,6,6" Background="{DynamicResource ContentBackgroundColor}"
                                                                 MaxHeight="150" ZIndex="10">
                                                             <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                                 <ItemsControl ItemsSource="{Binding JournalLossAccountResults}">
                                                                     <ItemsControl.ItemTemplate>
                                                                         <DataTemplate>
                                                                             <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                                                     Background="Transparent" CornerRadius="0" Padding="10,7"
                                                                                     Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).SelectJournalLossAccountCommand}"
                                                                                     CommandParameter="{Binding .}"
                                                                                     Cursor="Hand">
                                                                                 <StackPanel Orientation="Horizontal" Spacing="10">
                                                                                     <TextBlock Text="{Binding Code}" FontSize="11" Foreground="Gray" VerticalAlignment="Center" MinWidth="60"/>
                                                                                     <TextBlock Text="{Binding Name}" FontWeight="Medium" VerticalAlignment="Center"/>
                                                                                 </StackPanel>
                                                                             </Button>
                                                                         </DataTemplate>
                                                                     </ItemsControl.ItemTemplate>
                                                                 </ItemsControl>
                                                             </ScrollViewer>
                                                         </Border>
                                                         <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding JournalLossAccount, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                             <Border Background="#10007ACC" CornerRadius="4" Padding="8,4">
                                                                 <StackPanel Orientation="Horizontal" Spacing="6">
                                                                     <TextBlock Text="{Binding JournalLossAccount.Code}" FontSize="11" Foreground="#007ACC" FontWeight="SemiBold"/>
                                                                     <TextBlock Text="{Binding JournalLossAccount.Name}" FontSize="11" Foreground="{DynamicResource TextPrimaryColor}"/>
                                                                 </StackPanel>
                                                             </Border>
                                                             <Button Content="✕" FontSize="10" Padding="4,2" VerticalAlignment="Center"
                                                                     Background="Transparent" Foreground="Gray" Cursor="Hand"
                                                                     Command="{Binding SelectJournalLossAccountCommand}" CommandParameter="{x:Null}" />
                                                         </StackPanel>
                                                     </StackPanel>

                                                     <!-- Outstanding Receipts Account -->
                                                     <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,12" Spacing="5">
                                                         <TextBlock Text="5. Outstanding Receipts Account" FontWeight="Medium" FontSize="12" />
                                                         <TextBox Text="{Binding JournalOutstandingReceiptsAccountSearch}" Watermark="Search outstanding receipts..." />
                                                         <Border IsVisible="{Binding IsJournalOutstandingReceiptsAccountResultsVisible}"
                                                                 BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                                                 CornerRadius="0,0,6,6" Background="{DynamicResource ContentBackgroundColor}"
                                                                 MaxHeight="150" ZIndex="10">
                                                             <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                                 <ItemsControl ItemsSource="{Binding JournalOutstandingReceiptsAccountResults}">
                                                                     <ItemsControl.ItemTemplate>
                                                                         <DataTemplate>
                                                                             <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                                                     Background="Transparent" CornerRadius="0" Padding="10,7"
                                                                                     Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).SelectJournalOutstandingReceiptsAccountCommand}"
                                                                                     CommandParameter="{Binding .}"
                                                                                     Cursor="Hand">
                                                                                 <StackPanel Orientation="Horizontal" Spacing="10">
                                                                                     <TextBlock Text="{Binding Code}" FontSize="11" Foreground="Gray" VerticalAlignment="Center" MinWidth="60"/>
                                                                                     <TextBlock Text="{Binding Name}" FontWeight="Medium" VerticalAlignment="Center"/>
                                                                                 </StackPanel>
                                                                             </Button>
                                                                         </DataTemplate>
                                                                     </ItemsControl.ItemTemplate>
                                                                 </ItemsControl>
                                                             </ScrollViewer>
                                                         </Border>
                                                         <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding JournalOutstandingReceiptsAccount, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                             <Border Background="#10007ACC" CornerRadius="4" Padding="8,4">
                                                                 <StackPanel Orientation="Horizontal" Spacing="6">
                                                                     <TextBlock Text="{Binding JournalOutstandingReceiptsAccount.Code}" FontSize="11" Foreground="#007ACC" FontWeight="SemiBold"/>
                                                                     <TextBlock Text="{Binding JournalOutstandingReceiptsAccount.Name}" FontSize="11" Foreground="{DynamicResource TextPrimaryColor}"/>
                                                                 </StackPanel>
                                                             </Border>
                                                             <Button Content="✕" FontSize="10" Padding="4,2" VerticalAlignment="Center"
                                                                     Background="Transparent" Foreground="Gray" Cursor="Hand"
                                                                     Command="{Binding SelectJournalOutstandingReceiptsAccountCommand}" CommandParameter="{x:Null}" />
                                                         </StackPanel>
                                                     </StackPanel>

                                                     <!-- Outstanding Payments Account -->
                                                     <StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,12" Spacing="5">
                                                         <TextBlock Text="6. Outstanding Payments Account" FontWeight="Medium" FontSize="12" />
                                                         <TextBox Text="{Binding JournalOutstandingPaymentsAccountSearch}" Watermark="Search outstanding payments..." />
                                                         <Border IsVisible="{Binding IsJournalOutstandingPaymentsAccountResultsVisible}"
                                                                 BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                                                 CornerRadius="0,0,6,6" Background="{DynamicResource ContentBackgroundColor}"
                                                                 MaxHeight="150" ZIndex="10">
                                                             <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                                 <ItemsControl ItemsSource="{Binding JournalOutstandingPaymentsAccountResults}">
                                                                     <ItemsControl.ItemTemplate>
                                                                         <DataTemplate>
                                                                             <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                                                     Background="Transparent" CornerRadius="0" Padding="10,7"
                                                                                     Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).SelectJournalOutstandingPaymentsAccountCommand}"
                                                                                     CommandParameter="{Binding .}"
                                                                                     Cursor="Hand">
                                                                                 <StackPanel Orientation="Horizontal" Spacing="10">
                                                                                     <TextBlock Text="{Binding Code}" FontSize="11" Foreground="Gray" VerticalAlignment="Center" MinWidth="60"/>
                                                                                     <TextBlock Text="{Binding Name}" FontWeight="Medium" VerticalAlignment="Center"/>
                                                                                 </StackPanel>
                                                                             </Button>
                                                                         </DataTemplate>
                                                                     </ItemsControl.ItemTemplate>
                                                                 </ItemsControl>
                                                             </ScrollViewer>
                                                         </Border>
                                                         <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding JournalOutstandingPaymentsAccount, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                             <Border Background="#10007ACC" CornerRadius="4" Padding="8,4">
                                                                 <StackPanel Orientation="Horizontal" Spacing="6">
                                                                     <TextBlock Text="{Binding JournalOutstandingPaymentsAccount.Code}" FontSize="11" Foreground="#007ACC" FontWeight="SemiBold"/>
                                                                     <TextBlock Text="{Binding JournalOutstandingPaymentsAccount.Name}" FontSize="11" Foreground="{DynamicResource TextPrimaryColor}"/>
                                                                 </StackPanel>
                                                             </Border>
                                                             <Button Content="✕" FontSize="10" Padding="4,2" VerticalAlignment="Center"
                                                                     Background="Transparent" Foreground="Gray" Cursor="Hand"
                                                                     Command="{Binding SelectJournalOutstandingPaymentsAccountCommand}" CommandParameter="{x:Null}" />
                                                         </StackPanel>
                                                     </StackPanel>
                                                 </Grid>

                                                 <!-- Linked Real-World Bank Account Dropdown -->
                                                 <StackPanel Spacing="5" Margin="0,5,0,0">
                                                     <TextBlock Text="7. Linked Bank Account (Company's Real-World Bank Account)" FontWeight="Medium" FontSize="12" />
                                                     <ComboBox ItemsSource="{Binding BankAccounts}" SelectedItem="{Binding JournalSelectedLinkedBankAccount}" HorizontalAlignment="Stretch">
                                                         <ComboBox.ItemTemplate>
                                                             <DataTemplate>
                                                                 <StackPanel Orientation="Horizontal" Spacing="10">
                                                                     <TextBlock Text="{Binding AccountNumber}" FontWeight="SemiBold"/>
                                                                     <TextBlock Text="-" Foreground="Gray"/>
                                                                     <TextBlock Text="{Binding BankName}" Foreground="Gray"/>
                                                                     <TextBlock Text="(Send Money Enabled)" Foreground="Green" FontSize="11" IsVisible="{Binding SendMoney}"/>
                                                                 </StackPanel>
                                                             </DataTemplate>
                                                         </ComboBox.ItemTemplate>
                                                     </ComboBox>
                                                     <TextBlock Text="Linking this connects incoming bank transactions directly to this double-entry accounting journal." FontSize="11" Foreground="Gray" Margin="2,2,0,0"/>
                                                 </StackPanel>
                                             </StackPanel>
                                             </Border>
                                             <TextBlock Text="{Binding JournalErrorMessage}" Foreground="#D32F2F" FontSize="12" Margin="0,5,0,0" IsVisible="{Binding JournalErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                                             <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,15,0,0">
                                                 <Button Content="Cancel" Command="{Binding CloseJournalFormCommand}" Padding="15,8" />
                                                 <Button Content="Save Journal" Command="{Binding SaveJournalCommand}" Background="#2E7D32" Foreground="White" Padding="15,8" FontWeight="SemiBold" />
                                             </StackPanel>
                                         </StackPanel>
                                     </ScrollViewer>
                                 </Border>

                            <!-- ══ ACCOUNTING REPORTS ══ -->
                            <Grid RowDefinitions="Auto, *" IsVisible="{Binding IsAccountingReportsVisible}">
                                <DataGrid Grid.Row="1" ItemsSource="{Binding Reports}" AutoGenerateColumns="False" IsReadOnly="False" GridLinesVisibility="All" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" MinHeight="350">
                                    <DataGrid.Columns>
                                        <!-- Checkbox Column -->
                                        <DataGridTemplateColumn Width="50">
                                            <DataGridTemplateColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).SelectAllReports, Mode=TwoWay}" HorizontalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.HeaderTemplate>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" HorizontalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Report Name -->
                                        <DataGridTemplateColumn Header="Report Name" Width="2*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding Report.Name}" FontSize="12" Padding="10,6" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" Foreground="#007ACC" Cursor="Hand" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).GoInsideReportCommand}" CommandParameter="{Binding .}">
                                                        <Button.Styles>
                                                            <Style Selector="Button:pointerover">
                                                                <Setter Property="Foreground" Value="#005A9E"/>
                                                                <Setter Property="Background" Value="Transparent"/>
                                                            </Style>
                                                        </Button.Styles>
                                                    </Button>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Root Report -->
                                        <DataGridTextColumn Header="Root Report" Binding="{Binding Report.RootReport}" FontSize="12" Width="*" IsReadOnly="True" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>

                            <!-- ══ REPORT DETAILS VIEW (INSIDE REPORT) ══ -->
                            <Grid RowDefinitions="Auto, *" IsVisible="{Binding IsReportDetailVisible}">
                                <!-- Details Header -->
                                <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,15">
                                    <Button Grid.Column="0" Content="← Back to Reports" Command="{Binding GoBackToReportsListCommand}" Padding="12,8" FontSize="12" Background="Transparent" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="15,0,0,0">
                                        <TextBlock Text="{Binding ReportDetailTitle}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <TextBlock Text="Structure &amp; Balances Configuration" FontSize="12" Foreground="Gray" VerticalAlignment="Center" Margin="5,4,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="Refresh Balances" Command="{Binding LoadReportLinesAsyncCommand}" Background="#007ACC" Foreground="White" Padding="12,8" FontSize="12" FontWeight="SemiBold" CornerRadius="6" />
                                </Grid>

                                <!-- Hierarchical Lines Table -->
                                <Grid Grid.Row="1" RowDefinitions="*, Auto">
                                    <DataGrid Grid.Row="0" ItemsSource="{Binding ReportLines}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="All" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" MinHeight="350">
                                        <DataGrid.Columns>
                                            <!-- Hierarchical Name -->
                                            <DataGridTemplateColumn Header="Line Name" Width="2*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Margin="5,0">
                                                            <Border Width="{Binding Indentation}"/>
                                                            <TextBlock Text="▸ " Foreground="Gray" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                            <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- Code -->
                                            <DataGridTextColumn Header="Code" Binding="{Binding Code}" FontSize="12" Width="1.2*" />

                                            <!-- Foldability -->
                                            <DataGridTextColumn Header="Foldability" Binding="{Binding Foldability}" FontSize="12" Width="*" />

                                            <!-- Preview Balance -->
                                            <DataGridTemplateColumn Header="Preview Balance" Width="1.5*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Balance, StringFormat={}{0:N0} RWF}" FontSize="12" FontWeight="Bold" Foreground="#007ACC" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- Actions -->
                                            <DataGridTemplateColumn Header="Actions" Width="140">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="5" Margin="5,0">
                                                            <Button Content="Edit" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).OpenEditLineFormCommand}" CommandParameter="{Binding .}" FontSize="11" Padding="6,3" />
                                                            <Button Content="Delete" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).DeleteLineCommand}" CommandParameter="{Binding .}" Background="#D32F2F" Foreground="White" FontSize="11" Padding="6,3" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <!-- Add Line button link -->
                                    <Button Grid.Row="1" Content="+ Add Line" Command="{Binding OpenAddLineFormCommand}" Background="Transparent" Foreground="#009688" Padding="10,8" Margin="0,10,0,0" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" HorizontalAlignment="Left">
                                        <Button.Styles>
                                            <Style Selector="Button:pointerover">
                                                <Setter Property="Foreground" Value="#00796B"/>
                                                <Setter Property="Background" Value="#10009688"/>
                                            </Style>
                                        </Button.Styles>
                                    </Button>
                                </Grid>
                             </Grid>

                          </Panel>
                     </Grid>

                     <!-- TAB 4: PAYMENTS SETUP -->
                     <Grid RowDefinitions="Auto, *" IsVisible="{Binding IsPaymentsTabActive}" Margin="0,10,0,0">
                         <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,15">
                             <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
                                 <TextBlock Text="Manage:" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryColor}"/>
                                 <ComboBox ItemsSource="{Binding PaymentsManagementTypes}" SelectedItem="{Binding SelectedPaymentsManagementType}" Width="220" VerticalAlignment="Center"/>
                             </StackPanel>
                             <Panel Grid.Column="2">
                                 <Button Content="+ Create Bank" Command="{Binding OpenAddBankFormCommand}" Background="#007ACC" Foreground="White" Padding="15,8" FontWeight="SemiBold" CornerRadius="6" IsVisible="{Binding IsBanksSubTabActive}" />
                                 <Button Content="+ Create Bank Account" Command="{Binding OpenAddBankAccountFormCommand}" Background="#007ACC" Foreground="White" Padding="15,8" FontWeight="SemiBold" CornerRadius="6" IsVisible="{Binding IsBankAccountsSubTabActive}" />
                             </Panel>
                         </Grid>

                         <Panel Grid.Row="1">
                             <!-- SUB-TAB 1: BANKS LIST & FORM -->
                             <Grid RowDefinitions="*, Auto" IsVisible="{Binding IsBanksSubTabActive}">
                                 <Panel>
                                     <!-- Banks Grid -->
                                     <Grid RowDefinitions="*, Auto" IsVisible="{Binding !IsBankFormVisible}">
                                         <DataGrid ItemsSource="{Binding Banks}" AutoGenerateColumns="False" CanUserResizeColumns="True" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" GridLinesVisibility="All">
                                             <DataGrid.Columns>
                                                 <DataGridTextColumn Header="Bank Name" Binding="{Binding Name}" Width="1.5*" />
                                                 <DataGridTextColumn Header="City" Binding="{Binding City}" Width="*" />
                                                 <DataGridTextColumn Header="Country" Binding="{Binding Country}" Width="*" />
                                                 <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="*" />
                                                 <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.5*" />
                                                 <DataGridTemplateColumn Header="Actions" Width="140">
                                                     <DataGridTemplateColumn.CellTemplate>
                                                         <DataTemplate x:DataType="domain:Bank">
                                                             <StackPanel Orientation="Horizontal" Spacing="5" Margin="5,0">
                                                                 <Button Content="Edit" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).OpenEditBankFormCommand}" CommandParameter="{Binding .}" FontSize="11" Padding="6,3" />
                                                                 <Button Content="Delete" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).DeleteBankCommand}" CommandParameter="{Binding .}" Background="#D32F2F" Foreground="White" FontSize="11" Padding="6,3" />
                                                             </StackPanel>
                                                         </DataTemplate>
                                                     </DataGridTemplateColumn.CellTemplate>
                                                 </DataGridTemplateColumn>
                                             </DataGrid.Columns>
                                         </DataGrid>
                                     </Grid>

                                     <!-- Bank Create/Edit Form -->
                                     <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="20" CornerRadius="8" IsVisible="{Binding IsBankFormVisible}">
                                         <StackPanel Spacing="15" MaxWidth="600" HorizontalAlignment="Left">
                                             <TextBlock Text="Bank Information" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryColor}"/>
                                             
                                             <Grid ColumnDefinitions="*, 15, *">
                                                 <StackPanel Grid.Column="0" Spacing="5">
                                                     <TextBlock Text="Bank Name" FontSize="12" FontWeight="SemiBold"/>
                                                     <TextBox Text="{Binding BankName}" Watermark="e.g. Bank of Kigali"/>
                                                 </StackPanel>
                                                 <StackPanel Grid.Column="2" Spacing="5">
                                                     <TextBlock Text="Phone" FontSize="12" FontWeight="SemiBold"/>
                                                     <TextBox Text="{Binding BankPhone}" Watermark="e.g. +250..."/>
                                                 </StackPanel>
                                             </Grid>

                                             <Grid ColumnDefinitions="*, 15, *">
                                                 <StackPanel Grid.Column="0" Spacing="5">
                                                     <TextBlock Text="Email" FontSize="12" FontWeight="SemiBold"/>
                                                     <TextBox Text="{Binding BankEmail}" Watermark="e.g. contact@bank.com"/>
                                                 </StackPanel>
                                                 <StackPanel Grid.Column="2" Spacing="5">
                                                     <TextBlock Text="Street Address" FontSize="12" FontWeight="SemiBold"/>
                                                     <TextBox Text="{Binding BankStreet}" Watermark="e.g. 12 KN 82 St"/>
                                                 </StackPanel>
                                             </Grid>

                                             <Grid ColumnDefinitions="*, 15, *">
                                                 <StackPanel Grid.Column="0" Spacing="5">
                                                     <TextBlock Text="City" FontSize="12" FontWeight="SemiBold"/>
                                                     <TextBox Text="{Binding BankCity}" Watermark="e.g. Kigali"/>
                                                 </StackPanel>
                                                 <StackPanel Grid.Column="2" Spacing="5">
                                                     <TextBlock Text="Country" FontSize="12" FontWeight="SemiBold"/>
                                                     <TextBox Text="{Binding BankCountry}" Watermark="e.g. Rwanda"/>
                                                 </StackPanel>
                                             </Grid>

                                             <TextBlock Text="{Binding BankErrorMessage}" Foreground="#D32F2F" FontSize="12" IsVisible="{Binding BankErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                                             <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                                                 <Button Content="Save" Command="{Binding SaveBankCommand}" Background="#007ACC" Foreground="White" Padding="20,8" FontWeight="SemiBold"/>
                                                 <Button Content="Cancel" Command="{Binding CancelBankFormCommand}" Background="#3A3F4C" Foreground="White" Padding="15,8"/>
                                             </StackPanel>
                                         </StackPanel>
                                     </Border>
                                 </Panel>
                             </Grid>

                             <!-- SUB-TAB 2: BANK ACCOUNTS LIST & FORM -->
                             <Grid RowDefinitions="*, Auto" IsVisible="{Binding IsBankAccountsSubTabActive}">
                                 <Panel>
                                     <!-- Bank Accounts Grid -->
                                     <Grid RowDefinitions="*, Auto" IsVisible="{Binding !IsBankAccountFormVisible}">
                                         <DataGrid ItemsSource="{Binding BankAccounts}" AutoGenerateColumns="False" CanUserResizeColumns="True" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" GridLinesVisibility="All">
                                             <DataGrid.Columns>
                                                 <DataGridTextColumn Header="Account Number" Binding="{Binding AccountNumber}" Width="1.5*" />
                                                 <DataGridTextColumn Header="Account Holder" Binding="{Binding AccountHolder}" Width="1.5*" />
                                                 <DataGridTextColumn Header="Bank" Binding="{Binding BankName}" Width="1.5*" />
                                                 <DataGridTextColumn Header="Currency" Binding="{Binding Currency}" Width="0.8*" />
                                                 <DataGridTemplateColumn Header="Send Money" Width="120">
                                                     <DataGridTemplateColumn.CellTemplate>
                                                         <DataTemplate x:DataType="vm:BankAccountDisplayRow">
                                                             <ToggleSwitch IsChecked="{Binding SendMoney, Mode=OneWay}" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).ToggleSendMoneyCommand}" CommandParameter="{Binding .}" OnContent="On" OffContent="Off" HorizontalAlignment="Center"/>
                                                         </DataTemplate>
                                                     </DataGridTemplateColumn.CellTemplate>
                                                 </DataGridTemplateColumn>
                                                 <DataGridTemplateColumn Header="Actions" Width="140">
                                                     <DataGridTemplateColumn.CellTemplate>
                                                         <DataTemplate x:DataType="vm:BankAccountDisplayRow">
                                                             <StackPanel Orientation="Horizontal" Spacing="5" Margin="5,0">
                                                                 <Button Content="Edit" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).OpenEditBankAccountFormCommand}" CommandParameter="{Binding .}" FontSize="11" Padding="6,3" />
                                                                 <Button Content="Delete" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).DeleteBankAccountCommand}" CommandParameter="{Binding .}" Background="#D32F2F" Foreground="White" FontSize="11" Padding="6,3" />
                                                             </StackPanel>
                                                         </DataTemplate>
                                                     </DataGridTemplateColumn.CellTemplate>
                                                 </DataGridTemplateColumn>
                                             </DataGrid.Columns>
                                         </DataGrid>
                                     </Grid>

                                     <!-- Bank Account Create/Edit Form -->
                                     <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="20" CornerRadius="8" IsVisible="{Binding IsBankAccountFormVisible}">
                                         <StackPanel Spacing="15" MaxWidth="600" HorizontalAlignment="Left">
                                             <TextBlock Text="Bank Account Information" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryColor}"/>
                                             
                                             <Grid ColumnDefinitions="*, 15, *">
                                                 <StackPanel Grid.Column="0" Spacing="5">
                                                     <TextBlock Text="Account Number" FontSize="12" FontWeight="SemiBold"/>
                                                     <TextBox Text="{Binding BankAccountNumber}" Watermark="e.g. 100012345678"/>
                                                 </StackPanel>
                                                 <StackPanel Grid.Column="2" Spacing="5">
                                                     <TextBlock Text="Account Holder" FontSize="12" FontWeight="SemiBold"/>
                                                     <TextBox Text="{Binding BankAccountHolder}" Watermark="e.g. My Company Name"/>
                                                 </StackPanel>
                                             </Grid>

                                             <Grid ColumnDefinitions="*, 15, *">
                                                 <!-- Bank Search and Autocomplete selection -->
                                                 <StackPanel Grid.Column="0" Spacing="5">
                                                     <TextBlock Text="Bank Link" FontSize="12" FontWeight="SemiBold"/>
                                                     <Panel>
                                                         <TextBox Text="{Binding BankSearchText}" Watermark="Search bank name..."/>
                                                         <Popup IsOpen="{Binding IsBankDropdownVisible}" Placement="Bottom">
                                                             <Border Background="{DynamicResource ContentBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="4" Width="280" MaxHeight="200" BoxShadow="0 4 6 -1 #1A000000">
                                                                 <ScrollViewer>
                                                                     <ItemsControl ItemsSource="{Binding MatchedBanks}">
                                                                         <ItemsControl.ItemTemplate>
                                                                             <DataTemplate x:DataType="domain:Bank">
                                                                                 <Button Content="{Binding Name}" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).SelectSearchBankCommand}" CommandParameter="{Binding .}" Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="10,8" Cursor="Hand"/>
                                                                             </DataTemplate>
                                                                         </ItemsControl.ItemTemplate>
                                                                     </ItemsControl>
                                                                 </ScrollViewer>
                                                             </Border>
                                                         </Popup>
                                                     </Panel>
                                                 </StackPanel>
                                                 
                                                 <StackPanel Grid.Column="2" Spacing="5">
                                                     <TextBlock Text="Currency" FontSize="12" FontWeight="SemiBold"/>
                                                     <TextBox Text="{Binding BankAccountCurrency}" Watermark="e.g. RWF, USD"/>
                                                 </StackPanel>
                                             </Grid>

                                             <!-- Send Money Switch -->
                                             <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                 <ToggleSwitch IsChecked="{Binding BankAccountSendMoney}" OnContent="Send Money Enabled" OffContent="Send Money Disabled"/>
                                             </StackPanel>

                                             <TextBlock Text="{Binding BankAccountErrorMessage}" Foreground="#D32F2F" FontSize="12" IsVisible="{Binding BankAccountErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                                             <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                                                 <Button Content="Save" Command="{Binding SaveBankAccountCommand}" Background="#007ACC" Foreground="White" Padding="20,8" FontWeight="SemiBold"/>
                                                 <Button Content="Cancel" Command="{Binding CancelBankAccountFormCommand}" Background="#3A3F4C" Foreground="White" Padding="15,8"/>
                                             </StackPanel>
                                         </StackPanel>
                                     </Border>
                                 </Panel>
                             </Grid>
                         </Panel>
                     </Grid>

                    <!-- TAB: FINANCIAL (Exchange Rates & Budget Lines) -->
                    <StackPanel Spacing="30" IsVisible="{Binding IsFinancialTabActive}">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Financial Settings" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="Manage exchange rates and annual budget lines for budget vs actual reporting." Foreground="Gray" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Exchange Rates -->
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBlock Text="Exchange Rates" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="+ Add Rate" Command="{Binding OpenAddExchangeRateFormCommand}" Background="#007ACC" Foreground="White" Padding="12,6"/>
                            </Grid>
                            <Grid ColumnDefinitions="*, *, *, Auto, Auto" RowDefinitions="Auto, Auto" Margin="0,0,0,8">
                                <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="From" FontSize="11" FontWeight="SemiBold"/>
                                    <ComboBox ItemsSource="{Binding CurrencyOptions}" SelectedItem="{Binding ExchangeFromCurrency}" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="To" FontSize="11" FontWeight="SemiBold"/>
                                    <ComboBox ItemsSource="{Binding CurrencyOptions}" SelectedItem="{Binding ExchangeToCurrency}" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Rate" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding ExchangeRateValue}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Effective Date" FontSize="11" FontWeight="SemiBold"/>
                                    <DatePicker SelectedDate="{Binding ExchangeEffectiveDate}"/>
                                </StackPanel>
                                <Button Grid.Column="4" Content="Save Rate" Command="{Binding SaveExchangeRateCommand}" Background="#2E7D32" Foreground="White" Padding="12,6" VerticalAlignment="Bottom"/>
                            </Grid>
                            <TextBlock Text="{Binding ExchangeRateErrorMessage}" Foreground="#D32F2F" IsVisible="{Binding ExchangeRateErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            <DataGrid ItemsSource="{Binding ExchangeRates}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" Height="180">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="From" Binding="{Binding FromCurrency}" Width="80"/>
                                    <DataGridTextColumn Header="To" Binding="{Binding ToCurrency}" Width="80"/>
                                    <DataGridTextColumn Header="Rate" Binding="{Binding Rate, StringFormat='{}{0:N4}'}" Width="120"/>
                                    <DataGridTextColumn Header="Effective" Binding="{Binding EffectiveDate, StringFormat='{}{0:yyyy-MM-dd}'}" Width="120"/>
                                    <DataGridTemplateColumn Header="Actions" Width="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate x:DataType="domain:ExchangeRate">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Button Content="Edit" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).OpenEditExchangeRateFormCommand}" CommandParameter="{Binding .}" Padding="6,2" FontSize="11"/>
                                                    <Button Content="Delete" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).DeleteExchangeRateCommand}" CommandParameter="{Binding .}" Padding="6,2" FontSize="11" Background="#D32F2F" Foreground="White"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>

                        <Separator Height="1" Background="{DynamicResource BorderColor}"/>

                        <!-- Budget Lines -->
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*, Auto, Auto">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <TextBlock Text="Budget Lines" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="Fiscal Year:" VerticalAlignment="Center"/>
                                    <NumericUpDown Value="{Binding BudgetLineFiscalYear}" Minimum="2000" Maximum="2100" Width="100"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="+ Add Budget Line" Command="{Binding OpenAddBudgetLineFormCommand}" Background="#007ACC" Foreground="White" Padding="12,6" Margin="0,0,8,0"/>
                                <Button Grid.Column="2" Content="Refresh" Command="{Binding LoadBudgetLinesCommand}" Background="#78909C" Foreground="White" Padding="12,6"/>
                            </Grid>
                            <Grid ColumnDefinitions="*, *, Auto, Auto" RowDefinitions="Auto, Auto">
                                <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Account" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding BudgetLineAccountSearch, Mode=TwoWay}" Watermark="Search account..."/>
                                    <ListBox ItemsSource="{Binding BudgetLineAccountResults}" IsVisible="{Binding IsBudgetLineAccountResultsVisible}" MaxHeight="120">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="domain:Account">
                                                <Button Content="{Binding Name}" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).SelectBudgetLineAccountCommand}" CommandParameter="{Binding .}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Month (0=annual)" FontSize="11" FontWeight="SemiBold"/>
                                    <ComboBox ItemsSource="{Binding BudgetPeriodMonthOptions}" SelectedItem="{Binding BudgetLinePeriodMonth}" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Amount" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding BudgetLineAmount}"/>
                                </StackPanel>
                                <Button Grid.Column="3" Content="Save Line" Command="{Binding SaveBudgetLineCommand}" Background="#2E7D32" Foreground="White" Padding="12,6" VerticalAlignment="Bottom"/>
                            </Grid>
                            <TextBox Text="{Binding BudgetLineNotes}" Watermark="Notes (optional)"/>
                            <TextBlock Text="{Binding BudgetLineErrorMessage}" Foreground="#D32F2F" IsVisible="{Binding BudgetLineErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            <DataGrid ItemsSource="{Binding BudgetLines}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" Height="200">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Account" Binding="{Binding AccountDisplay}" Width="*"/>
                                    <DataGridTextColumn Header="Month" Binding="{Binding PeriodMonth}" Width="70"/>
                                    <DataGridTextColumn Header="Amount" Binding="{Binding BudgetAmount, StringFormat='{}{0:N2}'}" Width="120"/>
                                    <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                                    <DataGridTemplateColumn Header="Actions" Width="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate x:DataType="vm:BudgetLineDisplayRow">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Button Content="Edit" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).OpenEditBudgetLineFormCommand}" CommandParameter="{Binding .}" Padding="6,2" FontSize="11"/>
                                                    <Button Content="Delete" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).DeleteBudgetLineCommand}" CommandParameter="{Binding .}" Padding="6,2" FontSize="11" Background="#D32F2F" Foreground="White"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>

                        <TextBlock Text="{Binding FinancialStatusMessage}" Foreground="#4CAF50" FontWeight="Medium"/>
                    </StackPanel>

                    <!-- TAB 5: BUSINESS SETUP -->
                    <StackPanel Spacing="20" MaxWidth="700" HorizontalAlignment="Left" IsVisible="{Binding IsBusinessSetupTabActive}">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Business Setup" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="Configure the business type that drives default categories, terminology, custom fields and enabled modules." Foreground="Gray" TextWrapping="Wrap" Margin="0,0,0,10"/>
                        </StackPanel>

                        <Border Background="{DynamicResource PageBackgroundColor}" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Current Business Type:" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding CurrentBusinessTypeDisplay}" Foreground="#007ACC" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Setup Completed:" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding IsBusinessSetupCompleted}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <StackPanel Spacing="10">
                            <TextBlock Text="Available Industry Templates" FontSize="16" FontWeight="SemiBold"/>
                            <ItemsControl ItemsSource="{Binding AvailableBusinessTemplates}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="svc:IndustryTemplate">
                                        <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Description}" Foreground="Gray" TextWrapping="Wrap" FontSize="12"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <Button Content="Run / Re-run Setup Wizard" Command="{Binding RunSetupWizardCommand}"
                                Classes="accent" Background="#2E7D32" Foreground="White" Padding="20,10" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                        <TextBlock Text="Re-running the wizard is additive: it only adds missing categories, custom fields, terminology and enables modules — it never deletes your existing data." Foreground="Gray" TextWrapping="Wrap" FontSize="12"/>
                    </StackPanel>

                    <!-- TAB 6: CUSTOM FIELDS -->
                    <Grid RowDefinitions="Auto, Auto, *" IsVisible="{Binding IsCustomFieldsTabActive}" Margin="0,10,0,0" MaxWidth="800" HorizontalAlignment="Left">
                        <StackPanel Grid.Row="0" Spacing="5" Margin="0,0,0,15">
                            <TextBlock Text="Custom Fields" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="Add extra fields per record type without writing code." Foreground="Gray"/>
                        </StackPanel>

                        <Grid Grid.Row="1" ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,15">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <TextBlock Text="Entity Type:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <ComboBox ItemsSource="{Binding CustomFieldEntityTypes}" SelectedItem="{Binding SelectedCustomFieldEntityType}" Width="180"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="+ Add Field" Command="{Binding OpenAddCustomFieldFormCommand}" Background="#007ACC" Foreground="White" Padding="15,8" FontWeight="SemiBold" CornerRadius="6" IsVisible="{Binding !IsCustomFieldFormVisible}"/>
                        </Grid>

                        <StackPanel Grid.Row="2" Spacing="15">
                            <!-- Add/Edit Field Form -->
                            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="20" CornerRadius="8" IsVisible="{Binding IsCustomFieldFormVisible}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Field Details" FontSize="16" FontWeight="SemiBold"/>
                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Field Label" FontWeight="Medium" FontSize="12"/>
                                        <TextBox Text="{Binding CustomFieldFormLabel}" Watermark="e.g. Grade, Moisture %, Crop Season"/>
                                    </StackPanel>
                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Field Type" FontWeight="Medium" FontSize="12"/>
                                        <ComboBox ItemsSource="{Binding CustomFieldTypeOptions}" SelectedItem="{Binding CustomFieldFormType}" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                    <StackPanel Spacing="5" IsVisible="{Binding IsCustomFieldChoiceOptionsVisible}">
                                        <TextBlock Text="Choice Options (comma-separated)" FontWeight="Medium" FontSize="12"/>
                                        <TextBox Text="{Binding CustomFieldFormChoiceOptions}" Watermark="e.g. A,AA,AB,PB,C"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <TextBlock Text="Required" FontWeight="Medium" FontSize="12" VerticalAlignment="Center"/>
                                        <ToggleSwitch IsChecked="{Binding CustomFieldFormIsRequired}" OnContent="Yes" OffContent="No"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding CustomFieldErrorMessage}" Foreground="#D32F2F" FontSize="12" IsVisible="{Binding CustomFieldErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                                        <Button Content="Cancel" Command="{Binding CloseCustomFieldFormCommand}" Padding="15,8"/>
                                        <Button Content="Save Field" Command="{Binding SaveCustomFieldCommand}" Background="#2E7D32" Foreground="White" Padding="15,8" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Fields List -->
                            <DataGrid ItemsSource="{Binding CustomFieldDefinitions}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="All" BorderThickness="1" BorderBrush="{DynamicResource BorderColor}" MinHeight="200">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Label" Binding="{Binding FieldLabel}" Width="*"/>
                                    <DataGridTextColumn Header="Key" Binding="{Binding FieldKey}" Width="140"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding FieldType}" Width="100"/>
                                    <DataGridTextColumn Header="Required" Binding="{Binding IsRequired}" Width="90"/>
                                    <DataGridTextColumn Header="Active" Binding="{Binding IsActive}" Width="80"/>
                                    <DataGridTemplateColumn Header="Actions" Width="160">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate x:DataType="domain:CustomFieldDefinition">
                                                <StackPanel Orientation="Horizontal" Spacing="5" Margin="5,0">
                                                    <Button Content="Edit" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).OpenEditCustomFieldFormCommand}" CommandParameter="{Binding .}" FontSize="11" Padding="6,3"/>
                                                    <Button Content="Deactivate" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).DeactivateCustomFieldCommand}" CommandParameter="{Binding .}" Background="#D32F2F" Foreground="White" FontSize="11" Padding="6,3"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Grid>

                    <!-- TAB 7: TERMINOLOGY -->
                    <StackPanel Spacing="20" MaxWidth="600" HorizontalAlignment="Left" IsVisible="{Binding IsTerminologyTabActive}">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Terminology" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="Rename common terms to match your business language. Leave blank to use the default label." Foreground="Gray" TextWrapping="Wrap"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding TerminologyTerms}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TerminologyTermItem">
                                    <StackPanel Spacing="5" Margin="0,0,0,12">
                                        <TextBlock Text="{Binding DefaultLabel}" FontWeight="SemiBold"/>
                                        <TextBox Text="{Binding OverrideText}" Watermark="{Binding DefaultLabel}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Orientation="Horizontal" Spacing="15" Margin="0,10,0,0">
                            <Button Content="Save Terminology" Command="{Binding SaveTerminologyCommand}"
                                    Classes="accent" Background="#2E7D32" Foreground="White" Padding="20,10" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding TerminologyStatusMessage}" VerticalAlignment="Center" Foreground="#4CAF50" FontWeight="Medium"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- TAB 8: MODULES -->
                    <StackPanel Spacing="20" MaxWidth="600" HorizontalAlignment="Left" IsVisible="{Binding IsModulesTabActive}">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Modules" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="Turn features on or off based on how your business operates. This is independent of your license tier." Foreground="Gray" TextWrapping="Wrap"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding ModuleToggles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ModuleToggleItem">
                                    <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,12">
                                        <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsEnabled}" OnContent="Enabled" OffContent="Disabled"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Orientation="Horizontal" Spacing="15" Margin="0,10,0,0">
                            <Button Content="Save Modules" Command="{Binding SaveModulesCommand}"
                                    Classes="accent" Background="#2E7D32" Foreground="White" Padding="20,10" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ModulesStatusMessage}" VerticalAlignment="Center" Foreground="#4CAF50" FontWeight="Medium"/>
                        </StackPanel>
                    </StackPanel>
                 </Panel>
            </ScrollViewer>
        </Border>

        <!-- Line Modal Overlay (Open: Lines) -->
        <Grid Grid.Row="0" Grid.RowSpan="3" IsVisible="{Binding IsLineFormVisible}" Background="#AA12131A" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ZIndex="100">
            <Grid.Styles>
                <!-- Force dark background and white text for textboxes inside modal even when focused/hovered -->
                <Style Selector="TextBox">
                    <Setter Property="Background" Value="#262A33"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#3A3F4C"/>
                    <Setter Property="CaretBrush" Value="White"/>
                    <Setter Property="SelectionBrush" Value="#007ACC"/>
                </Style>
                <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                    <Setter Property="Background" Value="#2E333D"/>
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                </Style>
                <Style Selector="TextBox:focus">
                    <Setter Property="Foreground" Value="White"/>
                </Style>
                <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                    <Setter Property="Background" Value="#2E333D"/>
                    <Setter Property="BorderBrush" Value="#4A4F5C"/>
                </Style>
                <Style Selector="TextBox:pointerover">
                    <Setter Property="Foreground" Value="White"/>
                </Style>

                <!-- Style numeric updown internal textbox and buttons -->
                <Style Selector="NumericUpDown">
                    <Setter Property="Background" Value="#262A33"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#3A3F4C"/>
                </Style>
                <Style Selector="NumericUpDown /template/ TextBox">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                </Style>
                <Style Selector="NumericUpDown Button">
                    <Setter Property="Background" Value="#3A3F4C"/>
                    <Setter Property="Foreground" Value="White"/>
                </Style>

                <!-- ComboBox styles -->
                <Style Selector="ComboBox">
                    <Setter Property="Background" Value="#262A33"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#3A3F4C"/>
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                </Style>
                <Style Selector="ComboBox:pointerover">
                    <Setter Property="Background" Value="#2E333D"/>
                    <Setter Property="BorderBrush" Value="#4A4F5C"/>
                    <Setter Property="Foreground" Value="White"/>
                </Style>
                <Style Selector="ComboBox:focus">
                    <Setter Property="Background" Value="#2E333D"/>
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                    <Setter Property="Foreground" Value="White"/>
                </Style>
                <Style Selector="ComboBoxItem">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#262A33"/>
                </Style>
                <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="#007ACC"/>
                    <Setter Property="Foreground" Value="White"/>
                </Style>
                <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
                    <Setter Property="Background" Value="#007ACC"/>
                    <Setter Property="Foreground" Value="White"/>
                </Style>
            </Grid.Styles>

            <Border Width="850" Background="#1D2026" BorderBrush="#303540" BorderThickness="1" CornerRadius="12" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="25" BoxShadow="0 8 24 0 #40000000">
                <StackPanel Spacing="15">
                    <!-- Modal Header -->
                    <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,10">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Open: Lines" FontSize="13" Foreground="Gray" FontWeight="Medium" />
                            <TextBox Text="{Binding LineName}" FontSize="24" FontWeight="Bold" Foreground="White" Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="#40FFFFFF" Padding="0,2" Margin="0,5,0,0" Watermark="Line Name (e.g. Goodwill)" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Top">
                            <Button Content="✕" Command="{Binding DiscardLineCommand}" Background="Transparent" Foreground="Gray" FontSize="14" Cursor="Hand" />
                        </StackPanel>
                    </Grid>

                    <!-- Two Column Metadata fields -->
                    <Grid ColumnDefinitions="*, *" Margin="0,10,0,15">
                        <!-- Left Column -->
                        <StackPanel Grid.Column="0" Spacing="12" Margin="0,0,15,0">
                            <!-- Action -->
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="Action" Foreground="#A0A5B5" FontSize="12" FontWeight="SemiBold" />
                                    <TextBlock Text="?" Foreground="#007ACC" FontSize="12" FontWeight="Bold" ToolTip.Tip="Optional action trigger for interactive reporting." Cursor="Hand" />
                                </StackPanel>
                                <TextBox Text="{Binding LineAction}" Watermark="e.g. Action Name" Height="36"/>
                            </StackPanel>

                            <!-- Level -->
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="Level" Foreground="#A0A5B5" FontSize="12" FontWeight="SemiBold" />
                                    <TextBlock Text="?" Foreground="#007ACC" FontSize="12" FontWeight="Bold" ToolTip.Tip="The nesting level in report hierarchy (e.g. Level 1 for Assets, Level 2 for Current Assets, Level 3 for Cash)" Cursor="Hand" />
                                </StackPanel>
                                <NumericUpDown Value="{Binding LineLevel}" Minimum="1" Maximum="10" Increment="1" Height="36"/>
                            </StackPanel>

                            <!-- Group By -->
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="Group By" Foreground="#A0A5B5" FontSize="12" FontWeight="SemiBold" />
                                    <TextBlock Text="?" Foreground="#007ACC" FontSize="12" FontWeight="Bold" ToolTip.Tip="Field to group the accounts by inside the final report." Cursor="Hand" />
                                </StackPanel>
                                <TextBox Text="{Binding LineGroupBy}" Watermark="Use report's 'Group By'" Height="36"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Right Column -->
                        <StackPanel Grid.Column="1" Spacing="12" Margin="15,0,0,0">
                            <!-- Code -->
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="Code" Foreground="#A0A5B5" FontSize="12" FontWeight="SemiBold" />
                                    <TextBlock Text="?" Foreground="#007ACC" FontSize="12" FontWeight="Bold" ToolTip.Tip="A unique code representing this line in total lines sums computations formulas (e.g. assets_current)" Cursor="Hand" />
                                </StackPanel>
                                <TextBox Text="{Binding LineCode}" Watermark="e.g. rw_goodwill" Height="36"/>
                            </StackPanel>

                            <!-- Foldability -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="Foldability" Foreground="#A0A5B5" FontSize="12" FontWeight="SemiBold" />
                                <ComboBox ItemsSource="{Binding FoldabilityOptions}" SelectedItem="{Binding LineFoldability}" Height="36"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="25" Margin="0,15,0,0">
                                <!-- Print On New Page -->
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <CheckBox IsChecked="{Binding LinePrintOnNewPage}" Foreground="White" />
                                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Text="Print On New Page" Foreground="#A0A5B5" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock Text="?" Foreground="#007ACC" FontSize="12" FontWeight="Bold" ToolTip.Tip="Forces a page break before printing this section." VerticalAlignment="Center" Cursor="Hand" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- Hide if Zero -->
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <CheckBox IsChecked="{Binding LineHideIfZero}" Foreground="White" />
                                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Text="Hide if Zero" Foreground="#A0A5B5" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock Text="?" Foreground="#007ACC" FontSize="12" FontWeight="Bold" ToolTip.Tip="If the balance evaluates to 0, this line won't show on the final printable statement." VerticalAlignment="Center" Cursor="Hand" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Separator Height="1" Background="#303540" Margin="0,5" />

                    <!-- Computations Grid -->
                    <StackPanel Spacing="5">
                        <TextBlock Text="Formula Computations Engine" FontSize="13" FontWeight="Bold" Foreground="White" Margin="0,0,0,5" />
                        <Border BorderBrush="#303540" BorderThickness="1" CornerRadius="8" Background="#16181E" Padding="10">
                            <StackPanel Spacing="8">
                                <!-- Header Row -->
                                <Grid ColumnDefinitions="120, 200, 220, *, Auto" Margin="5,0,5,5">
                                    <TextBlock Grid.Column="0" Text="Label" Foreground="Gray" FontSize="11" FontWeight="Bold" />
                                    <TextBlock Grid.Column="1" Text="Computation Engine" Foreground="Gray" FontSize="11" FontWeight="Bold" />
                                    <TextBlock Grid.Column="2" Text="Formula" Foreground="Gray" FontSize="11" FontWeight="Bold" />
                                    <TextBlock Grid.Column="3" Text="Subformula" Foreground="Gray" FontSize="11" FontWeight="Bold" />
                                </Grid>
                                
                                <!-- Computations Rows -->
                                <ItemsControl ItemsSource="{Binding LineComputations}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="120, 200, 220, *, Auto" Margin="0,4" VerticalAlignment="Center">
                                                <TextBox Grid.Column="0" Text="{Binding Label}" Margin="0,0,5,0" Height="30" FontSize="12" />
                                                <ComboBox Grid.Column="1" ItemsSource="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).ComputationEngineOptions}" SelectedItem="{Binding ComputationEngine}" Margin="0,0,5,0" Height="30" FontSize="11" />
                                                <TextBox Grid.Column="2" Text="{Binding Formula}" Watermark="e.g. 101,102\(1021) or assets" Margin="0,0,5,0" Height="30" FontSize="12" />
                                                <TextBox Grid.Column="3" Text="{Binding Subformula}" Margin="0,0,5,0" Height="30" FontSize="12" />
                                                <Button Grid.Column="4" Content="🗑" Foreground="#D32F2F" Background="Transparent" Width="30" Height="30" CornerRadius="4" Cursor="Hand" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).RemoveComputationRowCommand}" CommandParameter="{Binding .}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Add a line link -->
                                <Button Content="Add a line" Command="{Binding AddComputationRowCommand}" Background="Transparent" Foreground="#009688" BorderThickness="0" FontSize="12" FontWeight="SemiBold" Cursor="Hand" HorizontalAlignment="Left" Margin="5,5,0,0">
                                    <Button.Styles>
                                        <Style Selector="Button:pointerover">
                                            <Setter Property="Foreground" Value="#00796B"/>
                                            <Setter Property="Background" Value="#10009688"/>
                                        </Style>
                                    </Button.Styles>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Save & Discard buttons at bottom -->
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Left" Margin="0,15,0,0">
                        <Button Content="Save" Command="{Binding SaveLineCommand}" Background="#7B1FA2" Foreground="White" Padding="25,8" FontWeight="SemiBold" CornerRadius="6" Cursor="Hand" />
                        <Button Content="Discard" Command="{Binding DiscardLineCommand}" Background="#3A3F4C" Foreground="White" Padding="20,8" CornerRadius="6" Cursor="Hand" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
