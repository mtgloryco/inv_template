<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:InventoryManagementSystem.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="800"
             x:Class="InventoryManagementSystem.UI.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <Grid>
        <ScrollViewer>
            <StackPanel Spacing="25" Margin="30">
                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="{Binding WelcomeMessage}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryColor}"/>
                            <TextBlock Text="{Binding AppVersion}" FontSize="12" Foreground="#EF4444" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Here's what's happening in your inventory today." Foreground="{DynamicResource TextSecondaryColor}" Margin="0,5,0,0"/>
                    </StackPanel>
                    
                    <Button Grid.Column="1" Command="{Binding LoadDashboardDataCommand}" Content="Refresh" Background="Transparent" Foreground="#007ACC" BorderThickness="0"/>
                </Grid>

                <!-- Daily Briefing (Phase 11.1) -->
                <StackPanel Spacing="10" IsVisible="{Binding Briefing.Count}">
                    <TextBlock Text="Morning Briefing" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryColor}"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Briefing}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="15"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="280" Padding="15" CornerRadius="12" BoxShadow="0 4 12 0 #08000000" Background="{DynamicResource ContentBackgroundColor}">
                                        <Grid ColumnDefinitions="Auto, *">
                                            <TextBlock Text="{Binding Icon}" FontSize="24" VerticalAlignment="Top" Margin="0,0,12,0"/>
                                            <StackPanel Grid.Column="1" Spacing="8">
                                                <TextBlock Text="{Binding Priority}" FontSize="10" FontWeight="Bold" Foreground="#888" TextAlignment="Right"/>
                                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryColor}"/>
                                                <Button Content="{Binding ActionLabel}" Height="30" FontSize="11" Padding="15,0" HorizontalAlignment="Left" Background="#f0f0f0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

                <!-- Low Stock Alert -->
                <Border Background="#FFEBEE" BorderBrush="#FF5252" BorderThickness="1" CornerRadius="8" Padding="15" IsVisible="{Binding LowStockCount}">
                    <Grid ColumnDefinitions="Auto, *">
                        <TextBlock Text="⚠️" FontSize="20" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Low Stock Warning" FontWeight="Bold" Foreground="#D32F2F"/>
                            <TextBlock Text="{Binding LowStockCount, StringFormat='{}{0} items are running low on stock. Check Inventory.'}" Foreground="#D32F2F" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Financial Cards -->
                <Grid ColumnDefinitions="*,15,*,15,*" RowDefinitions="Auto">
                    <Border Grid.Column="0" Background="{DynamicResource ContentBackgroundColor}" CornerRadius="8" Padding="20" BoxShadow="0 4 10 0 #10000000">
                        <StackPanel>
                            <TextBlock Text="Total Revenue" Foreground="{DynamicResource TextSecondaryColor}" FontSize="14"/>
                            <TextBlock FontSize="28" FontWeight="Bold" Foreground="#2E7D32" Margin="0,5,0,0">
                                <Run Text="{Binding TotalRevenue, StringFormat={}{0:N0}}"/>
                                <Run Text="{Binding CurrencySymbol}" FontSize="18"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="{DynamicResource ContentBackgroundColor}" CornerRadius="8" Padding="20" BoxShadow="0 4 10 0 #10000000">
                        <StackPanel>
                            <TextBlock Text="Total Profit" Foreground="{DynamicResource TextSecondaryColor}" FontSize="14"/>
                            <Panel>
                                <TextBlock FontSize="28" FontWeight="Bold" Foreground="#007ACC" Margin="0,5,0,0" IsVisible="{Binding ShowFinancials}">
                                    <Run Text="{Binding TotalProfit, StringFormat={}{0:N0}}"/>
                                    <Run Text="{Binding CurrencySymbol}" FontSize="18"/>
                                </TextBlock>
                                <TextBlock Text="LOCKED" FontSize="24" FontWeight="Bold" Foreground="#CCC" Margin="0,5,0,0" IsVisible="{Binding HideFinancials}"/>
                            </Panel>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Background="{DynamicResource ContentBackgroundColor}" CornerRadius="8" Padding="20" BoxShadow="0 4 10 0 #10000000">
                        <StackPanel>
                            <TextBlock Text="Inventory Value" Foreground="{DynamicResource TextSecondaryColor}" FontSize="14"/>
                            <TextBlock FontSize="28" FontWeight="Bold" Foreground="#F57C00" Margin="0,5,0,0">
                                <Run Text="{Binding TotalInventoryValue, StringFormat={}{0:N0}}"/>
                                <Run Text="{Binding CurrencySymbol}" FontSize="18"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Operational Cards -->
                <Grid ColumnDefinitions="*,15,*,15,*" RowDefinitions="Auto">
                    <Border Grid.Column="0" Background="{DynamicResource ContentBackgroundColor}" CornerRadius="8" Padding="20" BoxShadow="0 4 10 0 #10000000">
                        <StackPanel>
                            <TextBlock Text="Total Products" Foreground="{DynamicResource TextSecondaryColor}" FontSize="14"/>
                            <TextBlock Text="{Binding TotalProducts}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryColor}" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="{DynamicResource ContentBackgroundColor}" CornerRadius="8" Padding="20" BoxShadow="0 4 10 0 #10000000">
                        <StackPanel>
                            <TextBlock Text="Low Stock Alerts" Foreground="{DynamicResource TextSecondaryColor}" FontSize="14"/>
                            <TextBlock Text="{Binding LowStockCount}" FontSize="28" FontWeight="Bold" Foreground="#FF5252" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Background="{DynamicResource ContentBackgroundColor}" CornerRadius="8" Padding="20" BoxShadow="0 4 10 0 #10000000">
                        <StackPanel>
                            <TextBlock Text="License Tier" Foreground="{DynamicResource TextSecondaryColor}" FontSize="14"/>
                            <TextBlock Text="{Binding LicenseTypeDisplay}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryColor}" Margin="0,5,0,0"/>
                            <TextBlock Text="{Binding LicenseStatusDisplay}" Foreground="#4CAF50" FontSize="12" Margin="0,5,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Quick Actions -->
                <StackPanel Spacing="15">
                    <TextBlock Text="{Binding Language.Resources[QuickActions]}" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource TextPrimaryColor}"/>
                    <StackPanel Orientation="Horizontal" Spacing="30">
                         <Button Classes="action-btn" Command="{Binding OpenAddProductModal}">
                             <StackPanel>
                                 <TextBlock Text="+" FontSize="24" HorizontalAlignment="Center" Foreground="#007ACC"/>
                                 <TextBlock Text="{Binding Language.Resources[AddProduct]}" FontSize="12"/>
                             </StackPanel>
                         </Button>
                         <Button Classes="action-btn" Command="{Binding OpenStockModal}" CommandParameter="IN">
                             <StackPanel>
                                 <TextBlock Text="⬇" FontSize="24" HorizontalAlignment="Center" Foreground="#2E7D32"/>
                                 <TextBlock Text="{Binding Language.Resources[StockIN]}" FontSize="12"/>
                             </StackPanel>
                         </Button>
                         <Button Classes="action-btn" Command="{Binding OpenStockModal}" CommandParameter="OUT">
                             <StackPanel>
                                 <TextBlock Text="⬆" FontSize="24" HorizontalAlignment="Center" Foreground="#D32F2F"/>
                                 <TextBlock Text="{Binding Language.Resources[StockOUT]}" FontSize="12"/>
                             </StackPanel>
                         </Button>
                         <Button Classes="action-btn" Command="{Binding RunBulkImport}" IsEnabled="{Binding CanBulkImport}" Opacity="{Binding CanBulkImport, Converter={x:Static ObjectConverters.IsNull}}"> 
                             <StackPanel>
                                 <TextBlock Text="📂" FontSize="24" HorizontalAlignment="Center" Foreground="#FF9800"/>
                                 <TextBlock Text="{Binding Language.Resources[BulkImport]}" FontSize="12"/>
                             </StackPanel>
                             <ToolTip.Tip>Import Products from CSV (Premium)</ToolTip.Tip>
                         </Button>
                         <Button Classes="action-btn" Command="{Binding GoToReportsCommand}" IsEnabled="{Binding CanViewReports}">
                             <StackPanel>
                                 <TextBlock Text="📊" FontSize="24" HorizontalAlignment="Center" Foreground="#607D8B"/>
                                 <TextBlock Text="{Binding Language.Resources[Reports]}" FontSize="12"/>
                             </StackPanel>
                         </Button>
                         <Button Classes="action-btn" Command="{Binding GoToPOSCommand}" IsEnabled="{Binding CanAccessPOS}">
                             <StackPanel>
                                 <TextBlock Text="🛒" FontSize="24" HorizontalAlignment="Center" Foreground="#607D8B"/>
                                 <TextBlock Text="{Binding Language.Resources[POS]}" FontSize="12"/>
                             </StackPanel>
                         </Button>
                    </StackPanel>
                </StackPanel>

            <!-- Recent Activity Table -->
            <StackPanel Spacing="10">
                <TextBlock Text="{Binding Language.Resources[RecentMovements]}" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource TextPrimaryColor}"/>
                    <Border Background="{DynamicResource ContentBackgroundColor}" CornerRadius="8" BoxShadow="0 2 8 0 #08000000" ClipToBounds="True">
                        <StackPanel>
                            <Grid ColumnDefinitions="50,*,*,*,*,*" Background="{DynamicResource PageBackgroundColor}" Height="40">
                                <TextBlock Text="#" FontWeight="SemiBold" VerticalAlignment="Center" Margin="15,0"/>
                                <TextBlock Text="Product ID" Grid.Column="1" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Text="Type" Grid.Column="2" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Text="Qty" Grid.Column="3" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Text="User" Grid.Column="4" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Text="Date" Grid.Column="5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding RecentMovements}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1">
                                            <Grid ColumnDefinitions="50,*,*,*,*,*" Height="45" Background="Transparent">
                                                <TextBlock Text="{Binding Id}" VerticalAlignment="Center" Margin="15,0" Foreground="{DynamicResource TextSecondaryColor}"/>
                                                <TextBlock Text="{Binding ProductId}" Grid.Column="1" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding MovementType}" Grid.Column="2" VerticalAlignment="Center" FontWeight="Medium"/>
                                                <TextBlock Text="{Binding QuantityChanged}" Grid.Column="3" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Username}" Grid.Column="4" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryColor}"/>
                                                <TextBlock Text="{Binding Date, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Grid.Column="5" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryColor}" FontSize="12"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="No recent movements found." IsVisible="{Binding !HasMovements}" HorizontalAlignment="Center" Margin="20" Foreground="#999"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- MODAL OVERLAY (Quick Actions) -->
        <Border Background="#44000000" IsVisible="{Binding IsModalOpen}">
            <Border Background="{DynamicResource ContentBackgroundColor}" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center" Width="450" Padding="30" BoxShadow="0 10 40 0 #44000000">
                <StackPanel Spacing="20">
                    <TextBlock Text="{Binding ModalTitle}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryColor}"/>
                    <Separator Height="1" Background="{DynamicResource BorderColor}"/>

                    <StackPanel Spacing="15" IsVisible="{Binding ShowProductForm}">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Product Name" FontSize="12" Foreground="#888"/>
                            <TextBox Text="{Binding FormProduct.Name}" Watermark="Enter product name"/>
                        </StackPanel>
                        <Grid ColumnDefinitions="*, 15, *">
                            <StackPanel Grid.Column="0" Spacing="5">
                                <TextBlock Text="SKU" FontSize="12" Foreground="#888"/>
                                <TextBox Text="{Binding FormProduct.SKU}" Watermark="Optional SKU"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="5">
                                <TextBlock Text="Category" FontSize="12" Foreground="#888"/>
                                <TextBox Text="{Binding FormProduct.Category}" Watermark="General"/>
                            </StackPanel>
                        </Grid>
                        <Grid ColumnDefinitions="*, 15, *">
                            <StackPanel Grid.Column="0" Spacing="5">
                                <TextBlock Text="Price" FontSize="12" Foreground="#888"/>
                                <TextBox Text="{Binding FormProduct.Price}" Watermark="0.00"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="5">
                                <TextBlock Text="Cost" FontSize="12" Foreground="#888"/>
                                <TextBox Text="{Binding FormProduct.Cost}" Watermark="0.00"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="15" IsVisible="{Binding ShowStockForm}">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Select Product" FontSize="12" Foreground="#888"/>
                            <ComboBox ItemsSource="{Binding AllProducts}" SelectedItem="{Binding SelectedTargetProduct}" HorizontalAlignment="Stretch" PlaceholderText="Choose product...">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Spacing="5">
                            <TextBlock Text="Quantity" FontSize="12" Foreground="#888"/>
                            <TextBox Text="{Binding AdjQuantity}" Watermark="Enter quantity"/>
                        </StackPanel>
                         <StackPanel Spacing="5" IsVisible="{Binding IsStockIn}">
                            <!-- Show Cost Price only for STOCK IN to update master cost -->
                             <TextBlock Text="Buying Price (Unit Cost)" FontSize="12" Foreground="#888"/>
                             <TextBox Text="{Binding AdjCostPrice}" Watermark="Unit Cost Update..."/> 
                             
                             <!-- Allow updating Selling Price too -->
                             <TextBlock Text="Selling Price (Update Master)" FontSize="12" Foreground="#888"/>
                             <TextBox Text="{Binding AdjSellingPrice}" Watermark="New Selling Price..."/>
                        </StackPanel>

                         <StackPanel Spacing="5" IsVisible="{Binding IsStockOut}">
                            <!-- Show Selling Price only for STOCK OUT to verify revenue -->
                            <TextBlock Text="Selling Price (Per Unit)" FontSize="12" Foreground="#888"/>
                             <TextBox Text="{Binding AdjSellingPrice}" Watermark="Price per unit"/>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Reason" FontSize="12" Foreground="#888"/>
                            <TextBox Text="{Binding AdjReason}" Watermark="Optional reason..."/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="{Binding ModalError}" Foreground="#FF5252" FontSize="13" TextWrapping="Wrap" IsVisible="{Binding ModalError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <Grid ColumnDefinitions="*, 10, *">
                        <Button Grid.Column="0" Content="Cancel" Command="{Binding CloseModalCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#F5F5F5"/>
                        <Button Grid.Column="2" Content="Save Action" Command="{Binding SaveModalCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- IMPORT PROGRESS OVERLAY -->
        <Border Background="#AA000000" IsVisible="{Binding IsImporting}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="15">
                <TextBlock Text="Importing Products..." Foreground="White" FontSize="18" HorizontalAlignment="Center"/>
                <ProgressBar Value="{Binding ImportProgress}" Minimum="0" Maximum="100" Width="300" Height="20" ShowProgressText="True"/>
                <TextBlock Text="Please wait while we process your file." Foreground="#CCC" FontSize="12" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- IMPORT SUMMARY MODAL -->
        <Border Background="#44000000" IsVisible="{Binding ShowImportSummary}">
            <Border Background="White" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center" Width="400" Padding="30" BoxShadow="0 10 40 0 #44000000">
                <StackPanel Spacing="20">
                    <TextBlock Text="Import Summary" FontSize="20" FontWeight="Bold" Foreground="#333"/>
                    <Separator Height="1" Background="#EEE"/>
                    
                    <ScrollViewer MaxHeight="300">
                         <TextBlock Text="{Binding ImportSummaryText}" TextWrapping="Wrap" LineHeight="20" Foreground="#555"/>
                    </ScrollViewer>

                    <Button Content="Dismiss" Command="{Binding CloseImportSummaryCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#007ACC" Foreground="White" FontWeight="Bold" Height="40"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
