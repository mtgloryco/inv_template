<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:InventoryManagementSystem.UI.ViewModels"
             xmlns:helpers="using:InventoryManagementSystem.UI.Helpers"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="800"
             x:Class="InventoryManagementSystem.UI.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <Grid>
        <ScrollViewer>
            <StackPanel Spacing="25" Margin="30">
                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="{Binding WelcomeMessage}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryColor}"/>
                            <TextBlock Text="{Binding AppVersion}" FontSize="12" Foreground="#EF4444" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Here's what's happening in your inventory today." Foreground="{DynamicResource TextSecondaryColor}" Margin="0,5,0,0"/>
                    </StackPanel>
                    
                    <Button Grid.Column="1" Command="{Binding LoadDashboardDataCommand}" Content="Refresh" Background="Transparent" Foreground="#007ACC" BorderThickness="0"/>
                </Grid>

                <!-- Daily Briefing (Phase 11.1) -->
                <StackPanel Spacing="10" IsVisible="{Binding Briefing.Count}">
                    <TextBlock Text="Morning Briefing" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryColor}"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Briefing}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="15"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="280" Padding="15" CornerRadius="12" BoxShadow="0 4 12 0 #08000000" Background="{DynamicResource ContentBackgroundColor}">
                                        <Grid ColumnDefinitions="Auto, *">
                                            <TextBlock Text="{Binding Icon}" FontSize="24" VerticalAlignment="Top" Margin="0,0,12,0"/>
                                            <StackPanel Grid.Column="1" Spacing="8">
                                                <TextBlock Text="{Binding Priority}" FontSize="10" FontWeight="Bold" Foreground="#888" TextAlignment="Right"/>
                                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryColor}"/>
                                                <Button Content="{Binding ActionLabel}" Height="30" FontSize="11" Padding="15,0" HorizontalAlignment="Left" Background="#f0f0f0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

                <!-- Low Stock Alert -->
                <Border Background="#FFEBEE" BorderBrush="#FF5252" BorderThickness="1" CornerRadius="8" Padding="15" IsVisible="{Binding LowStockCount}">
                    <Grid ColumnDefinitions="Auto, *">
                        <TextBlock Text="⚠️" FontSize="20" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Low Stock Warning" FontWeight="Bold" Foreground="#D32F2F"/>
                            <TextBlock Text="{Binding LowStockCount, StringFormat='{}{0} items are running low on stock. Check Inventory.'}" Foreground="#D32F2F" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Financial Cards -->
                <Grid ColumnDefinitions="*,15,*,15,*" RowDefinitions="Auto">
                    <!-- Total Revenue Card -->
                    <Border Grid.Column="0" Background="{DynamicResource ContentBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" ClipToBounds="True" BoxShadow="0 2 8 0 #0A000000">
                        <Grid ColumnDefinitions="4, *">
                            <Rectangle Grid.Column="0" Fill="#10B981" VerticalAlignment="Stretch"/>
                            <StackPanel Grid.Column="1" Margin="20,15">
                                <TextBlock Text="Total Revenue" Foreground="{DynamicResource TextSecondaryColor}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock FontSize="26" FontWeight="Bold" Foreground="#10B981" Margin="0,5,0,0">
                                    <Run Text="{Binding TotalRevenue, StringFormat={}{0:N0}}"/>
                                    <Run Text="{Binding CurrencySymbol}" FontSize="16"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!-- Total Profit Card -->
                    <Border Grid.Column="2" Background="{DynamicResource ContentBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" ClipToBounds="True" BoxShadow="0 2 8 0 #0A000000">
                        <Grid ColumnDefinitions="4, *">
                            <Rectangle Grid.Column="0" Fill="#6366F1" VerticalAlignment="Stretch"/>
                            <StackPanel Grid.Column="1" Margin="20,15">
                                <TextBlock Text="Total Profit" Foreground="{DynamicResource TextSecondaryColor}" FontSize="13" FontWeight="SemiBold"/>
                                <Panel Margin="0,5,0,0">
                                    <TextBlock FontSize="26" FontWeight="Bold" Foreground="#6366F1" IsVisible="{Binding ShowFinancials}">
                                        <Run Text="{Binding TotalProfit, StringFormat={}{0:N0}}"/>
                                        <Run Text="{Binding CurrencySymbol}" FontSize="16"/>
                                    </TextBlock>
                                    <TextBlock Text="LOCKED" FontSize="20" FontWeight="Bold" Foreground="#94A3B8" IsVisible="{Binding HideFinancials}"/>
                                </Panel>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!-- Inventory Value Card -->
                    <Border Grid.Column="4" Background="{DynamicResource ContentBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" ClipToBounds="True" BoxShadow="0 2 8 0 #0A000000">
                        <Grid ColumnDefinitions="4, *">
                            <Rectangle Grid.Column="0" Fill="#F59E0B" VerticalAlignment="Stretch"/>
                            <StackPanel Grid.Column="1" Margin="20,15">
                                <TextBlock Text="Inventory Value" Foreground="{DynamicResource TextSecondaryColor}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock FontSize="26" FontWeight="Bold" Foreground="#F59E0B" Margin="0,5,0,0">
                                    <Run Text="{Binding TotalInventoryValue, StringFormat={}{0:N0}}"/>
                                    <Run Text="{Binding CurrencySymbol}" FontSize="16"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Operational Cards -->
                <Grid ColumnDefinitions="*,15,*,15,*" RowDefinitions="Auto">
                    <!-- Total Products Card -->
                    <Border Grid.Column="0" Background="{DynamicResource ContentBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" ClipToBounds="True" BoxShadow="0 2 8 0 #0A000000">
                        <Grid ColumnDefinitions="4, *">
                            <Rectangle Grid.Column="0" Fill="#3B82F6" VerticalAlignment="Stretch"/>
                            <StackPanel Grid.Column="1" Margin="20,15">
                                <TextBlock Text="Total Products" Foreground="{DynamicResource TextSecondaryColor}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding TotalProducts}" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryColor}" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!-- Low Stock Alerts Card -->
                    <Border Grid.Column="2" Background="{DynamicResource ContentBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" ClipToBounds="True" BoxShadow="0 2 8 0 #0A000000">
                        <Grid ColumnDefinitions="4, *">
                            <Rectangle Grid.Column="0" Fill="#F43F5E" VerticalAlignment="Stretch"/>
                            <StackPanel Grid.Column="1" Margin="20,15">
                                <TextBlock Text="Low Stock Alerts" Foreground="{DynamicResource TextSecondaryColor}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding LowStockCount}" FontSize="26" FontWeight="Bold" Foreground="#F43F5E" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!-- License Tier Card -->
                    <Border Grid.Column="4" Background="{DynamicResource ContentBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" ClipToBounds="True" BoxShadow="0 2 8 0 #0A000000">
                        <Grid ColumnDefinitions="4, *">
                            <Rectangle Grid.Column="0" Fill="#8B5CF6" VerticalAlignment="Stretch"/>
                            <StackPanel Grid.Column="1" Margin="20,15">
                                <TextBlock Text="License Tier" Foreground="{DynamicResource TextSecondaryColor}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding LicenseTypeDisplay}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryColor}" Margin="0,5,0,0"/>
                                <TextBlock Text="{Binding LicenseStatusDisplay}" Foreground="#10B981" FontSize="11" Margin="0,5,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Analytics Graphs -->
                <Grid ColumnDefinitions="*, 20, *" Margin="0,10,0,10">
                    <!-- Column 0: Sales Trend Chart -->
                    <Border Grid.Column="0" Background="{DynamicResource ContentBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="20" BoxShadow="0 2 8 0 #0A000000">
                        <StackPanel Spacing="15">
                            <TextBlock Text="Sales Trends (Last 7 Days)" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryColor}"/>
                            <Grid Height="150" VerticalAlignment="Bottom">
                                <ItemsControl ItemsSource="{Binding SalesTrendBars}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1" VerticalAlignment="Bottom"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:DashboardChartBar">
                                            <Grid RowDefinitions="*, Auto" Margin="5,0" VerticalAlignment="Bottom">
                                                <StackPanel Grid.Row="0" Spacing="4" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding ValueDisplay}" FontSize="9" FontWeight="SemiBold" Foreground="Gray" HorizontalAlignment="Center"/>
                                                    <Border Height="{Binding BarHeight}" CornerRadius="4 4 0 0" Width="30" HorizontalAlignment="Center">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Offset="0" Color="#4F46E5"/>
                                                                <GradientStop Offset="1" Color="#818CF8"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Grid.Row="1" Text="{Binding Label}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,6,0,0" Foreground="{DynamicResource TextSecondaryColor}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Column 2: Top Stocks Chart -->
                    <Border Grid.Column="2" Background="{DynamicResource ContentBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="20" BoxShadow="0 2 8 0 #0A000000">
                        <StackPanel Spacing="15">
                            <TextBlock Text="Top Product Stock Levels" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryColor}"/>
                            <Grid Height="150" VerticalAlignment="Bottom">
                                <ItemsControl ItemsSource="{Binding StockLevelBars}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1" VerticalAlignment="Bottom"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:DashboardChartBar">
                                            <Grid RowDefinitions="*, Auto" Margin="5,0" VerticalAlignment="Bottom">
                                                <StackPanel Grid.Row="0" Spacing="4" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding ValueDisplay}" FontSize="9" FontWeight="SemiBold" Foreground="Gray" HorizontalAlignment="Center"/>
                                                    <Border Height="{Binding BarHeight}" CornerRadius="4 4 0 0" Width="30" HorizontalAlignment="Center">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Offset="0" Color="#10B981"/>
                                                                <GradientStop Offset="1" Color="#34D399"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Grid.Row="1" Text="{Binding Label}" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,6,0,0" Foreground="{DynamicResource TextSecondaryColor}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Quick Actions -->
                <StackPanel Spacing="15">
                    <TextBlock Text="{Binding Language.Resources[QuickActions]}" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource TextPrimaryColor}"/>
                    <StackPanel Orientation="Horizontal" Spacing="30">
                         <Button Classes="action-btn" Command="{Binding OpenAddProductModal}">
                             <StackPanel>
                                 <TextBlock Text="+" FontSize="24" HorizontalAlignment="Center" Foreground="#007ACC"/>
                                 <TextBlock Text="{Binding Language.Resources[AddProduct]}" FontSize="12"/>
                             </StackPanel>
                         </Button>
                         <Button Classes="action-btn" Command="{Binding OpenStockModal}" CommandParameter="IN">
                             <StackPanel>
                                 <TextBlock Text="⬇" FontSize="24" HorizontalAlignment="Center" Foreground="#2E7D32"/>
                                 <TextBlock Text="{Binding Language.Resources[StockIN]}" FontSize="12"/>
                             </StackPanel>
                         </Button>
                         <Button Classes="action-btn" Command="{Binding OpenStockModal}" CommandParameter="OUT">
                             <StackPanel>
                                 <TextBlock Text="⬆" FontSize="24" HorizontalAlignment="Center" Foreground="#D32F2F"/>
                                 <TextBlock Text="{Binding Language.Resources[StockOUT]}" FontSize="12"/>
                             </StackPanel>
                         </Button>
                         <Button Classes="action-btn" Command="{Binding RunBulkImport}" IsEnabled="{Binding CanBulkImport}" Opacity="{Binding CanBulkImport, Converter={x:Static ObjectConverters.IsNull}}"> 
                             <StackPanel>
                                 <TextBlock Text="📂" FontSize="24" HorizontalAlignment="Center" Foreground="#FF9800"/>
                                 <TextBlock Text="{Binding Language.Resources[BulkImport]}" FontSize="12"/>
                             </StackPanel>
                             <ToolTip.Tip>Import Products from CSV (Premium)</ToolTip.Tip>
                         </Button>
                         <Button Classes="action-btn" Command="{Binding GoToReportsCommand}" IsEnabled="{Binding CanViewReports}">
                             <StackPanel>
                                 <TextBlock Text="📊" FontSize="24" HorizontalAlignment="Center" Foreground="#607D8B"/>
                                 <TextBlock Text="{Binding Language.Resources[Reports]}" FontSize="12"/>
                             </StackPanel>
                         </Button>
                         <Button Classes="action-btn" Command="{Binding GoToPOSCommand}" IsEnabled="{Binding CanAccessPOS}">
                             <StackPanel>
                                 <TextBlock Text="🛒" FontSize="24" HorizontalAlignment="Center" Foreground="#607D8B"/>
                                 <TextBlock Text="{Binding Language.Resources[POS]}" FontSize="12"/>
                             </StackPanel>
                         </Button>
                    </StackPanel>
                          <!-- Recent Activity Table -->
            <StackPanel Spacing="10">
                <TextBlock Text="{Binding Language.Resources[RecentMovements]}" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource TextPrimaryColor}"/>
                <Border Background="{DynamicResource ContentBackgroundColor}" CornerRadius="8" BoxShadow="0 2 8 0 #0A000000" Padding="15">
                    <Grid RowDefinitions="*, Auto">
                        <DataGrid Grid.Row="0" ItemsSource="{Binding RecentMovementRows}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" Height="280" IsVisible="{Binding HasMovements}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="60"/>
                                <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="2*"/>
                                <DataGridTemplateColumn Header="Type" Width="1.2*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Center" VerticalAlignment="Center" Tag="{Binding MovementType}">
                                                <Border.Styles>
                                                    <Style Selector="Border[Tag=IN]">
                                                        <Setter Property="Background" Value="#E6F4EA"/>
                                                        <Setter Property="TextBlock.Foreground" Value="#137333"/>
                                                    </Style>
                                                    <Style Selector="Border[Tag=OUT]">
                                                        <Setter Property="Background" Value="#FCE8E6"/>
                                                        <Setter Property="TextBlock.Foreground" Value="#C5221F"/>
                                                     </Style>
                                                     <Style Selector="Border[Tag=ADJUST]">
                                                         <Setter Property="Background" Value="#FEF7E0"/>
                                                         <Setter Property="TextBlock.Foreground" Value="#B06000"/>
                                                     </Style>
                                                 </Border.Styles>
                                                 <TextBlock Text="{Binding MovementType}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                             </Border>
                                         </DataTemplate>
                                     </DataGridTemplateColumn.CellTemplate>
                                 </DataGridTemplateColumn>
                                 <DataGridTextColumn Header="Qty" Binding="{Binding QuantityChanged}" Width="1*"/>
                                 <DataGridTextColumn Header="User" Binding="{Binding Username}" Width="1.5*"/>
                                 <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="2*"/>
                             </DataGrid.Columns>
                         </DataGrid>
                         <TextBlock Grid.Row="1" Text="No recent movements found." IsVisible="{Binding !HasMovements}" HorizontalAlignment="Center" Margin="20" Foreground="#999"/>
                     </Grid>
                 </Border>
             </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- MODAL OVERLAY (Quick Actions) -->
        <Border Background="#44000000" IsVisible="{Binding IsModalOpen}">
            <Border Background="{DynamicResource ContentBackgroundColor}" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center" MinWidth="350" MinHeight="300" Width="480" Height="550" Padding="30" BoxShadow="0 10 40 0 #44000000" helpers:ResizableHelper.CanResize="True">
                <StackPanel Spacing="20">
                    <TextBlock Text="{Binding ModalTitle}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryColor}"/>
                    <Separator Height="1" Background="{DynamicResource BorderColor}"/>

                    <StackPanel Spacing="15" IsVisible="{Binding ShowProductForm}">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Product Name" FontSize="12" Foreground="#888"/>
                            <TextBox Text="{Binding FormProduct.Name}" Watermark="Enter product name"/>
                        </StackPanel>
                        <Grid ColumnDefinitions="*, 15, *">
                            <StackPanel Grid.Column="0" Spacing="5">
                                <TextBlock Text="SKU" FontSize="12" Foreground="#888"/>
                                <TextBox Text="{Binding FormProduct.SKU}" Watermark="Optional SKU"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="5">
                                <TextBlock Text="Category" FontSize="12" Foreground="#888"/>
                                <TextBox Text="{Binding FormProduct.Category}" Watermark="General"/>
                            </StackPanel>
                        </Grid>
                        <Grid ColumnDefinitions="*, 15, *">
                            <StackPanel Grid.Column="0" Spacing="5">
                                <TextBlock Text="Price" FontSize="12" Foreground="#888"/>
                                <TextBox Text="{Binding FormProduct.Price}" Watermark="0.00"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="5">
                                <TextBlock Text="Cost" FontSize="12" Foreground="#888"/>
                                <TextBox Text="{Binding FormProduct.Cost}" Watermark="0.00"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="15" IsVisible="{Binding ShowStockForm}">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Select Product" FontSize="12" Foreground="#888"/>
                            <ComboBox ItemsSource="{Binding AllProducts}" SelectedItem="{Binding SelectedTargetProduct}" HorizontalAlignment="Stretch" PlaceholderText="Choose product...">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Spacing="5">
                            <TextBlock Text="Quantity" FontSize="12" Foreground="#888"/>
                            <TextBox Text="{Binding AdjQuantity}" Watermark="Enter quantity"/>
                        </StackPanel>
                         <StackPanel Spacing="5" IsVisible="{Binding IsStockIn}">
                            <!-- Show Cost Price only for STOCK IN to update master cost -->
                             <TextBlock Text="Buying Price (Unit Cost)" FontSize="12" Foreground="#888"/>
                             <TextBox Text="{Binding AdjCostPrice}" Watermark="Unit Cost Update..."/> 
                             
                             <!-- Allow updating Selling Price too -->
                             <TextBlock Text="Selling Price (Update Master)" FontSize="12" Foreground="#888"/>
                             <TextBox Text="{Binding AdjSellingPrice}" Watermark="New Selling Price..."/>
                        </StackPanel>

                         <StackPanel Spacing="5" IsVisible="{Binding IsStockOut}">
                            <!-- Show Selling Price only for STOCK OUT to verify revenue -->
                            <TextBlock Text="Selling Price (Per Unit)" FontSize="12" Foreground="#888"/>
                             <TextBox Text="{Binding AdjSellingPrice}" Watermark="Price per unit"/>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Reason" FontSize="12" Foreground="#888"/>
                            <TextBox Text="{Binding AdjReason}" Watermark="Optional reason..."/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="{Binding ModalError}" Foreground="#FF5252" FontSize="13" TextWrapping="Wrap" IsVisible="{Binding ModalError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <Grid ColumnDefinitions="*, 10, *">
                        <Button Grid.Column="0" Content="Cancel" Command="{Binding CloseModalCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#F5F5F5"/>
                        <Button Grid.Column="2" Content="Save Action" Command="{Binding SaveModalCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- IMPORT PROGRESS OVERLAY -->
        <Border Background="#AA000000" IsVisible="{Binding IsImporting}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="15">
                <TextBlock Text="Importing Products..." Foreground="White" FontSize="18" HorizontalAlignment="Center"/>
                <ProgressBar Value="{Binding ImportProgress}" Minimum="0" Maximum="100" Width="300" Height="20" ShowProgressText="True"/>
                <TextBlock Text="Please wait while we process your file." Foreground="#CCC" FontSize="12" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- IMPORT SUMMARY MODAL -->
        <Border Background="#44000000" IsVisible="{Binding ShowImportSummary}">
            <Border Background="White" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center" Width="400" Padding="30" BoxShadow="0 10 40 0 #44000000">
                <StackPanel Spacing="20">
                    <TextBlock Text="Import Summary" FontSize="20" FontWeight="Bold" Foreground="#333"/>
                    <Separator Height="1" Background="#EEE"/>
                    
                    <ScrollViewer MaxHeight="300">
                         <TextBlock Text="{Binding ImportSummaryText}" TextWrapping="Wrap" LineHeight="20" Foreground="#555"/>
                    </ScrollViewer>

                    <Button Content="Dismiss" Command="{Binding CloseImportSummaryCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#007ACC" Foreground="White" FontWeight="Bold" Height="40"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
